<header class="site-header" data-header>
  <div class="site-header__inner">
    <button class="site-header__menu-toggle" type="button" aria-label="{{ 'general.accessibility.menu' | t }}" data-menu-toggle>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>

    <nav class="site-header__nav" data-mobile-nav aria-label="القائمة الرئيسية">
      <a href="{{ routes.account_url }}" class="site-header__nav-link">حسابج</a>
      <button type="button" class="site-header__nav-link site-header__cart-trigger" data-cart-open aria-label="{{ 'general.cart.title' | t }}">
        سلتج
        {% if cart.item_count > 0 %}
          <span class="site-header__cart-count" data-cart-count>{{ cart.item_count }}</span>
        {% endif %}
      </button>
      <a href="{{ routes.search_url }}" class="site-header__nav-link">{{ 'general.search.title' | t }}</a>
      {% for link in section.settings.menu.links %}
        <a href="{{ link.url }}" class="site-header__nav-link">{{ link.title }}</a>
      {% endfor %}
    </nav>

    <a href="{{ routes.root_url }}" class="site-header__logo">
      {% if settings.logo %}
        {{
          settings.logo
          | image_url: width: settings.logo_width
          | image_tag:
            alt: shop.name,
            width: settings.logo_width,
            loading: 'eager'
        }}
      {% else %}
        <span class="site-header__logo-text">{{ shop.name }}</span>
      {% endif %}
    </a>

    <div class="site-header__actions">
      <form action="{{ routes.search_url }}" method="get" class="site-header__search" role="search">
        <input
          type="search"
          name="q"
          placeholder="{{ 'general.search.placeholder' | t }}"
          aria-label="{{ 'general.search.title' | t }}"
          autocomplete="off"
        >
      </form>
      {% if shop.customer_accounts_enabled %}
        <a href="{{ routes.account_url }}" class="site-header__icon" aria-label="حسابج">
          {{ 'icon-account.svg' | inline_asset_content }}
        </a>
      {% endif %}
      <button type="button" class="site-header__icon site-header__cart-trigger" data-cart-open aria-label="{{ 'general.cart.title' | t }}">
        {{ 'icon-cart.svg' | inline_asset_content }}
        {% if cart.item_count > 0 %}
          <span class="site-header__cart-count" data-cart-count>{{ cart.item_count }}</span>
        {% endif %}
      </button>
    </div>
  </div>
</header>

{% stylesheet %}
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-white);
    border-block-end: 1px solid var(--color-sand);
    box-shadow: var(--shadow-soft);
  }
  .site-header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    min-height: var(--header-height);
    padding-inline: var(--page-margin);
    max-width: var(--page-width);
    margin-inline: auto;
  }
  .site-header__logo {
    justify-self: center;
    text-decoration: none;
    color: var(--color-dark);
  }
  .site-header__logo-text {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-gold);
  }
  .site-header__nav {
    display: none;
    flex-direction: column;
    position: fixed;
    inset: 0;
    top: var(--header-height);
    background: var(--color-white);
    padding: 1.5rem;
    gap: 1rem;
    z-index: 99;
  }
  .site-header__nav.is-open { display: flex; }
  .site-header__nav-link {
    text-decoration: none;
    color: var(--color-dark);
    font-weight: 600;
    background: none;
    border: none;
    font: inherit;
    cursor: pointer;
    text-align: start;
    padding: 0.5rem 0;
  }
  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    justify-self: end;
  }
  .site-header__search { display: none; }
  .site-header__search input {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-sand);
    border-radius: var(--style-border-radius-inputs);
    min-width: 12rem;
  }
  .site-header__icon {
    position: relative;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-dark);
    padding: 0.25rem;
  }
  .site-header__icon svg { width: 1.5rem; height: 1.5rem; }
  .site-header__cart-count {
    position: absolute;
    top: -4px;
    inset-inline-start: -4px;
    background: var(--color-gold);
    color: var(--color-white);
    font-size: 0.65rem;
    font-weight: 700;
    min-width: 1.125rem;
    height: 1.125rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .site-header__menu-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-dark);
    justify-self: start;
  }
  @media (min-width: 768px) {
    .site-header__menu-toggle { display: none; }
    .site-header__nav {
      display: flex;
      position: static;
      flex-direction: row;
      padding: 0;
      gap: 1.25rem;
      align-items: center;
    }
    .site-header__search { display: block; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "class": "site-header-section",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
