<section
  class="product-recommendations section-padding"
  data-recommendations
  data-url="{{ routes.product_recommendations_url }}?product_id={{ product.id }}&limit={{ section.settings.limit | default: 4 }}&section_id={{ section.id }}"
  {% if recommendations.performed and recommendations.products_count == 0 %}hidden{% endif %}
>
  <h2 class="section-heading">{{ section.settings.heading }}</h2>
  <div class="product-recommendations__grid" data-recommendations-grid>
    {% if recommendations.performed and recommendations.products_count > 0 %}
      {% for rec_product in recommendations.products %}
        {% render 'product-card', product: rec_product %}
      {% endfor %}
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .product-recommendations__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }
  @media (min-width: 768px) {
    .product-recommendations__grid { grid-template-columns: repeat(4, 1fr); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product recommendations",
  "class": "product-recommendations-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "العنوان",
      "default": "قد يعجبج أيضًا"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4,
      "label": "عدد المنتجات"
    }
  ]
}
{% endschema %}
