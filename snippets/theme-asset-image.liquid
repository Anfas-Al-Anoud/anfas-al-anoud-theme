{% doc %}
  Renders image from theme assets/ folder by filename.
  @param {string} asset - Filename in assets/ e.g. hero-banner-desktop.jpg
  @param {string} [alt]
  @param {string} [class]
  @param {number} [width]
  @param {string} [loading]
{% enddoc %}

{% liquid
  assign alt_text = alt | default: shop.name
  assign img_loading = loading | default: 'lazy'
  assign img_width = width | default: 1200
%}

{% if asset != blank %}
  {{
    asset
    | asset_img_url: width: img_width
    | image_tag: alt: alt_text, class: class, loading: img_loading, widths: '375, 550, 750, 1100, 1500', sizes: '100vw'
  }}
{% endif %}
