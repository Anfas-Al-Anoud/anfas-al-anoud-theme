{% doc %}
  Renders 5 stars reflecting a numeric rating (0-5).
  @param {number} rating - Rating value, e.g. 4.5
{% enddoc %}

{%- liquid
  assign value = rating | plus: 0.0
  assign full = value | floor
-%}
<span class="rating-stars" role="img" aria-label="{{ value }}/5">
  {%- for i in (1..5) -%}
    {%- if i <= full -%}
      {% render 'icon-inline', name: 'star' %}
    {%- else -%}
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" style="opacity:0.3"><path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z" fill="currentColor"/></svg>
    {%- endif -%}
  {%- endfor -%}
</span>

{% stylesheet %}
  .rating-stars { display: inline-flex; gap: 1px; }
  .rating-stars svg { width: 0.95rem; height: 0.95rem; }
{% endstylesheet %}
