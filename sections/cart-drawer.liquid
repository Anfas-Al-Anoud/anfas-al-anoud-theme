<div class="cart-drawer" data-cart-drawer aria-hidden="true" data-currency="{{ cart.currency.iso_code | default: shop.currency }}">
  <div class="cart-drawer__overlay" data-cart-close></div>
  <aside class="cart-drawer__panel" role="dialog" aria-label="{{ 'general.cart.title' | t }}">
    <header class="cart-drawer__header">
      <h2>{{ 'general.cart.title' | t }}</h2>
      <button type="button" class="cart-drawer__close" data-cart-close aria-label="{{ 'general.accessibility.close' | t }}">&times;</button>
    </header>

    {% if settings.show_free_shipping_bar %}
      <div class="cart-drawer__shipping" data-free-shipping-bar data-threshold="{{ settings.free_shipping_threshold | times: 100 }}">
        <p data-shipping-message></p>
        <div class="cart-drawer__shipping-bar">
          <div class="cart-drawer__shipping-progress" data-shipping-progress></div>
        </div>
      </div>
    {% endif %}

    <div class="cart-drawer__items" data-cart-items data-empty-text="{{ 'general.cart.empty' | t }}">
      {% if cart.item_count > 0 %}
        {% for item in cart.items %}
          <div class="cart-drawer__item" data-line-key="{{ item.key }}">
            {% if item.image %}
              <img src="{{ item.image | image_url: width: 120 }}" alt="{{ item.image.alt | default: item.product.title | escape }}" width="60" height="60" loading="lazy">
            {% endif %}
            <div class="cart-drawer__item-info">
              <a href="{{ item.url }}">{{ item.product.title }}</a>
              {% unless item.variant.title contains 'Default' %}
                <span class="cart-drawer__variant">{{ item.variant.title }}</span>
              {% endunless %}
              <div class="cart-drawer__qty">
                <button type="button" data-qty-change="{{ item.quantity | minus: 1 }}" data-key="{{ item.key }}" aria-label="{{ 'general.cart.decrease' | t }}">&minus;</button>
                <span>{{ item.quantity }}</span>
                <button type="button" data-qty-change="{{ item.quantity | plus: 1 }}" data-key="{{ item.key }}" aria-label="{{ 'general.cart.increase' | t }}">+</button>
              </div>
              <p class="cart-drawer__line-price">{{ item.final_line_price | money }}</p>
            </div>
            <button type="button" class="cart-drawer__remove" data-remove-line="{{ item.key }}" aria-label="{{ 'general.cart.remove' | t }}">&times;</button>
          </div>
        {% endfor %}
      {% else %}
        <p class="cart-drawer__empty">{{ 'general.cart.empty' | t }}</p>
      {% endif %}
    </div>

    <div class="cart-drawer__upsell" data-cart-upsell hidden>
      <h3 class="cart-drawer__upsell-title">{{ 'general.cart.upsell_title' | t }}</h3>
      <div data-cart-upsell-body></div>
    </div>

    <footer class="cart-drawer__footer" data-cart-footer {% if cart.item_count == 0 %}hidden{% endif %}>
      <div class="cart-drawer__subtotal">
        <span>{{ 'general.cart.subtotal' | t }}</span>
        <span data-cart-subtotal>{{ cart.total_price | money }}</span>
      </div>
      <p class="cart-drawer__taxnote">{{ 'general.cart.tax_note' | t }}</p>
      <a href="{{ routes.cart_url }}" class="btn btn--outline">{{ 'general.cart.view_cart' | t }}</a>
      <form action="{{ routes.cart_url }}" method="post">
        <button type="submit" name="checkout" class="btn cart-drawer__checkout">{{ 'general.cart.checkout' | t }}</button>
      </form>
    </footer>
  </aside>
</div>

{% stylesheet %}
  .cart-drawer { position: fixed; inset: 0; z-index: 200; pointer-events: none; }
  .cart-drawer.is-open { pointer-events: auto; }
  .cart-drawer__overlay {
    position: absolute;
    inset: 0;
    background: rgba(61, 43, 31, 0.5);
    opacity: 0;
    transition: opacity var(--transition-base);
  }
  .cart-drawer.is-open .cart-drawer__overlay { opacity: 1; }
  /* Opens from the physical left — matches cart icon placement in this RTL layout. */
  .cart-drawer__panel {
    position: absolute;
    top: 0;
    left: 0;
    right: auto;
    width: min(100%, 24rem);
    height: 100%;
    background: var(--color-white);
    display: flex;
    flex-direction: column;
    transform: translateX(-100%);
    transition: transform var(--transition-base);
    box-shadow: var(--shadow-soft);
  }
  .cart-drawer.is-open .cart-drawer__panel { transform: translateX(0); }
  .cart-drawer__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem;
    border-block-end: 1px solid var(--color-sand);
  }
  .cart-drawer__close {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: var(--color-dark);
  }
  .cart-drawer__shipping { padding: 1rem 1.25rem; background: var(--color-cream); }
  .cart-drawer__shipping-bar {
    height: 6px;
    background: var(--color-sand);
    border-radius: 3px;
    margin-block-start: 0.5rem;
    overflow: hidden;
  }
  .cart-drawer__shipping-progress {
    height: 100%;
    background: var(--color-gold);
    width: 0%;
    transition: width var(--transition-base);
  }
  .cart-drawer__items {
    flex: 1;
    overflow-y: auto;
    padding: 1rem 1.25rem;
  }
  .cart-drawer__item {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    padding-block: 0.75rem;
    border-block-end: 1px solid var(--color-sand);
  }
  .cart-drawer__item img { border-radius: 8px; object-fit: cover; width: 60px; height: 60px; }
  .cart-drawer__item-info { flex: 1; display: flex; flex-direction: column; gap: 0.25rem; }
  .cart-drawer__item-info a { color: var(--color-dark); text-decoration: none; font-weight: 600; }
  .cart-drawer__variant { font-size: 0.8rem; color: var(--color-accent); }
  .cart-drawer__line-price { font-weight: 700; color: var(--color-dark); }
  .cart-drawer__qty {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    align-self: flex-start;
    border: 1px solid var(--color-sand);
    border-radius: 999px;
    padding: 0.15rem 0.5rem;
  }
  .cart-drawer__qty button {
    background: none;
    border: none;
    font-size: 1.1rem;
    line-height: 1;
    cursor: pointer;
    color: var(--color-dark);
    width: 1.5rem;
    height: 1.5rem;
  }
  .cart-drawer__taxnote { font-size: 0.75rem; color: var(--color-accent); text-align: center; }
  .cart-drawer__remove {
    background: none;
    border: none;
    font-size: 1.25rem;
    cursor: pointer;
    color: #999;
    align-self: flex-start;
  }
  .cart-drawer__empty { text-align: center; color: #999; padding: 2rem; }
  .cart-drawer__upsell { padding: 0.9rem 1.25rem; border-block-start: 1px solid var(--color-sand); background: var(--color-cream); }
  .cart-drawer__upsell[hidden] { display: none; }
  .cart-drawer__upsell-title { font-size: 0.9rem; font-weight: 700; margin-block-end: 0.6rem; color: var(--color-dark); }
  .cart-drawer__footer {
    padding: 1.25rem;
    border-block-start: 1px solid var(--color-sand);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .cart-drawer__subtotal {
    display: flex;
    justify-content: space-between;
    font-weight: 700;
    font-size: 1.1rem;
  }
  .cart-drawer__checkout { width: 100%; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.cart_drawer.name",
  "class": "cart-drawer-section",
  "settings": []
}
{% endschema %}
