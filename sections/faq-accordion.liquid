<section class="faq-accordion section-padding" data-animate-section data-faq-accordion>
  <h2 class="section-heading">{{ section.settings.heading }}</h2>
  <div class="faq-accordion__list" itemscope itemtype="https://schema.org/FAQPage">
    {% assign visible_count = section.settings.initial_visible_count | default: 2 %}
    {% for block in section.blocks %}
      {% liquid
        assign is_hidden = false
        if forloop.index > visible_count
          assign is_hidden = true
        endif
      %}
      <details
        class="faq-accordion__item{% if is_hidden %} faq-accordion__item--collapsed{% endif %}"
        {% if is_hidden %}hidden{% endif %}
        {{ block.shopify_attributes }}
        itemscope
        itemprop="mainEntity"
        itemtype="https://schema.org/Question"
        data-faq-item
      >
        <summary class="faq-accordion__question" itemprop="name">{{ block.settings.question }}</summary>
        <div class="faq-accordion__answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
          <div itemprop="text">{{ block.settings.answer }}</div>
        </div>
      </details>
    {% endfor %}
  </div>
  {% if section.blocks.size > visible_count %}
    <div class="faq-accordion__toggle-wrap">
      <button type="button" class="btn btn--outline faq-accordion__toggle" data-faq-toggle data-hide-label="{{ 'sections.faq_accordion.show_less' | t }}" aria-expanded="false">
        {{ 'sections.faq_accordion.show_more' | t }}
      </button>
    </div>
  {% endif %}
</section>

{% stylesheet %}
  .faq-accordion__list {
    max-width: 48rem;
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }
  .faq-accordion__item {
    border-block-end: 1px solid var(--color-sand);
    padding-block: 0.25rem;
  }
  .faq-accordion__question {
    padding: 1rem 0;
    font-weight: 700;
    cursor: pointer;
    list-style: none;
    color: var(--color-dark);
  }
  .faq-accordion__question::-webkit-details-marker { display: none; }
  .faq-accordion__answer {
    padding-block-end: 1rem;
    line-height: 1.8;
    color: var(--color-accent);
  }
  .faq-accordion__toggle-wrap {
    text-align: center;
    margin-block-start: 1rem;
    padding-inline: var(--page-margin);
  }
  .faq-accordion__toggle {
    min-width: 12rem;
  }

  @media (max-width: 767px) {
    .faq-accordion.section-padding {
      padding-block: clamp(1rem, 3vw, 1.5rem);
    }

    .faq-accordion__list {
      padding-inline: calc(var(--page-margin) * 0.75);
    }

    .faq-accordion__item {
      padding-block: 0;
    }

    .faq-accordion__question {
      padding: 0.625rem 0;
      font-size: 0.875rem;
      line-height: 1.45;
    }

    .faq-accordion__answer {
      padding-block-end: 0.625rem;
      font-size: 0.8125rem;
      line-height: 1.6;
    }
  }
{% endstylesheet %}

{% javascript %}
  document.querySelectorAll('[data-faq-accordion]').forEach((section) => {
    const toggle = section.querySelector('[data-faq-toggle]');
    if (!toggle) return;

    const hiddenItems = [...section.querySelectorAll('[data-faq-item][hidden]')];
    if (!hiddenItems.length) {
      toggle.closest('.faq-accordion__toggle-wrap')?.remove();
      return;
    }

    const showLabel = toggle.textContent.trim();
    const hideLabel = toggle.dataset.hideLabel || 'أخفي الأسئلة';

    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      hiddenItems.forEach((item) => {
        item.hidden = expanded;
      });
      toggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      toggle.textContent = expanded ? showLabel : hideLabel;
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.faq_accordion.name",
  "class": "faq-accordion-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "العنوان", "default": "في خاطرج سؤال؟ أنا حاضرة عشانج" },
    {
      "type": "range",
      "id": "initial_visible_count",
      "label": "عدد الأسئلة الظاهرة",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 2
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "سؤال",
      "settings": [
        { "type": "text", "id": "question", "label": "السؤال", "default": "سؤال" },
        { "type": "richtext", "id": "answer", "label": "الجواب", "default": "<p>الجواب</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.faq_accordion.name",
      "blocks": [
        { "type": "faq", "settings": { "question": "شو نوع الدخون اللي عندج؟", "answer": "<p>عندنا دخون إماراتي فاخر بخلطات أصلية ومكونات طبيعية.</p>" } },
        { "type": "faq", "settings": { "question": "ايش هي طرق الدفع المتوفرة عندج؟", "answer": "<p>بطاقات، Apple Pay، تابي، وتمارا.</p>" } },
        { "type": "faq", "settings": { "question": "كم حبة دخون في الغرشة؟", "answer": "<p>تختلف حسب المنتج، التفاصيل موجودة في صفحة كل منتج.</p>" } },
        { "type": "faq", "settings": { "question": "كيف أطلب؟", "answer": "<p>اختاري المنتج، أضيفيه للسلة، وكمّلي الدفع.</p>" } },
        { "type": "faq", "settings": { "question": "اقدر أدفع بتابي أو تمارا؟", "answer": "<p>نعم، متوفرين في صفحة الدفع.</p>" } },
        { "type": "faq", "settings": { "question": "وين توصلين؟", "answer": "<p>نوصل لكل الإمارات، وخارج الإمارات حسب التوفر.</p>" } },
        { "type": "faq", "settings": { "question": "ايش هي العروض اللي عاملتيها؟", "answer": "<p>تابعينا على السوشيال أو اشتركي بالنشرة للعروض.</p>" } },
        { "type": "faq", "settings": { "question": "هل في شحن لخارج الإمارات؟", "answer": "<p>نعم، حسب الدولة والوزن.</p>" } },
        { "type": "faq", "settings": { "question": "ايش أسوي لو المنتج لو ما عيبني؟", "answer": "<p>تقدرين ترجعينه خلال 3 أيام حسب سياسة الإرجاع.</p>" } },
        { "type": "faq", "settings": { "question": "هل الروائح عندج مناسبة للنساء والرجال؟", "answer": "<p>نعم، عندنا روائح تناسب الجميع.</p>" } }
      ]
    }
  ]
}
{% endschema %}
