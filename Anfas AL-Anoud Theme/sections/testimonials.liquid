<section class="testimonials section-padding" data-animate-section>
  <h2 class="section-heading">{{ section.settings.heading }}</h2>
  <p class="section-subheading">{{ section.settings.subheading }}</p>
  <div class="testimonials__grid">
    {% for block in section.blocks %}
      <blockquote class="testimonials__card" {{ block.shopify_attributes }}>
        <p class="testimonials__quote">"{{ block.settings.quote }}"</p>
        <footer>
          <cite class="testimonials__author">{{ block.settings.author }}</cite>
        </footer>
      </blockquote>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .testimonials__grid {
    display: grid;
    gap: 1.5rem;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }
  @media (min-width: 768px) {
    .testimonials__grid { grid-template-columns: repeat(3, 1fr); }
  }
  .testimonials__card {
    background: var(--color-white);
    padding: 1.5rem;
    border-radius: var(--style-border-radius-cards);
    box-shadow: var(--shadow-soft);
    margin: 0;
  }
  .testimonials__quote {
    font-style: italic;
    line-height: 1.8;
    margin-block-end: 1rem;
    color: var(--color-dark);
  }
  .testimonials__author {
    font-weight: 700;
    color: var(--color-gold);
    font-style: normal;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.testimonials.name",
  "class": "testimonials-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "العنوان", "default": "شو قالوا عنا الحبايب؟" },
    { "type": "textarea", "id": "subheading", "label": "النص", "default": "تصفحي سوالف وتجارب البنات اللي وثقوا فينا." }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "رأي",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "النص", "default": "منتجات رائعة وريحة تدوم!" },
        { "type": "text", "id": "author", "label": "الاسم", "default": "عميلة سعيدة" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.testimonials.name",
      "blocks": [
        { "type": "testimonial", "settings": { "quote": "الدخون يفوح فخامة، والتوصيل سريع!", "author": "فاطمة - دبي" } },
        { "type": "testimonial", "settings": { "quote": "بدي أويل ناعم وريحته ثابتة طول اليوم.", "author": "مريم - أبوظبي" } },
        { "type": "testimonial", "settings": { "quote": "بوكس الهدية كان تحفة، والتغليف فخم.", "author": "شما - الشارقة" } }
      ]
    }
  ]
}
{% endschema %}
