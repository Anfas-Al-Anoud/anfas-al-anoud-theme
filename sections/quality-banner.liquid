<section class="quality-banner section-padding full-width" data-animate-section>
  <div class="quality-banner__shell">
    <div class="quality-banner__inner">
      <div class="quality-banner__media" aria-hidden="true">
        {% if section.settings.image %}
          {% render 'image', image: section.settings.image, alt: section.settings.image_alt, fallback_alt: section.settings.heading, class: 'quality-banner__image', width: 1200 %}
        {% elsif section.settings.image_asset != blank %}
          {% render 'theme-asset-image', asset: section.settings.image_asset, alt: section.settings.image_alt, class: 'quality-banner__image', width: 1200 %}
        {% endif %}
      </div>
      <div class="quality-banner__overlay">
        <div class="quality-banner__copy">
          <h2 class="quality-banner__heading">{{ section.settings.heading }}</h2>
          {% if section.settings.button_label != blank %}
            <a href="{{ section.settings.button_link }}" class="btn quality-banner__btn">{{ section.settings.button_label }}</a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .quality-banner__shell {
    width: 100%;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }

  .quality-banner__inner {
    position: relative;
    overflow: hidden;
    width: 100%;
    border-radius: var(--style-border-radius-cards);
    height: clamp(11.5rem, 14vw, 15.5rem);
  }

  .quality-banner__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .quality-banner__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }

  .quality-banner__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1rem, 2.5vw, 2rem);
    background: rgba(61, 43, 31, 0.7);
  }

  .quality-banner__copy {
    text-align: center;
    width: min(100%, 44rem);
    margin-inline: auto;
  }

  .quality-banner__heading {
    color: var(--color-white);
    font-size: clamp(1rem, 1.35vw, 1.375rem);
    font-weight: 700;
    margin: 0 0 0.875rem;
    line-height: 1.5;
    text-wrap: balance;
  }

  .quality-banner__btn {
    font-size: 0.875rem;
    padding: 0.5625rem 1.25rem;
  }

  @media (min-width: 768px) {
    .quality-banner.section-padding {
      padding-block: clamp(1.5rem, 3vw, 2.5rem);
    }

    .quality-banner__inner {
      box-shadow: var(--shadow-soft);
    }
  }

  @media (max-width: 767px) {
    .quality-banner.section-padding {
      padding-block: 0.75rem;
    }

    .quality-banner__shell {
      padding-inline: 0;
      max-width: none;
    }

    .quality-banner__inner {
      border-radius: 0;
      height: clamp(9.5rem, 42vw, 11rem);
    }

    .quality-banner__overlay {
      padding: 0.625rem var(--page-margin);
      background: rgba(61, 43, 31, 0.78);
    }

    .quality-banner__heading {
      font-size: clamp(0.75rem, 3.2vw, 0.875rem);
      margin-block-end: 0.5rem;
      line-height: 1.4;
    }

    .quality-banner__btn {
      font-size: 0.75rem;
      padding: 0.4375rem 0.875rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.quality_banner.name",
  "class": "quality-banner-section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "الصورة (ingredients-banner.jpg)" },
    { "type": "text", "id": "image_asset", "label": "ملف الصورة (assets/)", "default": "quality-banner-ingredients.jpg" },
    {
      "type": "text",
      "id": "image_alt",
      "label": "نص alt (مطلوب)",
      "default": "صورة تعبر عن جودة المكونات - أنفاس العنود",
      "info": "مطلوب لإمكانية الوصول ومحركات البحث. لا تتركي الحقل فارغًا."
    },
    { "type": "text", "id": "heading", "label": "العنوان", "default": "سر الزين في تفاصيلنا.. أنا دايمًا أختار لج أصفى المكونات عشان تميزج في كل خطوة." },
    { "type": "text", "id": "button_label", "label": "نص الزر", "default": "اكتشفي أسرار منتجاتي" },
    { "type": "url", "id": "button_link", "label": "الرابط" }
  ],
  "presets": [{ "name": "t:sections.quality_banner.name" }]
}
{% endschema %}
