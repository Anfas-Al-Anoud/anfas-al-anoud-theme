<article class="about-anoud section-padding">
  <div class="about-anoud__inner">
    <h1 class="about-anoud__title">{{ section.settings.heading }}</h1>

    <div class="about-anoud__hero">
      {% if section.settings.hero_image != blank %}
        {{
          section.settings.hero_image
          | image_url: width: 1600
          | image_tag:
            class: 'about-anoud__hero-img',
            alt: section.settings.hero_image_alt,
            loading: 'eager',
            widths: '400, 800, 1200, 1600',
            sizes: '(min-width: 768px) 720px, 100vw'
        }}
      {% elsif section.settings.hero_asset != blank %}
        <img
          class="about-anoud__hero-img"
          src="{{ section.settings.hero_asset | asset_url }}"
          alt="{{ section.settings.hero_image_alt | escape }}"
          width="1000"
          height="560"
          loading="eager"
        >
      {% else %}
        <div class="about-anoud__hero-placeholder" aria-hidden="true"></div>
      {% endif %}

      {% if section.settings.welcome_bubble != blank %}
        <div class="about-anoud__bubble">
          <p>{{ section.settings.welcome_bubble }}</p>
        </div>
      {% endif %}
    </div>

    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'text_block' %}
          <section class="about-anoud__block" {{ block.shopify_attributes }}>
            {% if block.settings.heading != blank %}
              <h2 class="about-anoud__block-title">{{ block.settings.heading }}</h2>
            {% endif %}
            {% if block.settings.body != blank %}
              <div class="about-anoud__block-body">{{ block.settings.body }}</div>
            {% endif %}
          </section>
        {% when 'closing' %}
          <section class="about-anoud__closing" {{ block.shopify_attributes }}>
            <div class="about-anoud__closing-icon" aria-hidden="true">
              {{ 'icon-policy-heart.svg' | inline_asset_content }}
            </div>
            {% if block.settings.heading != blank %}
              <h2 class="about-anoud__closing-title">{{ block.settings.heading }}</h2>
            {% endif %}
            {% if block.settings.body != blank %}
              <div class="about-anoud__closing-body">{{ block.settings.body }}</div>
            {% endif %}
            {% if block.settings.signature != blank %}
              <p class="about-anoud__signature">{{ block.settings.signature }}</p>
            {% endif %}
          </section>
      {% endcase %}
    {% endfor %}
  </div>
</article>

{% stylesheet %}
  .about-anoud__inner {
    max-width: 40rem;
    margin-inline: auto;
  }

  .about-anoud__title {
    text-align: center;
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    color: var(--color-dark);
    margin: 0 0 1.5rem;
  }

  .about-anoud__hero {
    position: relative;
    border-radius: 1.25rem;
    overflow: hidden;
    margin-block-end: 2.5rem;
    background: var(--color-sand);
    min-height: 12rem;
  }

  .about-anoud__hero-img,
  .about-anoud__hero-placeholder {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .about-anoud__hero-placeholder {
    background: linear-gradient(135deg, var(--color-sand), var(--color-cream));
  }

  .about-anoud__bubble {
    position: absolute;
    inset-inline: 1rem;
    bottom: 1rem;
    background: rgba(250, 246, 239, 0.94);
    border-radius: 1rem;
    padding: 0.85rem 1.1rem;
    box-shadow: 0 8px 24px rgba(58, 36, 24, 0.12);
  }

  .about-anoud__bubble p {
    margin: 0;
    text-align: center;
    font-weight: 600;
    color: var(--color-dark);
    line-height: 1.6;
  }

  .about-anoud__block {
    margin-block-end: 2rem;
  }

  .about-anoud__block-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-dark);
    margin: 0 0 0.65rem;
    text-align: center;
  }

  .about-anoud__block-body {
    text-align: center;
    line-height: 1.9;
    color: var(--color-accent);
  }

  .about-anoud__block-body p {
    margin: 0 0 0.75rem;
  }

  .about-anoud__closing {
    text-align: center;
    margin-block-start: 2.5rem;
    padding-block-start: 1.5rem;
    border-block-start: 1px solid var(--color-sand);
  }

  .about-anoud__closing-icon {
    width: 2.75rem;
    height: 2.75rem;
    margin-inline: auto;
    margin-block-end: 0.85rem;
    color: var(--color-primary);
  }

  .about-anoud__closing-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .about-anoud__closing-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
  }

  .about-anoud__closing-body {
    line-height: 1.9;
    color: var(--color-accent);
    max-width: 32rem;
    margin-inline: auto;
  }

  .about-anoud__signature {
    margin-block-start: 1.25rem;
    font-weight: 700;
    color: var(--color-burgundy, #7a1f2b);
    font-size: 1.05rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "منو هي العنود؟",
  "class": "about-anoud-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "العنوان",
      "default": "منو هي العنود؟"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "صورة الترحيب"
    },
    {
      "type": "text",
      "id": "hero_asset",
      "label": "اسم ملف صورة من assets (اختياري)",
      "default": "about-anoud-hero.png",
      "info": "مثال: about-anoud-hero.png — يُستخدم إذا لم تُرفع صورة من المحرر"
    },
    {
      "type": "text",
      "id": "hero_image_alt",
      "label": "وصف الصورة",
      "default": "مجلس دافئ - أنفاس العنود"
    },
    {
      "type": "textarea",
      "id": "welcome_bubble",
      "label": "نص فقاعة الترحيب",
      "default": "يا هلا بالغالية.. نورتي مكاني!"
    }
  ],
  "blocks": [
    {
      "type": "text_block",
      "name": "فقرة",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "عنوان الفقرة"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "النص"
        }
      ]
    },
    {
      "type": "closing",
      "name": "ختام",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "عنوان الختام",
          "default": "رسالة من قلبي لقلبج.."
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "نص الرسالة"
        },
        {
          "type": "text",
          "id": "signature",
          "label": "التوقيع",
          "default": "العنود"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "منو هي العنود؟",
      "blocks": [
        {
          "type": "text_block",
          "settings": {
            "heading": "السر اللي ما يعرفه وايد ناس..",
            "body": "<p>أنا العنود، وهواسّة روائح من يوم كنت صغيرة. الدخون والعطر عندي مو مجرد منتج — هذي طريقة أحسّسج فيها إنج فواحة وتستاهلين أجمل حضور.</p>"
          }
        },
        {
          "type": "text_block",
          "settings": {
            "heading": "عشان تكونين فواحة..",
            "body": "<p>أختار لج خلطات أصلية، زيوت، ومرشات تناسب يومج وميلسج وعزايمج. كل قطعة أجهزها بنية وحدة: تريحج وتخلّج تثقين بريحة جوج.</p>"
          }
        },
        {
          "type": "text_block",
          "settings": {
            "heading": "وعدي لج يا الغالية..",
            "body": "<p>جودة أصلية، خدمة قريبة من القلب، وتجربة تسوق تحسّين فيها إن أحد يفهمج. أنتي مو رقم طلب — أنتي من هالبيت.</p>"
          }
        },
        {
          "type": "closing",
          "settings": {
            "heading": "رسالة من قلبي لقلبج..",
            "body": "<p>شكرًا إنج وثقني بج، وخلّيتي أنفاس العنود جزء من يومج. الله يخلّيج لأهلك وتبقين دائمًا على أحلى روائحج.</p>",
            "signature": "العنود"
          }
        }
      ]
    }
  ]
}
{% endschema %}
