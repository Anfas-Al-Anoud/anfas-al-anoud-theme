<article class="page-content section-padding">
  <div class="page-content__inner">
    <h1 class="page-content__title">اتفاقنا الحلو</h1>
    <div class="page-content__body rte">
      {% if page.content != blank %}
        {{ page.content }}
      {% else %}
        <p>باستخدامك لمتجر أنفاس العنود، فإنتِ توافقين على الشروط والأحكام التالية. شكرًا لثقتج بنا.</p>
      {% endif %}
    </div>
  </div>
</article>

{% stylesheet %}
  .page-content__inner { max-width: 48rem; margin-inline: auto; padding-inline: var(--page-margin); line-height: 1.8; }
  .page-content__title { font-size: clamp(1.5rem, 4vw, 2.25rem); font-weight: 700; margin-block-end: 1.5rem; color: var(--color-dark); }
{% endstylesheet %}

{% schema %}
{
  "name": "Terms",
  "class": "terms-section",
  "settings": []
}
{% endschema %}
