{% liquid
  assign featured_products = section.settings.collection.products
  if featured_products == blank or featured_products.size == 0
    assign featured_products = collections.all.products
  endif
  assign collection_url = section.settings.collection.url | default: routes.all_products_collection_url
%}
<section class="featured-collection section-padding" data-animate-section{% if section.settings.enable_countdown and section.settings.countdown_end != blank %} data-offers-countdown data-countdown-end="{{ section.settings.countdown_end }}"{% endif %}>
  <div class="featured-collection__header">
    <div class="featured-collection__titles">
      {%- if section.settings.enable_countdown and section.settings.countdown_end != blank -%}
        <div class="featured-collection__countdown" data-countdown hidden>
          <span class="featured-collection__countdown-label">{{ 'sections.featured_collection.countdown_label' | t }}</span>
          <div class="featured-collection__countdown-units" data-countdown-units aria-live="polite"></div>
        </div>
      {%- endif -%}
      <h2 class="section-heading featured-collection__heading">{% render 'tanween', text: section.settings.heading %}</h2>
      {% if section.settings.subheading != blank %}
        <p class="section-subheading featured-collection__subheading">{% render 'tanween', text: section.settings.subheading %}</p>
      {% endif %}
    </div>
    {% if section.settings.show_view_all %}
      <a href="{{ collection_url }}" class="featured-collection__view-all">
        {{ 'sections.featured_collection.view_all' | t }}
        <span aria-hidden="true">&lsaquo;</span>
      </a>
    {% endif %}
  </div>

  {% if featured_products.size > 0 %}
    <div class="featured-collection__carousel" data-carousel>
      <button type="button" class="featured-collection__nav featured-collection__nav--prev" data-carousel-prev aria-label="{{ 'general.pagination.previous' | t }}">&lsaquo;</button>
      <div class="featured-collection__track-wrap">
        <div class="featured-collection__track" data-carousel-track>
          {% for product in featured_products limit: section.settings.products_to_show %}
            <div class="featured-collection__slide">
              {% render 'product-card', product: product %}
            </div>
          {% endfor %}
        </div>
      </div>
      <button type="button" class="featured-collection__nav featured-collection__nav--next" data-carousel-next aria-label="{{ 'general.pagination.next' | t }}">&rsaquo;</button>
      <div class="featured-collection__dots" data-carousel-dots role="tablist" aria-label="{{ 'general.pagination.label' | t }}"></div>
    </div>
  {% endif %}
</section>

{% stylesheet %}
  .featured-collection__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
    margin-block-end: 0.25rem;
  }

  .featured-collection__titles {
    flex: 1;
    min-width: 0;
  }

  .featured-collection__heading,
  .featured-collection__subheading {
    text-align: start;
    margin-inline: 0;
  }

  .featured-collection__subheading {
    margin-block-end: 0;
  }

  .featured-collection__countdown {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.75rem;
    margin-block-end: 0.5rem;
  }
  .featured-collection__countdown[hidden] { display: none; }
  .featured-collection__countdown-label {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-primary);
  }
  .featured-collection__countdown-units {
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
  }
  .featured-collection__countdown-unit {
    min-width: 3.25rem;
    padding: 0.35rem 0.5rem;
    border-radius: 0.65rem;
    background: var(--color-cream);
    border: 1px solid color-mix(in srgb, var(--color-gold) 45%, transparent);
    text-align: center;
    font-size: 0.78rem;
    line-height: 1.2;
  }
  .featured-collection__countdown-unit strong {
    display: block;
    font-size: 1rem;
    color: var(--color-primary);
  }

  .featured-collection__view-all {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
    padding-block: 0.25rem;
    transition: color var(--transition-base);
  }

  .featured-collection__view-all:hover {
    color: var(--color-primary-dark);
  }

  .featured-collection__view-all span {
    font-size: 1.125rem;
    line-height: 1;
  }

  .featured-collection__carousel {
    position: relative;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }

  .featured-collection__track-wrap {
    overflow: hidden;
  }

  .featured-collection__track {
    display: flex;
    gap: 1rem;
    align-items: stretch;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-block: 0.5rem;
    padding-inline: 0.25rem;
  }

  .featured-collection__track::-webkit-scrollbar {
    display: none;
  }

  .featured-collection__slide {
    flex: 0 0 calc(72% - 0.5rem);
    scroll-snap-align: start;
    min-width: 0;
    display: flex;
  }

  .featured-collection__slide .product-card {
    width: 100%;
  }

  .featured-collection__dots {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: center;
    gap: 0.375rem;
    margin-block-start: 0.75rem;
    min-height: 0.5rem;
  }

  .featured-collection__dot {
    width: 0.5rem;
    height: 0.5rem;
    padding: 0;
    border: none;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-primary) 25%, transparent);
    cursor: pointer;
    transition: background var(--transition-base), transform var(--transition-base);
  }

  .featured-collection__dot.is-active {
    background: var(--color-primary);
    transform: scale(1.15);
  }

  @media (min-width: 768px) {
    .featured-collection__carousel {
      padding-inline: calc(var(--page-margin) + 2rem);
    }

    .featured-collection__slide {
      flex: 0 0 calc(33.333% - 0.667rem);
    }
  }

  @media (min-width: 1024px) {
    .featured-collection__slide {
      flex: 0 0 calc(25% - 0.75rem);
    }
  }

  .featured-collection__nav {
    position: absolute;
    top: 42%;
    transform: translateY(-50%);
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    border: none;
    background: var(--color-primary);
    color: var(--color-primary-foreground);
    font-size: 1.35rem;
    cursor: pointer;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 18px rgba(122, 31, 43, 0.28);
    transition: background var(--transition-base), transform var(--transition-base);
  }

  .featured-collection__nav:hover {
    background: var(--color-primary-dark);
  }

  @media (min-width: 768px) {
    .featured-collection__nav {
      width: 2.5rem;
      height: 2.5rem;
      font-size: 1.5rem;
    }
  }

  .featured-collection__nav--prev {
    inset-inline-start: 0;
  }

  .featured-collection__nav--next {
    inset-inline-end: 0;
  }

  @media (max-width: 767px) {
    .featured-collection__header {
      align-items: flex-start;
      flex-wrap: wrap;
    }

    .featured-collection__view-all {
      font-size: 0.8125rem;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function initOfferCountdowns() {
    const sections = document.querySelectorAll('[data-offers-countdown]');
    if (!sections.length) return;

    const labels = {
      days: 'يوم',
      hours: 'ساعة',
      minutes: 'دقيقة',
      seconds: 'ثانية',
    };

    function renderUnit(value, label) {
      return `<span class="featured-collection__countdown-unit"><strong>${value}</strong>${label}</span>`;
    }

    sections.forEach((section) => {
      const endRaw = section.dataset.countdownEnd;
      const wrap = section.querySelector('[data-countdown]');
      const units = section.querySelector('[data-countdown-units]');
      if (!endRaw || !wrap || !units) return;

      const end = new Date(endRaw).getTime();
      if (Number.isNaN(end)) return;

      const tick = () => {
        const diff = end - Date.now();
        if (diff <= 0) {
          units.textContent = '';
          wrap.hidden = true;
          return;
        }
        const days = Math.floor(diff / 86400000);
        const hours = Math.floor((diff % 86400000) / 3600000);
        const minutes = Math.floor((diff % 3600000) / 60000);
        const seconds = Math.floor((diff % 60000) / 1000);
        units.innerHTML =
          renderUnit(days, labels.days) +
          renderUnit(hours, labels.hours) +
          renderUnit(minutes, labels.minutes) +
          renderUnit(seconds, labels.seconds);
        wrap.hidden = false;
      };

      tick();
      setInterval(tick, 1000);
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.featured_collection.name",
  "class": "featured-collection-section",
  "blocks": [{ "type": "@app" }],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "العنوان",
      "default": "الأكثر مبيعًا"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "النص الفرعي",
      "default": "هذي أكثر المنتجات اللي حبوها البنات ورجعوا طلبوها مرة ثانية.. جربيها وما بتندمين."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "المجموعة"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 20,
      "step": 1,
      "default": 8,
      "label": "عدد المنتجات"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "عرض رابط «شوفي الكل»",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_countdown",
      "label": "t:sections.featured_collection.enable_countdown",
      "default": false
    },
    {
      "type": "text",
      "id": "countdown_end",
      "label": "t:sections.featured_collection.countdown_end",
      "info": "t:sections.featured_collection.countdown_end_info",
      "placeholder": "2026-12-31T23:59"
    }
  ],
  "presets": [{ "name": "t:sections.featured_collection.name" }]
}
{% endschema %}
