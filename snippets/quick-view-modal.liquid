{% doc %}
  Shared quick-view modal shell. Rendered once in the theme layout.
  The store-enhancements.js quick-view module injects the fetched
  quick-view section into [data-qv-body] and toggles .is-open.

  @example
  {% render 'quick-view-modal' %}
{% enddoc %}

<div class="quick-view" data-quick-view-modal aria-hidden="true">
  <div class="quick-view__overlay" data-qv-close></div>
  <div class="quick-view__dialog" role="dialog" aria-modal="true" aria-label="{{ 'products.quick_view' | t }}">
    <button type="button" class="quick-view__close" data-qv-close aria-label="{{ 'general.accessibility.close' | t }}">
      {% render 'icon-inline', name: 'close' %}
    </button>
    <div class="quick-view__body" data-qv-body>
      <div class="quick-view__loading" data-qv-loading>{{ 'general.search.searching' | t }}</div>
    </div>
  </div>
</div>

{% stylesheet %}
  .quick-view { position: fixed; inset: 0; z-index: 300; pointer-events: none; }
  .quick-view.is-open { pointer-events: auto; }
  .quick-view__overlay {
    position: absolute;
    inset: 0;
    background: rgba(58, 36, 24, 0.55);
    opacity: 0;
    transition: opacity var(--transition-base);
  }
  .quick-view.is-open .quick-view__overlay { opacity: 1; }
  .quick-view__dialog {
    position: absolute;
    inset-inline: 0;
    top: 50%;
    margin-inline: auto;
    width: min(52rem, 92vw);
    max-height: 88vh;
    overflow-y: auto;
    background: var(--color-white);
    border-radius: var(--style-border-radius-cards);
    padding: 1.5rem;
    transform: translateY(-46%) scale(0.98);
    opacity: 0;
    transition: transform var(--transition-base), opacity var(--transition-base);
    box-shadow: 0 24px 60px rgba(58, 36, 24, 0.28);
  }
  .quick-view.is-open .quick-view__dialog { transform: translateY(-50%) scale(1); opacity: 1; }
  .quick-view__close {
    position: absolute;
    top: 0.75rem;
    inset-inline-end: 0.75rem;
    background: var(--color-cream);
    border: none;
    border-radius: 50%;
    width: 2.25rem;
    height: 2.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--color-dark);
    z-index: 2;
  }
  .quick-view__close svg { width: 1.1rem; height: 1.1rem; }
  .quick-view__loading { padding: 3rem 1rem; text-align: center; color: var(--color-accent); }
{% endstylesheet %}
