[
  {
    "name": "theme_info",
    "theme_name": "Anfas Al-Anoud",
    "theme_version": "1.9.3",
    "theme_author": "Anfas Al-Anoud",
    "theme_documentation_url": "https://github.com/Anfas-Al-Anoud/anfas-al-anoud-theme",
    "theme_support_url": "https://github.com/Anfas-Al-Anoud/anfas-al-anoud-theme/issues"
  },
  {
    "name": "t:settings.brand.name",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "t:settings.brand.logo"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 60,
        "max": 300,
        "step": 5,
        "unit": "px",
        "label": "t:settings.brand.logo_width",
        "default": 160
      },
      {
        "type": "text",
        "id": "whatsapp_number",
        "label": "t:settings.brand.whatsapp",
        "default": "971500000000"
      }
    ]
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "select",
        "id": "arabic_font_family",
        "label": "t:labels.arabic_font",
        "info": "t:settings.typography.arabic_font_info",
        "default": "tajawal",
        "options": [
          { "value": "tajawal", "label": "Tajawal" },
          { "value": "cairo", "label": "Cairo" },
          { "value": "noto_sans", "label": "Noto Sans Arabic" },
          { "value": "ibm_plex", "label": "IBM Plex Sans Arabic" }
        ]
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          { "value": "90rem", "label": "t:options.page_width.narrow" },
          { "value": "100rem", "label": "متوسط" },
          { "value": "110rem", "label": "t:options.page_width.wide" }
        ],
        "default": "100rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color_palette",
        "id": "colors",
        "default": {
          "burgundy": "#7A1F2B",
          "gold": "#C9A24C",
          "sand": "#E8D5B7",
          "cream": "#FAF6EF",
          "dark": "#3A2418",
          "accent": "#8B6914",
          "white": "#FFFFFF"
        }
      },
      {
        "type": "color",
        "id": "background_color",
        "default": "#FAF6EF",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#3A2418",
        "label": "t:labels.foreground"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 40,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 24
      }
    ]
  },
  {
    "name": "t:settings.cart.name",
    "settings": [
      {
        "type": "number",
        "id": "free_shipping_threshold",
        "label": "t:settings.cart.free_shipping_threshold",
        "default": 200
      },
      {
        "type": "checkbox",
        "id": "show_free_shipping_bar",
        "label": "t:settings.cart.show_free_shipping_bar",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_cart_note",
        "label": "t:settings.cart.enable_cart_note",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_gift_message",
        "label": "t:settings.cart.enable_gift_message",
        "default": true
      }
    ]
  },
  {
    "name": "t:settings.product.name",
    "settings": [
      {
        "type": "number",
        "id": "low_stock_threshold",
        "label": "t:settings.product.low_stock_threshold",
        "info": "t:settings.product.low_stock_info",
        "default": 10
      }
    ]
  },
  {
    "name": "t:settings.header.name",
    "settings": [
      {
        "type": "select",
        "id": "header_style",
        "label": "t:settings.header.style",
        "info": "t:settings.header.style_info",
        "default": "classic",
        "options": [
          { "value": "classic", "label": "t:settings.header.style_options.classic" },
          { "value": "commerce", "label": "t:settings.header.style_options.commerce" },
          { "value": "overlay", "label": "t:settings.header.style_options.overlay" }
        ]
      },
      {
        "type": "checkbox",
        "id": "nav_promo_enabled",
        "label": "t:settings.header.promo_enabled",
        "default": true
      },
      {
        "type": "text",
        "id": "nav_promo_text",
        "label": "t:settings.header.promo_text",
        "default": "عروضنا الحلوة"
      },
      {
        "type": "url",
        "id": "nav_promo_link",
        "label": "t:settings.header.promo_link"
      }
    ]
  },
  {
    "name": "t:settings.social.name",
    "settings": [
      {
        "type": "url",
        "id": "social_instagram",
        "label": "Instagram"
      },
      {
        "type": "url",
        "id": "social_tiktok",
        "label": "TikTok"
      },
      {
        "type": "url",
        "id": "social_snapchat",
        "label": "Snapchat"
      },
      {
        "type": "url",
        "id": "social_facebook",
        "label": "Facebook"
      },
      {
        "type": "url",
        "id": "social_threads",
        "label": "Threads"
      }
    ]
  }
]
