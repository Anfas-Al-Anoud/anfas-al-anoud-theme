<section class="hero-banner section-padding" data-animate-section>
  <div class="hero-banner__inner">
    <div class="hero-banner__media">
      {% if section.settings.image_desktop %}
        {% render 'image',
          image: section.settings.image_desktop,
          alt: section.settings.image_alt,
          fallback_alt: section.settings.heading,
          class: 'hero-banner__image hero-banner__image--desktop',
          width: 1400,
          loading: 'eager'
        %}
      {% endif %}
      {% if section.settings.image_mobile %}
        {% render 'image',
          image: section.settings.image_mobile,
          alt: section.settings.image_alt,
          fallback_alt: section.settings.heading,
          class: 'hero-banner__image hero-banner__image--mobile',
          width: 750,
          loading: 'eager'
        %}
      {% else %}
        {% if section.settings.image_desktop %}
          {% render 'image',
            image: section.settings.image_desktop,
            alt: section.settings.image_alt,
            fallback_alt: section.settings.heading,
            class: 'hero-banner__image hero-banner__image--mobile',
            width: 750,
            loading: 'eager'
          %}
        {% endif %}
      {% endif %}
    </div>
    <div class="hero-banner__content">
      <h1 class="hero-banner__heading">{{ section.settings.heading }}</h1>
      <p class="hero-banner__text">{{ section.settings.text }}</p>
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="btn">{{ section.settings.button_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .hero-banner__inner {
    display: grid;
    gap: 2rem;
    align-items: center;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }
  @media (min-width: 768px) {
    .hero-banner__inner { grid-template-columns: 1fr 1fr; }
  }
  .hero-banner__media { border-radius: var(--style-border-radius-cards); overflow: hidden; }
  .hero-banner__image { width: 100%; height: auto; object-fit: cover; border-radius: var(--style-border-radius-cards); }
  .hero-banner__image--mobile { display: block; }
  .hero-banner__image--desktop { display: none; }
  @media (min-width: 768px) {
    .hero-banner__image--mobile { display: none; }
    .hero-banner__image--desktop { display: block; }
  }
  .hero-banner__heading {
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    font-weight: 700;
    color: var(--color-dark);
    margin-block-end: 1rem;
    line-height: 1.3;
  }
  .hero-banner__text {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-accent);
    margin-block-end: 1.5rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.hero_banner.name",
  "class": "hero-banner-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "صورة سطح المكتب (hero_banner_desktop.jpg)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "صورة الجوال (hero_banner_mobile.jpg)"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "نص alt للصورة",
      "default": "صورة للمنتجات من الأعلى - أنفاس العنود"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "العنوان",
      "default": "عيشي جوج.. وخلج غير عنهم"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "النص",
      "default": "تميزي بخلطات ما تتقلد، تعطيج حضورًا قويًا وتلفت الانتباه"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "نص الزر",
      "default": "تسوقي الآن"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "رابط الزر"
    }
  ],
  "presets": [{ "name": "t:sections.hero_banner.name" }]
}
{% endschema %}
