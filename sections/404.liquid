<section class="not-found section-padding">
  <div class="not-found__inner">
    <p class="not-found__code" aria-hidden="true">404</p>
    <h1 class="not-found__title">{{ '404.title' | t }}</h1>
    <p class="not-found__text">{{ '404.not_found' | t }}</p>
    <div class="not-found__actions">
      <a href="{{ routes.root_url }}" class="btn">{{ '404.back_home' | t }}</a>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--outline">{{ '404.back_to_shopping' | t }}</a>
    </div>
  </div>
</section>

{% stylesheet %}
  .not-found__inner {
    max-width: 28rem;
    margin-inline: auto;
    padding-inline: var(--page-margin);
    text-align: center;
  }
  .not-found__code {
    margin: 0 0 0.5rem;
    font-size: clamp(3rem, 12vw, 5rem);
    font-weight: 800;
    line-height: 1;
    color: color-mix(in srgb, var(--color-gold) 55%, var(--color-primary));
    letter-spacing: -0.04em;
  }
  .not-found__title {
    margin: 0 0 0.75rem;
    font-size: clamp(1.35rem, 4vw, 1.75rem);
    font-weight: 700;
    color: var(--color-dark);
    text-wrap: balance;
  }
  .not-found__text {
    margin: 0 0 1.75rem;
    line-height: 1.8;
    color: var(--color-accent);
    text-wrap: pretty;
  }
  .not-found__actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: stretch;
  }
  @media (min-width: 480px) {
    .not-found__actions {
      flex-direction: row;
      justify-content: center;
    }
    .not-found__actions .btn {
      min-width: 10rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.404",
  "class": "not-found-section",
  "settings": []
}
{% endschema %}
