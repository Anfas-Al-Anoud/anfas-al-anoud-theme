{% stylesheet %}
  .trust-bar {
    background: color-mix(in srgb, var(--color-cream) 70%, var(--color-white));
    border-block: 1px solid color-mix(in srgb, var(--color-gold) 28%, transparent);
    overflow: hidden;
  }
  .trust-bar__viewport {
    max-width: var(--page-width);
    margin-inline: auto;
  }
  .trust-bar__list {
    list-style: none;
    margin: 0;
    padding: 0.55rem var(--page-margin);
    display: flex;
    flex-wrap: nowrap;
    gap: 0.75rem 1.25rem;
    align-items: center;
  }
  .trust-bar__list--static {
    justify-content: space-between;
  }
  .trust-bar__marquee {
    display: none;
  }
  .trust-bar__item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-dark);
    white-space: nowrap;
  }
  .trust-bar__icon {
    display: inline-flex;
    color: var(--color-primary);
  }

  @media (max-width: 767px) {
    .trust-bar__list--static {
      display: none;
    }
    .trust-bar__marquee {
      display: block;
      overflow: hidden;
      padding-block: 0.45rem;
    }
    .trust-bar__list--track {
      width: max-content;
      padding-inline: 0;
      gap: 1.75rem;
      animation: trust-bar-marquee 28s linear infinite;
    }
    [dir="rtl"] .trust-bar__list--track {
      animation-name: trust-bar-marquee-rtl;
    }
    .trust-bar__item {
      font-size: 0.68rem;
    }
  }

  @keyframes trust-bar-marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @keyframes trust-bar-marquee-rtl {
    0% { transform: translateX(0); }
    100% { transform: translateX(50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .trust-bar__list--track {
      animation: none;
      width: 100%;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.5rem 1rem;
      padding-inline: var(--page-margin);
    }
    .trust-bar__list--track .trust-bar__item:nth-child(n + 5) {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.trust_bar.name",
  "class": "trust-bar-section",
  "settings": [],
  "presets": [{ "name": "t:sections.trust_bar.name" }]
}
{% endschema %}
