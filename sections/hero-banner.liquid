<section class="hero-banner full-width" data-animate-section>
  <div class="hero-banner__frame">
    <div class="hero-banner__media" aria-hidden="true">
      {% if section.settings.image_desktop %}
        {% render 'image',
          image: section.settings.image_desktop,
          alt: section.settings.image_alt,
          fallback_alt: section.settings.heading,
          class: 'hero-banner__image hero-banner__image--desktop',
          width: 1920,
          loading: 'eager'
        %}
      {% else %}
        {% liquid
          assign desktop_asset = section.settings.image_desktop_asset | default: 'hero-banner-desktop.jpg'
        %}
        {% render 'theme-asset-image',
          asset: desktop_asset,
          alt: section.settings.image_alt,
          class: 'hero-banner__image hero-banner__image--desktop',
          width: 1920,
          loading: 'eager'
        %}
      {% endif %}
      {% if section.settings.image_mobile %}
        {% render 'image',
          image: section.settings.image_mobile,
          alt: section.settings.image_alt,
          fallback_alt: section.settings.heading,
          class: 'hero-banner__image hero-banner__image--mobile',
          width: 900,
          loading: 'eager'
        %}
      {% elsif section.settings.image_desktop %}
        {% render 'image',
          image: section.settings.image_desktop,
          alt: section.settings.image_alt,
          fallback_alt: section.settings.heading,
          class: 'hero-banner__image hero-banner__image--mobile',
          width: 900,
          loading: 'eager'
        %}
      {% else %}
        {% liquid
          assign mobile_asset = section.settings.image_mobile_asset | default: 'hero-banner-mobile.jpg'
        %}
        {% render 'theme-asset-image',
          asset: mobile_asset,
          alt: section.settings.image_alt,
          class: 'hero-banner__image hero-banner__image--mobile',
          width: 900,
          loading: 'eager'
        %}
      {% endif %}
      <div class="hero-banner__veil"></div>
    </div>

    <div class="hero-banner__content">
      <p class="hero-banner__eyebrow">أنفاس العنود</p>
      <h1 class="hero-banner__heading">{{ section.settings.heading }}</h1>
      <p class="hero-banner__text">{{ section.settings.text }}</p>
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="hero-banner__btn btn btn--gold">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .hero-banner {
    padding-block: clamp(1rem, 3vw, 2rem);
    padding-inline: var(--page-margin);
  }

  .hero-banner__frame {
    position: relative;
    max-width: var(--page-width);
    margin-inline: auto;
    border-radius: calc(var(--style-border-radius-cards) + 4px);
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(61, 43, 31, 0.18);
  }

  .hero-banner__media {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero-banner__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .hero-banner__image--mobile { display: block; }
  .hero-banner__image--desktop { display: none; }

  .hero-banner__veil {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(270deg, rgba(94, 20, 31, 0.92) 0%, rgba(122, 31, 43, 0.6) 45%, rgba(122, 31, 43, 0.12) 100%),
      radial-gradient(circle at 90% 15%, rgba(201, 162, 76, 0.32), transparent 55%);
  }

  .hero-banner__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    text-align: start;
    min-height: clamp(17rem, 52vh, 30rem);
    padding: clamp(1.75rem, 6vw, 4.5rem);
    color: var(--color-white);
  }

  .hero-banner__eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold);
    font-weight: 700;
  }

  .hero-banner__heading {
    margin: 0 0 1rem;
    font-size: clamp(2rem, 6vw, 3.25rem);
    font-weight: 800;
    line-height: 1.2;
    text-wrap: balance;
  }

  .hero-banner__text {
    margin: 0 0 1.75rem;
    font-size: clamp(1rem, 2.4vw, 1.2rem);
    line-height: 1.9;
    color: rgba(255, 255, 255, 0.92);
    max-width: 32rem;
  }

  .hero-banner__btn {
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.22);
  }

  @media (max-width: 767px) {
    .hero-banner {
      padding: 0;
    }

    .hero-banner__frame {
      max-width: none;
      width: 100%;
      border-radius: 0;
      box-shadow: none;
      aspect-ratio: 1.7 / 1;
      min-height: 14.5rem;
    }

    .hero-banner__veil {
      background:
        linear-gradient(90deg, rgba(94, 20, 31, 0.88) 0%, rgba(94, 20, 31, 0.45) 55%, rgba(94, 20, 31, 0.15) 100%),
        linear-gradient(0deg, rgba(61, 43, 31, 0.55) 0%, transparent 50%);
    }

    .hero-banner__content {
      position: absolute;
      inset: 0;
      z-index: 2;
      min-height: 0;
      justify-content: center;
      align-items: flex-start;
      padding: 0.75rem var(--page-margin);
      max-width: 72%;
    }

    .hero-banner__eyebrow {
      font-size: 0.625rem;
      margin-block-end: 0.25rem;
      letter-spacing: 0.08em;
    }

    .hero-banner__heading {
      font-size: clamp(1.0625rem, 4.2vw, 1.25rem);
      margin-block-end: 0.5rem;
      line-height: 1.3;
    }

    .hero-banner__text {
      display: none;
    }

    .hero-banner__btn {
      padding: 0.4375rem 0.875rem;
      font-size: 0.75rem;
      margin-block-start: 0;
    }
  }

  @media (min-width: 768px) {
    .hero-banner__frame {
      max-height: 80vh;
      min-height: 28rem;
    }

    .hero-banner__image--mobile { display: none; }
    .hero-banner__image--desktop { display: block; }

    .hero-banner__content {
      min-height: 100%;
      max-width: 34rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.hero_banner.name",
  "class": "hero-banner-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "صورة سطح المكتب (hero_banner_desktop.jpg)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "صورة الجوال (hero_banner_mobile.jpg)"
    },
    {
      "type": "text",
      "id": "image_desktop_asset",
      "label": "ملف صورة الديسكتوب (assets/)",
      "default": "hero-banner-desktop.jpg",
      "info": "صورة سياقية من مجلد assets — ليست صورة منتج."
    },
    {
      "type": "text",
      "id": "image_mobile_asset",
      "label": "ملف صورة الجوال (assets/)",
      "default": "hero-banner-mobile.jpg"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "نص alt للصورة (مطلوب)",
      "default": "صورة للمنتجات من الأعلى - أنفاس العنود",
      "info": "مطلوب لإمكانية الوصول ومحركات البحث. لا تتركي الحقل فارغًا."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "العنوان",
      "default": "عيشي جوج.. وخلج غير عنهم"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "النص",
      "default": "تميزي بخلطات ما تتقلد، تعطيج حضورًا قويًا وتلفت الانتباه"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "نص الزر",
      "default": "تسوقي الآن"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "رابط الزر"
    }
  ],
  "presets": [{ "name": "t:sections.hero_banner.name" }]
}
{% endschema %}
