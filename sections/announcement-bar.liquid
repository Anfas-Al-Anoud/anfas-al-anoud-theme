<div class="announcement-bar full-width" role="region" aria-label="{{ 'sections.announcement_bar.name' | t }}">
  <div class="announcement-bar__track">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        <p class="announcement-bar__text" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
      {% endfor %}
      {% for block in section.blocks %}
        <p class="announcement-bar__text" aria-hidden="true">{{ block.settings.text }}</p>
      {% endfor %}
    {% else %}
      <p class="announcement-bar__text">{{ section.settings.text }}</p>
      <p class="announcement-bar__text" aria-hidden="true">{{ section.settings.text }}</p>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .announcement-bar {
    background: var(--color-primary);
    color: var(--color-primary-foreground);
    overflow: hidden;
    padding-block: 0.625rem;
  }

  .announcement-bar__track {
    display: flex;
    width: max-content;
    animation: marquee 36s linear infinite;
  }

  .announcement-bar__text {
    white-space: nowrap;
    padding-inline: 3rem;
    font-size: 0.875rem;
    margin: 0;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes marquee-rtl {
    0% { transform: translateX(0); }
    100% { transform: translateX(50%); }
  }

  [dir="rtl"] .announcement-bar__track {
    animation-name: marquee-rtl;
  }

  @media (max-width: 767px) {
    .announcement-bar {
      padding-block: 0.35rem;
    }

    .announcement-bar__text {
      font-size: 0.75rem;
      padding-inline: 1.75rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .announcement-bar__track {
      animation: none;
      width: 100%;
      flex-wrap: wrap;
      justify-content: center;
    }

    .announcement-bar__text[aria-hidden="true"] {
      display: none;
    }
  }
{% endstylesheet %}

