{%- liquid
  assign threshold = settings.free_shipping_threshold | default: 200
-%}
<section class="trust-bar full-width" aria-label="{{ 'sections.trust_bar.name' | t }}">
  <ul class="trust-bar__list">
    <li class="trust-bar__item">
      <span class="trust-bar__icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M1 3h15v13H1V3zm16 8h3l3 3v2h-6v-5zM5 21a2 2 0 100-4 2 2 0 000 4zm12 0a2 2 0 100-4 2 2 0 000 4z" stroke="currentColor" stroke-width="1.6"/></svg>
      </span>
      <span>{{ 'sections.trust_bar.free_shipping' | t: amount: threshold }}</span>
    </li>
    <li class="trust-bar__item">
      <span class="trust-bar__icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 8v4l3 2M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
      </span>
      <span>{{ 'sections.trust_bar.fast_prep' | t }}</span>
    </li>
    <li class="trust-bar__item">
      <span class="trust-bar__icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M2 10h20" stroke="currentColor" stroke-width="1.6"/></svg>
      </span>
      <span>{{ 'sections.trust_bar.cod' | t }}</span>
    </li>
    <li class="trust-bar__item">
      <span class="trust-bar__icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 21s-7-4.5-7-10a4 4 0 017-2.6A4 4 0 0119 11c0 5.5-7 10-7 10z" stroke="currentColor" stroke-width="1.6"/></svg>
      </span>
      <span>{{ 'sections.trust_bar.returns' | t }}</span>
    </li>
  </ul>
</section>

{% stylesheet %}
  .trust-bar {
    background: color-mix(in srgb, var(--color-cream) 70%, var(--color-white));
    border-block-end: 1px solid color-mix(in srgb, var(--color-gold) 28%, transparent);
  }
  .trust-bar__list {
    list-style: none;
    margin: 0;
    padding: 0.55rem var(--page-margin);
    max-width: var(--page-width);
    margin-inline: auto;
    display: flex;
    flex-wrap: nowrap;
    gap: 0.75rem 1.25rem;
    justify-content: space-between;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .trust-bar__list::-webkit-scrollbar { display: none; }
  .trust-bar__item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-dark);
    white-space: nowrap;
  }
  .trust-bar__icon {
    display: inline-flex;
    color: var(--color-primary);
  }
  @media (max-width: 767px) {
    .trust-bar__list {
      padding-block: 0.45rem;
      gap: 0.85rem;
      justify-content: flex-start;
    }
    .trust-bar__item {
      font-size: 0.68rem;
    }
  }

  /* Overlay homepage: keep chrome to announcement + floating header only */
  .header-style--overlay.template-index .trust-bar-section {
    display: none;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.trust_bar.name",
  "class": "trust-bar-section",
  "settings": [],
  "presets": [{ "name": "t:sections.trust_bar.name" }]
}
{% endschema %}
