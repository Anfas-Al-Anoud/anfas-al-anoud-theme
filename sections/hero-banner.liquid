<section class="hero-banner" data-animate-section>
  <div class="hero-banner__frame">
    <div class="hero-banner__media" aria-hidden="true">
      {% if section.settings.image_desktop %}
        {% render 'image',
          image: section.settings.image_desktop,
          alt: section.settings.image_alt,
          fallback_alt: section.settings.heading,
          class: 'hero-banner__image hero-banner__image--desktop',
          width: 1920,
          loading: 'eager'
        %}
      {% else %}
        {% render 'placeholder-svg',
          text: section.settings.image_alt,
          class: 'hero-banner__image hero-banner__image--desktop hero-banner__placeholder',
          width: '100%',
          height: '100%'
        %}
      {% endif %}
      {% if section.settings.image_mobile %}
        {% render 'image',
          image: section.settings.image_mobile,
          alt: section.settings.image_alt,
          fallback_alt: section.settings.heading,
          class: 'hero-banner__image hero-banner__image--mobile',
          width: 900,
          loading: 'eager'
        %}
      {% elsif section.settings.image_desktop %}
        {% render 'image',
          image: section.settings.image_desktop,
          alt: section.settings.image_alt,
          fallback_alt: section.settings.heading,
          class: 'hero-banner__image hero-banner__image--mobile',
          width: 900,
          loading: 'eager'
        %}
      {% else %}
        {% render 'placeholder-svg',
          text: section.settings.image_alt,
          class: 'hero-banner__image hero-banner__image--mobile hero-banner__placeholder',
          width: '100%',
          height: '100%'
        %}
      {% endif %}
      <div class="hero-banner__veil"></div>
    </div>

    <div class="hero-banner__content">
      <p class="hero-banner__eyebrow">أنفاس العنود</p>
      <h1 class="hero-banner__heading">{{ section.settings.heading }}</h1>
      <p class="hero-banner__text">{{ section.settings.text }}</p>
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="hero-banner__btn btn">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .hero-banner {
    padding-block: clamp(1rem, 3vw, 2rem);
    padding-inline: var(--page-margin);
  }

  .hero-banner__frame {
    position: relative;
    max-width: var(--page-width);
    margin-inline: auto;
    border-radius: calc(var(--style-border-radius-cards) + 4px);
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(61, 43, 31, 0.18);
    max-height: 100vh;
  }

  @media (min-width: 768px) {
    .hero-banner__frame {
      max-height: 80vh;
      min-height: 28rem;
    }
  }

  .hero-banner__media {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero-banner__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .hero-banner__placeholder {
    min-height: 100%;
  }

  .hero-banner__image--mobile { display: block; }
  .hero-banner__image--desktop { display: none; }

  @media (min-width: 768px) {
    .hero-banner__image--mobile { display: none; }
    .hero-banner__image--desktop { display: block; }
  }

  .hero-banner__veil {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(105deg, rgba(61, 43, 31, 0.88) 0%, rgba(61, 43, 31, 0.55) 42%, rgba(196, 163, 90, 0.25) 100%),
      radial-gradient(circle at 80% 20%, rgba(196, 163, 90, 0.35), transparent 55%);
  }

  .hero-banner__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    text-align: start;
    min-height: clamp(22rem, 72vh, 36rem);
    padding: clamp(2rem, 6vw, 4.5rem);
    color: var(--color-white);
  }

  @media (min-width: 768px) {
    .hero-banner__content {
      min-height: 100%;
      max-width: 34rem;
    }
  }

  .hero-banner__eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-sand);
    font-weight: 700;
  }

  .hero-banner__heading {
    margin: 0 0 1rem;
    font-size: clamp(2rem, 6vw, 3.25rem);
    font-weight: 800;
    line-height: 1.2;
    text-wrap: balance;
  }

  .hero-banner__text {
    margin: 0 0 1.75rem;
    font-size: clamp(1rem, 2.4vw, 1.2rem);
    line-height: 1.9;
    color: rgba(255, 255, 255, 0.92);
    max-width: 32rem;
  }

  .hero-banner__btn {
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.22);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.hero_banner.name",
  "class": "hero-banner-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "صورة سطح المكتب (hero_banner_desktop.jpg)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "صورة الجوال (hero_banner_mobile.jpg)"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "نص alt للصورة (مطلوب)",
      "default": "صورة للمنتجات من الأعلى - أنفاس العنود",
      "info": "مطلوب لإمكانية الوصول ومحركات البحث. لا تتركي الحقل فارغًا."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "العنوان",
      "default": "عيشي جوج.. وخلج غير عنهم"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "النص",
      "default": "تميزي بخلطات ما تتقلد، تعطيج حضورًا قويًا وتلفت الانتباه"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "نص الزر",
      "default": "تسوقي الآن"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "رابط الزر"
    }
  ],
  "presets": [{ "name": "t:sections.hero_banner.name" }]
}
{% endschema %}
