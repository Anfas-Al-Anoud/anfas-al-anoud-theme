<footer class="site-footer section-padding full-width">
  <div class="site-footer__grid">
    <div class="site-footer__col">
      <h3 class="site-footer__heading">{{ section.settings.contact_heading }}</h3>
      <p class="site-footer__text">{{ section.settings.contact_text }}</p>
      {% if settings.whatsapp_number != blank %}
        <a
          href="https://wa.me/{{ settings.whatsapp_number }}"
          class="site-footer__whatsapp btn"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="تواصلي عبر واتساب"
        >
          {{ 'icon-whatsapp.svg' | inline_asset_content }}
          رمسيني
        </a>
      {% endif %}
    </div>

    <div class="site-footer__col">
      <nav aria-label="روابط مهمة">
        <ul class="site-footer__links">
          <li><a href="/pages/order-tracking">وين طلبج؟</a></li>
          <li><a href="/pages/privacy-policy">أمانج وخصوصيتج</a></li>
          <li><a href="/pages/terms">اتفاقنا الحلو</a></li>
          <li><a href="/pages/returns">إذا ما عيبج؟</a></li>
          <li><a href="/pages/payment-methods">دفعي باللي يريّحج</a></li>
        </ul>
      </nav>
    </div>

    <div class="site-footer__col site-footer__col--social">
      <h3 class="site-footer__heading">{{ section.settings.social_heading }}</h3>
      <p class="site-footer__text">{{ section.settings.social_text }}</p>
      <div class="site-footer__social">
        {% if settings.social_instagram != blank %}
          <a href="{{ settings.social_instagram }}" class="site-footer__social-link" target="_blank" rel="noopener" aria-label="Instagram">
            <span class="site-footer__social-icon" aria-hidden="true">{{ 'icon-instagram.svg' | inline_asset_content }}</span>
          </a>
        {% endif %}
        {% if settings.social_tiktok != blank %}
          <a href="{{ settings.social_tiktok }}" class="site-footer__social-link" target="_blank" rel="noopener" aria-label="TikTok">
            <span class="site-footer__social-icon" aria-hidden="true">{{ 'icon-tiktok.svg' | inline_asset_content }}</span>
          </a>
        {% endif %}
        {% if settings.social_snapchat != blank %}
          <a href="{{ settings.social_snapchat }}" class="site-footer__social-link" target="_blank" rel="noopener" aria-label="Snapchat">
            <span class="site-footer__social-icon" aria-hidden="true">{{ 'icon-snapchat.svg' | inline_asset_content }}</span>
          </a>
        {% endif %}
        {% if settings.social_facebook != blank %}
          <a href="{{ settings.social_facebook }}" class="site-footer__social-link" target="_blank" rel="noopener" aria-label="Facebook">
            <span class="site-footer__social-icon" aria-hidden="true">{{ 'icon-facebook.svg' | inline_asset_content }}</span>
          </a>
        {% endif %}
        {% if settings.social_threads != blank %}
          <a href="{{ settings.social_threads }}" class="site-footer__social-link" target="_blank" rel="noopener" aria-label="Threads">
            <span class="site-footer__social-icon" aria-hidden="true">{{ 'icon-threads.svg' | inline_asset_content }}</span>
          </a>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="site-footer__newsletter">
    {% form 'customer', class: 'site-footer__newsletter-form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input
        type="email"
        name="contact[email]"
        placeholder="حطي إيميلج هنيه"
        aria-label="البريد الإلكتروني للنشرة"
        required
      >
      <button type="submit" class="btn">خلينا على تواصل</button>
    {% endform %}
  </div>

  <div class="site-footer__bottom">
    <p>&copy; <span translate="no">أنفاس العنود</span>. جميع الحقوق محفوظة.</p>
    {% if section.settings.show_payment_icons %}
      <div class="site-footer__payment">
        {% for type in shop.enabled_payment_types %}
          {{ type | payment_type_svg_tag }}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</footer>

{% stylesheet %}
  .site-footer {
    background: var(--color-dark);
    color: var(--color-sand);
  }
  .site-footer__grid {
    display: grid;
    gap: 2rem;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
    margin-block-end: 2rem;
  }
  @media (min-width: 768px) {
    .site-footer__grid { grid-template-columns: repeat(3, 1fr); }
  }
  .site-footer__heading {
    color: var(--color-gold);
    font-size: 1.125rem;
    margin-block-end: 0.75rem;
  }
  .site-footer__text {
    line-height: 1.7;
    margin-block-end: 1rem;
    font-size: 0.9rem;
  }
  .site-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .site-footer__links a {
    color: var(--color-sand);
    text-decoration: none;
    display: block;
    padding-block: 0.35rem;
    transition: color var(--transition-base);
  }
  .site-footer__links a:hover { color: var(--color-gold); }
  .site-footer__social {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .site-footer__social a {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--color-accent);
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: background var(--transition-base), transform var(--transition-base);
  }
  .site-footer__social a:hover {
    background: var(--color-gold);
    transform: scale(1.05);
  }
  .site-footer__social-icon svg {
    width: 1.25rem;
    height: 1.25rem;
    display: block;
  }
  .site-footer__newsletter {
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
    margin-block-end: 2rem;
  }
  .site-footer__newsletter-form {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    max-width: 32rem;
    margin-inline: auto;
  }
  .site-footer__newsletter-form input {
    flex: 1;
    min-width: 200px;
    padding: 0.875rem 1.25rem;
    border: none;
    border-radius: var(--style-border-radius-inputs);
  }
  .site-footer__bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
    padding-block-start: 1.5rem;
    border-block-start: 1px solid rgba(232, 213, 183, 0.2);
    font-size: 0.85rem;
  }
  .site-footer__payment {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  @media (max-width: 767px) {
    .site-footer.section-padding {
      padding-block: 1.5rem 1.25rem;
    }

    .site-footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 1rem 0.75rem;
      margin-block-end: 1rem;
    }

    .site-footer__col:first-child {
      grid-column: 1 / -1;
    }

    .site-footer__col--social {
      grid-column: 1 / -1;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .site-footer__col--social .site-footer__heading {
      margin-block-end: 0.625rem;
    }

    .site-footer__social {
      justify-content: center;
    }

    .site-footer__text {
      display: none;
    }

    .site-footer__heading {
      font-size: 0.9375rem;
      margin-block-end: 0.5rem;
    }

    .site-footer__links a {
      padding-block: 0.2rem;
      font-size: 0.8125rem;
    }

    .site-footer__whatsapp {
      padding: 0.5rem 1rem;
      font-size: 0.8125rem;
    }

    .site-footer__social a {
      width: 2rem;
      height: 2rem;
    }

    .site-footer__social-icon svg {
      width: 1rem;
      height: 1rem;
    }

    .site-footer__newsletter {
      margin-block-end: 1rem;
    }

    .site-footer__newsletter-form {
      flex-direction: column;
      gap: 0.5rem;
    }

    .site-footer__newsletter-form input {
      min-width: 0;
      padding: 0.625rem 1rem;
      font-size: 0.875rem;
    }

    .site-footer__newsletter-form .btn {
      width: 100%;
      padding: 0.625rem 1rem;
      font-size: 0.875rem;
    }

    .site-footer__bottom {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0.75rem;
      padding-block-start: 1rem;
      font-size: 0.75rem;
    }

    .site-footer__payment {
      justify-content: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "class": "site-footer-section",
  "settings": [
    {
      "type": "text",
      "id": "contact_heading",
      "label": "عنوان التواصل",
      "default": "رمسيني.. وريّحي بالج"
    },
    {
      "type": "textarea",
      "id": "contact_text",
      "label": "نص التواصل",
      "default": "أي شي بخاطرج، سواء استشارة أو متابعة لطلبيتج، كلميني ومابقصر وياج، رضاج وراحتج هي غايتي."
    },
    {
      "type": "text",
      "id": "social_heading",
      "label": "عنوان السوشيال",
      "default": "لمتنا أحلى وياج"
    },
    {
      "type": "textarea",
      "id": "social_text",
      "label": "نص السوشيال",
      "default": "خلك قريبة من القلب وتابعينا.. عشان تشوفين نصايحي السريعة للسنع، وأجدد عروضي، وتكونين جزءًا من عايلتنا."
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    }
  ]
}
{% endschema %}
