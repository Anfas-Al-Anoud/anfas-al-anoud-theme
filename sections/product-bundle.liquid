{%- liquid
  assign bundle_total = 0
  assign bundle_compare = 0
  assign item_count = 0
-%}

<section class="product-bundle section-padding" data-product-bundle data-animate-section>
  <div class="product-bundle__header">
    <h2 class="section-heading product-bundle__heading">{% render 'tanween', text: section.settings.heading %}</h2>
    {% if section.settings.subheading != blank %}
      <p class="section-subheading product-bundle__subheading">{% render 'tanween', text: section.settings.subheading %}</p>
    {% endif %}
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="product-bundle__grid">
      {%- for block in section.blocks -%}
        {%- assign bundle_product = block.settings.product -%}
        {%- if bundle_product != blank -%}
          {%- assign variant = bundle_product.selected_or_first_available_variant -%}
          {%- assign bundle_total = bundle_total | plus: variant.price -%}
          {%- if variant.compare_at_price > variant.price -%}
            {%- assign bundle_compare = bundle_compare | plus: variant.compare_at_price -%}
          {%- else -%}
            {%- assign bundle_compare = bundle_compare | plus: variant.price -%}
          {%- endif -%}
          {%- assign item_count = item_count | plus: 1 -%}
          <article class="product-bundle__item" {{ block.shopify_attributes }} data-bundle-item data-variant-id="{{ variant.id }}">
            <a href="{{ bundle_product.url }}" class="product-bundle__media">
              {% if bundle_product.featured_image %}
                {% render 'image', image: bundle_product.featured_image, alt: bundle_product.title, width: 400 %}
              {% endif %}
            </a>
            <div class="product-bundle__info">
              <h3 class="product-bundle__title">
                <a href="{{ bundle_product.url }}">{% render 'tanween', text: bundle_product.title %}</a>
              </h3>
              <p class="product-bundle__price">{{ variant.price | money_without_currency }} {{ 'general.currency' | t }}</p>
            </div>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if item_count > 1 -%}
      <div class="product-bundle__footer">
        <div class="product-bundle__pricing">
          <span class="product-bundle__pricing-label">{{ 'sections.product_bundle.total' | t }}</span>
          <div class="product-bundle__pricing-values">
            {% if bundle_compare > bundle_total %}
              <s class="product-bundle__compare">{{ bundle_compare | money_without_currency }} {{ 'general.currency' | t }}</s>
            {% endif %}
            <span class="product-bundle__total">{{ bundle_total | money_without_currency }} {{ 'general.currency' | t }}</span>
          </div>
        </div>
        <button type="button" class="btn product-bundle__add" data-bundle-add data-add-text="{{ section.settings.button_label | default: 'sections.product_bundle.add' | t }}">
          {{ section.settings.button_label | default: 'أضيفي الباقة' }}
        </button>
        <p class="product-bundle__error" data-bundle-error hidden role="alert"></p>
      </div>
    {%- endif -%}
  {%- endif -%}
</section>

{% stylesheet %}
  .product-bundle__header {
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
    margin-block-end: 1.25rem;
  }
  .product-bundle__heading,
  .product-bundle__subheading { text-align: start; margin-inline: 0; }
  .product-bundle__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }
  @media (min-width: 768px) {
    .product-bundle__grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  }
  .product-bundle__item {
    background: var(--color-white);
    border-radius: var(--style-border-radius-cards);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .product-bundle__media { display: block; aspect-ratio: 1; overflow: hidden; }
  .product-bundle__media img { width: 100%; height: 100%; object-fit: cover; }
  .product-bundle__info { padding: 0.85rem; display: flex; flex-direction: column; gap: 0.35rem; flex: 1; }
  .product-bundle__title { font-size: 0.9rem; margin: 0; line-height: 1.4; }
  .product-bundle__title a { color: inherit; text-decoration: none; }
  .product-bundle__price { color: var(--color-primary); font-weight: 700; margin: 0; }
  .product-bundle__footer {
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
    margin-block-start: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    text-align: center;
  }
  .product-bundle__pricing { display: flex; flex-direction: column; gap: 0.25rem; }
  .product-bundle__pricing-label { font-size: 0.9rem; color: var(--color-accent); font-weight: 600; }
  .product-bundle__pricing-values { display: flex; gap: 0.6rem; align-items: baseline; justify-content: center; }
  .product-bundle__compare { color: #6b635c; }
  .product-bundle__total { font-size: 1.35rem; font-weight: 700; color: var(--color-primary); }
  .product-bundle__add { min-width: min(100%, 18rem); }
  .product-bundle__add.is-loading { opacity: 0.7; pointer-events: none; }
  .product-bundle__error { color: #c0392b; font-size: 0.9rem; }
  .product-bundle__error[hidden] { display: none; }
{% endstylesheet %}

{% javascript %}
  document.querySelectorAll('[data-product-bundle]').forEach((section) => {
    const btn = section.querySelector('[data-bundle-add]');
    if (!btn) return;
    const errorEl = section.querySelector('[data-bundle-error]');
    btn.addEventListener('click', async () => {
      const items = Array.from(section.querySelectorAll('[data-bundle-item]'))
        .map((el) => ({ id: Number(el.dataset.variantId), quantity: 1 }))
        .filter((i) => i.id);
      if (!items.length || !window.cartDrawer) return;
      if (errorEl) errorEl.hidden = true;
      btn.classList.add('is-loading');
      try {
        const res = await fetch(`${window.Shopify?.routes?.root || '/'}cart/add.js`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({ items }),
        });
        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          throw new Error(err.description || 'add failed');
        }
        const cart = await window.cartDrawer.fetchCart();
        if (cart) window.cartDrawer.render(cart);
        window.cartDrawer.open();
      } catch (err) {
        if (errorEl) {
          errorEl.textContent = err.message || 'صار خطأ، حاولي مرة ثانية';
          errorEl.hidden = false;
        }
      } finally {
        btn.classList.remove('is-loading');
      }
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.product_bundle.name",
  "class": "product-bundle-section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "بوكسات الزين — باقة كاملة"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:labels.subheading",
      "default": "اختاري منتجات الباقة وأضيفيها للسلة دفعة واحدة — هدية جاهزة من العنود."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:labels.button_label",
      "default": "أضيفي الباقة"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "t:sections.product_bundle.product_block",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "t:labels.product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.product_bundle.name",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
