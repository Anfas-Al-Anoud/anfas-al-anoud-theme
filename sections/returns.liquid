<article class="page-content section-padding">
  <div class="page-content__inner">
    <h1 class="page-content__title">إذا ما عيبج؟</h1>
    <div class="page-content__body rte">
      {% if page.content != blank %}
        {{ page.content }}
      {% else %}
        <p>إذا ما عجبج المنتج، تقدرين ترجعينه خلال 3 أيام من استلام الطلب بشرط أن يكون بحالته الأصلية.</p>
        <p>تواصلي معنا عبر واتساب لترتيب الإرجاع — شكرًا لتفهمج.</p>
      {% endif %}
    </div>
  </div>
</article>

{% stylesheet %}
  .page-content__inner { max-width: 48rem; margin-inline: auto; padding-inline: var(--page-margin); line-height: 1.8; }
  .page-content__title { font-size: clamp(1.5rem, 4vw, 2.25rem); font-weight: 700; margin-block-end: 1.5rem; color: var(--color-dark); }
{% endstylesheet %}

{% schema %}
{
  "name": "Returns",
  "class": "returns-section",
  "settings": []
}
{% endschema %}
