{% doc %}
  Renders an image stored in the theme assets/ folder by filename.
  @param {string} asset - Filename in assets/ e.g. hero-banner-desktop.jpg
  @param {string} [alt]
  @param {string} [class]
  @param {number} [width]
  @param {string} [loading]
{% enddoc %}

{% liquid
  assign alt_text = alt | default: shop.name
  assign img_loading = loading | default: 'lazy'
  assign img_width = width | default: 1200
%}

{% if asset != blank %}
  <img
    src="{{ asset | asset_url }}"
    alt="{{ alt_text | escape }}"
    class="{{ class }}"
    loading="{{ img_loading }}"
    width="{{ img_width }}"
    decoding="async"
  >
{% endif %}
