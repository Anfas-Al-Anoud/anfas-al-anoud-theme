{%- liquid
  assign header_style = settings.header_style | default: 'classic'
  assign desktop_asset = section.settings.image_desktop_asset | default: 'hero-banner-desktop.jpg'
  assign mobile_asset = section.settings.image_mobile_asset | default: 'hero-banner-mobile.jpg'
  assign desktop_image = section.settings.image_desktop
  assign mobile_image = section.settings.image_mobile
  assign hero_bg_color = section.settings.background_color | default: '#2a221c'

  if header_style == 'commerce'
    assign desktop_asset = section.settings.commerce_desktop_asset | default: 'hero-banner-desktop.jpg'
    assign mobile_asset = section.settings.commerce_mobile_asset | default: 'hero-banner-mobile.jpg'
    if desktop_image == blank and section.settings.commerce_image_desktop != blank
      assign desktop_image = section.settings.commerce_image_desktop
    endif
    if mobile_image == blank and section.settings.commerce_image_mobile != blank
      assign mobile_image = section.settings.commerce_image_mobile
    endif
  elsif header_style == 'overlay'
    assign desktop_asset = section.settings.overlay_desktop_asset | default: 'hero-overlay-desktop.png'
    assign mobile_asset = section.settings.overlay_mobile_asset | default: 'hero-overlay-mobile.png'
    if desktop_image == blank and section.settings.overlay_image_desktop != blank
      assign desktop_image = section.settings.overlay_image_desktop
    endif
    if mobile_image == blank and section.settings.overlay_image_mobile != blank
      assign mobile_image = section.settings.overlay_image_mobile
    endif
  endif

  assign inset_asset = section.settings.overlay_inset_asset | default: 'hero-overlay-inset.png'

  assign hero_heading = section.settings.heading
  if header_style == 'commerce'
    if section.settings.commerce_heading != blank
      assign hero_heading = section.settings.commerce_heading
    endif
  endif
-%}
<section
  class="hero-banner full-width hero-banner--{{ header_style }}"
  data-animate-section
  style="--hero-bg: {{ hero_bg_color }};"
>
  <div class="hero-banner__frame">
    <div class="hero-banner__media" aria-hidden="true">
      {% if desktop_image %}
        {% render 'image',
          image: desktop_image,
          alt: section.settings.image_alt,
          fallback_alt: section.settings.heading,
          class: 'hero-banner__image hero-banner__image--desktop',
          width: 1920,
          loading: 'eager'
        %}
      {% else %}
        {% render 'theme-asset-image',
          asset: desktop_asset,
          alt: section.settings.image_alt,
          class: 'hero-banner__image hero-banner__image--desktop',
          width: 1920,
          loading: 'eager'
        %}
      {% endif %}

      {% if mobile_image %}
        {% render 'image',
          image: mobile_image,
          alt: section.settings.image_alt,
          fallback_alt: section.settings.heading,
          class: 'hero-banner__image hero-banner__image--mobile',
          width: 900,
          loading: 'eager'
        %}
      {% elsif desktop_image %}
        {% render 'image',
          image: desktop_image,
          alt: section.settings.image_alt,
          fallback_alt: section.settings.heading,
          class: 'hero-banner__image hero-banner__image--mobile',
          width: 900,
          loading: 'eager'
        %}
      {% else %}
        {% render 'theme-asset-image',
          asset: mobile_asset,
          alt: section.settings.image_alt,
          class: 'hero-banner__image hero-banner__image--mobile',
          width: 900,
          loading: 'eager'
        %}
      {% endif %}
      <div class="hero-banner__veil"></div>
    </div>

    {%- if header_style == 'overlay' and section.settings.show_overlay_inset != false -%}
      <div class="hero-banner__inset">
        {% if section.settings.overlay_inset_image != blank %}
          {% render 'image',
            image: section.settings.overlay_inset_image,
            alt: section.settings.overlay_inset_alt,
            fallback_alt: section.settings.heading,
            class: 'hero-banner__inset-image',
            width: 900,
            loading: 'eager'
          %}
        {% else %}
          {% render 'theme-asset-image',
            asset: inset_asset,
            alt: section.settings.overlay_inset_alt,
            class: 'hero-banner__inset-image',
            width: 900,
            loading: 'eager'
          %}
        {% endif %}
      </div>
    {%- endif -%}

    <div class="hero-banner__content">
      {% if section.settings.eyebrow != blank %}
        <p class="hero-banner__eyebrow">{{ section.settings.eyebrow }}</p>
      {% else %}
        <p class="hero-banner__eyebrow">أنفاس العنود</p>
      {% endif %}
      <h1 class="hero-banner__heading">{{ hero_heading }}</h1>
      <p class="hero-banner__text">{{ section.settings.text }}</p>
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="hero-banner__btn">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .hero-banner {
    padding-block: clamp(1rem, 3vw, 2rem);
    padding-inline: var(--page-margin);
  }

  .hero-banner__frame {
    position: relative;
    max-width: var(--page-width);
    margin-inline: auto;
    border-radius: calc(var(--style-border-radius-cards) + 4px);
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(61, 43, 31, 0.18);
  }

  .hero-banner__media {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero-banner__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .hero-banner__image--mobile { display: block; }
  .hero-banner__image--desktop { display: none; }

  .hero-banner__veil {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(270deg, rgba(94, 20, 31, 0.92) 0%, rgba(122, 31, 43, 0.6) 45%, rgba(122, 31, 43, 0.12) 100%),
      radial-gradient(circle at 90% 15%, rgba(201, 162, 76, 0.32), transparent 55%);
  }

  .hero-banner__inset { display: none; }

  .hero-banner__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    text-align: start;
    min-height: clamp(17rem, 52vh, 30rem);
    padding: clamp(1.75rem, 6vw, 4.5rem);
    color: var(--color-white);
  }

  .hero-banner__eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold);
    font-weight: 700;
  }

  .hero-banner__heading {
    margin: 0 0 1rem;
    font-size: clamp(2rem, 6vw, 3.25rem);
    font-weight: 800;
    line-height: 1.2;
    text-wrap: balance;
  }

  .hero-banner__text {
    margin: 0 0 1.75rem;
    font-size: clamp(1rem, 2.4vw, 1.2rem);
    line-height: 1.9;
    color: rgba(255, 255, 255, 0.92);
    max-width: 32rem;
  }

  .hero-banner__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 1.6rem;
    border-radius: var(--style-border-radius-buttons, 999px);
    background: var(--color-gold);
    color: var(--color-white);
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.22);
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .hero-banner__btn:hover {
    transform: translateY(-1px);
  }

  /* —— Commerce: banner assets — desktop landscape, mobile half-viewport —— */
  .hero-banner--commerce {
    padding: 0;
    background: var(--hero-bg, #2a221c);
  }
  .hero-banner--commerce .hero-banner__frame {
    max-width: none;
    width: 100%;
    border-radius: 0;
    box-shadow: none;
    background: var(--hero-bg, #2a221c);
    aspect-ratio: 3 / 2;
    min-height: 0;
    max-height: min(78vh, 44rem);
  }
  .hero-banner--commerce .hero-banner__media {
    inset: 0;
  }
  .hero-banner--commerce .hero-banner__image {
    object-fit: cover;
    object-position: center 30%;
  }
  .hero-banner--commerce .hero-banner__veil {
    display: none;
  }
  .hero-banner--commerce .hero-banner__content {
    position: absolute;
    z-index: 2;
    /* Copy on dark negative space (left) */
    left: 0;
    right: auto;
    top: 0;
    bottom: 0;
    width: min(42%, 20rem);
    max-width: none;
    min-height: 0;
    justify-content: center;
    padding: 1.5rem 1rem 1.75rem 1.15rem;
    color: var(--color-cream);
  }
  .hero-banner--commerce .hero-banner__eyebrow {
    color: var(--color-gold);
    font-size: clamp(1.85rem, 8.5vw, 2.6rem);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 800;
    line-height: 0.95;
    margin: 0 0 0.2rem;
  }
  .hero-banner--commerce .hero-banner__heading {
    color: var(--color-cream);
    font-size: clamp(1rem, 3.8vw, 1.2rem);
    font-weight: 700;
    line-height: 1.35;
    margin: 0 0 1.1rem;
  }
  .hero-banner--commerce .hero-banner__text {
    display: none;
  }
  .hero-banner--commerce .hero-banner__btn {
    border-radius: 0.2rem;
    background: var(--color-gold);
    color: var(--color-dark);
    padding: 0.72rem 1.35rem;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    box-shadow: none;
    min-width: 8.75rem;
  }
  .hero-banner--commerce .hero-banner__btn:hover {
    background: color-mix(in srgb, var(--color-gold) 85%, #fff);
  }

  /* —— Overlay: full-bleed photo + centered PiP inset —— */
  .hero-banner--overlay {
    padding: 0;
    background: #eceae7;
  }
  .hero-banner--overlay .hero-banner__frame {
    max-width: none;
    width: 100%;
    border-radius: 0;
    box-shadow: none;
    min-height: calc(100svh - 2.75rem);
    min-height: calc(100vh - 2.75rem);
  }
  .hero-banner--overlay .hero-banner__veil {
    display: none;
  }
  .hero-banner--overlay .hero-banner__content {
    display: none;
  }
  .hero-banner--overlay .hero-banner__image {
    object-position: center 18%;
  }
  .hero-banner--overlay .hero-banner__inset {
    display: block;
    position: absolute;
    z-index: 3;
    left: 50%;
    top: 52%;
    transform: translate(-50%, -50%);
    width: min(72vw, 22rem);
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: 0.15rem;
    box-shadow: 0 18px 48px rgba(20, 12, 8, 0.28);
    animation: hero-inset-in 0.7s ease both;
  }
  .hero-banner--overlay .hero-banner__inset-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    display: block;
  }

  @keyframes hero-inset-in {
    from {
      opacity: 0;
      transform: translate(-50%, -46%) scale(0.96);
    }
    to {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-banner--overlay .hero-banner__inset {
      animation: none;
    }
    .hero-banner__btn {
      transition: none;
    }
  }

  @media (max-width: 767px) {
    .hero-banner--classic {
      padding: 0;
    }
    .hero-banner--classic .hero-banner__frame {
      max-width: none;
      width: 100%;
      border-radius: 0;
      box-shadow: none;
      aspect-ratio: 1.7 / 1;
      min-height: 14.5rem;
    }
    .hero-banner--classic .hero-banner__veil {
      background:
        linear-gradient(90deg, rgba(94, 20, 31, 0.88) 0%, rgba(94, 20, 31, 0.45) 55%, rgba(94, 20, 31, 0.15) 100%),
        linear-gradient(0deg, rgba(61, 43, 31, 0.55) 0%, transparent 50%);
    }
    .hero-banner--classic .hero-banner__content {
      position: absolute;
      inset: 0;
      z-index: 2;
      min-height: 0;
      justify-content: center;
      align-items: flex-start;
      padding: 0.75rem var(--page-margin);
      max-width: 72%;
    }
    .hero-banner--classic .hero-banner__eyebrow {
      font-size: 0.625rem;
      margin-block-end: 0.25rem;
    }
    .hero-banner--classic .hero-banner__heading {
      font-size: clamp(1.0625rem, 4.2vw, 1.25rem);
      margin-block-end: 0.5rem;
      line-height: 1.3;
    }
    .hero-banner--classic .hero-banner__text { display: none; }
    .hero-banner--classic .hero-banner__btn {
      padding: 0.4375rem 0.875rem;
      font-size: 0.75rem;
    }

    .hero-banner--commerce .hero-banner__frame {
      aspect-ratio: auto;
      height: 50svh;
      min-height: 50svh;
      max-height: 50svh;
    }
    .hero-banner--commerce .hero-banner__image {
      object-fit: cover;
      object-position: 22% center;
    }
    .hero-banner--commerce .hero-banner__content {
      left: 0;
      right: auto;
      width: min(58%, 14rem);
      padding: 1.25rem 0.75rem 1.25rem 1rem;
      justify-content: flex-end;
    }
    .hero-banner--commerce .hero-banner__eyebrow {
      font-size: clamp(1.35rem, 6.5vw, 1.85rem);
    }
    .hero-banner--commerce .hero-banner__heading {
      font-size: clamp(0.9rem, 3.4vw, 1.05rem);
      margin: 0 0 0.75rem;
    }
    .hero-banner--commerce .hero-banner__btn {
      min-width: 7.5rem;
      padding: 0.6rem 1.1rem;
      font-size: 0.68rem;
    }
  }

  @media (min-width: 768px) {
    .hero-banner__image--mobile { display: none; }
    .hero-banner__image--desktop { display: block; }

    .hero-banner--classic .hero-banner__frame {
      max-height: 80vh;
      min-height: 28rem;
    }
    .hero-banner--classic .hero-banner__content {
      min-height: 100%;
      max-width: 34rem;
    }

    .hero-banner--commerce .hero-banner__frame {
      aspect-ratio: 2 / 1;
      min-height: 0;
      max-height: min(72vh, 40rem);
    }
    .hero-banner--commerce .hero-banner__image {
      object-fit: cover;
      object-position: center 28%;
    }
    .hero-banner--commerce .hero-banner__content {
      left: 0;
      right: auto;
      width: min(36%, 22rem);
      padding: 2.5rem 1.5rem 3rem 3rem;
    }
    .hero-banner--commerce .hero-banner__eyebrow {
      font-size: 3.5rem;
    }
    .hero-banner--commerce .hero-banner__heading {
      font-size: 1.45rem;
      margin-block-end: 1.35rem;
    }
    .hero-banner--commerce .hero-banner__btn {
      min-width: 11rem;
      padding: 0.85rem 1.75rem;
      font-size: 0.8rem;
    }

    .hero-banner--overlay .hero-banner__inset {
      width: min(42vw, 28rem);
      top: 54%;
    }
    .hero-banner--overlay .hero-banner__image {
      object-position: center 22%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.hero_banner.name",
  "class": "hero-banner-section",
  "settings": [
    {
      "type": "header",
      "content": "خلفية الـ Hero"
    },
    {
      "type": "paragraph",
      "content": "اختاري صورة من المكتبة لتغيير خلفية الـ Hero. تعمل مع Classic و Commerce و Overlay. إذا تركتِها فارغة تُستخدم الصورة الافتراضية للنمط الحالي."
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "صورة الـ Hero — سطح المكتب"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "صورة الـ Hero — الجوال",
      "info": "اختياري. إن تُركت فارغة تُستخدم صورة سطح المكتب على الجوال."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "لون خلفية الـ Hero",
      "default": "#2A221C",
      "info": "يظهر خلف الصورة أو في الحواف عند القصّ."
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "نص alt للصورة الرئيسية",
      "default": "صورة للمنتجات من الأعلى - أنفاس العنود"
    },
    {
      "type": "header",
      "content": "ملفات افتراضية (Classic)"
    },
    {
      "type": "text",
      "id": "image_desktop_asset",
      "label": "ملف ديسكتوب (assets/)",
      "default": "hero-banner-desktop.jpg"
    },
    {
      "type": "text",
      "id": "image_mobile_asset",
      "label": "ملف جوال (assets/)",
      "default": "hero-banner-mobile.jpg"
    },
    {
      "type": "header",
      "content": "صور Commerce (احتياطي)"
    },
    {
      "type": "paragraph",
      "content": "تُستخدم فقط إذا لم تختاري صورة في «خلفية الـ Hero» أعلاه."
    },
    {
      "type": "image_picker",
      "id": "commerce_image_desktop",
      "label": "Commerce — ديسكتوب"
    },
    {
      "type": "image_picker",
      "id": "commerce_image_mobile",
      "label": "Commerce — جوال"
    },
    {
      "type": "text",
      "id": "commerce_desktop_asset",
      "label": "Commerce ملف ديسكتوب",
      "default": "hero-banner-desktop.jpg"
    },
    {
      "type": "text",
      "id": "commerce_mobile_asset",
      "label": "Commerce ملف جوال",
      "default": "hero-banner-mobile.jpg"
    },
    {
      "type": "header",
      "content": "صور Overlay (احتياطي)"
    },
    {
      "type": "image_picker",
      "id": "overlay_image_desktop",
      "label": "Overlay — ديسكتوب"
    },
    {
      "type": "image_picker",
      "id": "overlay_image_mobile",
      "label": "Overlay — جوال"
    },
    {
      "type": "text",
      "id": "overlay_desktop_asset",
      "label": "Overlay ملف ديسكتوب",
      "default": "hero-overlay-desktop.png"
    },
    {
      "type": "text",
      "id": "overlay_mobile_asset",
      "label": "Overlay ملف جوال",
      "default": "hero-overlay-mobile.png"
    },
    {
      "type": "checkbox",
      "id": "show_overlay_inset",
      "label": "إظهار الصورة المصغّرة وسط Overlay",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "overlay_inset_image",
      "label": "صورة الـ inset"
    },
    {
      "type": "text",
      "id": "overlay_inset_asset",
      "label": "ملف inset (assets/)",
      "default": "hero-overlay-inset.png"
    },
    {
      "type": "text",
      "id": "overlay_inset_alt",
      "label": "نص alt للصورة المصغّرة",
      "default": "تفاصيل طقوس العناية - أنفاس العنود"
    },
    {
      "type": "header",
      "content": "المحتوى"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "سطر فوق العنوان (مثل NEW)",
      "default": "جديد"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "العنوان",
      "default": "عيشي جوج.. وخلج غير عنهم"
    },
    {
      "type": "text",
      "id": "commerce_heading",
      "label": "عنوان Commerce (قصير)",
      "default": "خلطات العنود",
      "info": "يُعرض بدل العنوان الرئيسي عند اختيار أسلوب Commerce"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "النص",
      "default": "تميزي بخلطات ما تتقلد، تعطيج حضورًا قويًا وتلفت الانتباه"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "نص الزر",
      "default": "تسوقي الآن"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "رابط الزر"
    }
  ],
  "presets": [{ "name": "t:sections.hero_banner.name" }]
}
{% endschema %}
