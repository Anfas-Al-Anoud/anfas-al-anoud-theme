<section class="category-icons section-padding" data-animate-section>
  <div class="category-icons__header">
    <div class="category-icons__titles">
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="section-subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
    {% if section.settings.show_view_all %}
      <a href="{{ routes.collections_url }}" class="category-icons__view-all">
        {{ 'sections.featured_collection.view_all' | t }}
        <span aria-hidden="true">&lsaquo;</span>
      </a>
    {% endif %}
  </div>

  {% capture category_slides %}
    {% for block in section.blocks %}
      <li class="carousel__slide category-icons__item" {{ block.shopify_attributes }}>
        <a href="{{ block.settings.link | default: '#' }}" class="category-icons__card">
          {% if block.settings.icon %}
            {% render 'image',
              image: block.settings.icon,
              alt: block.settings.icon_alt,
              fallback_alt: block.settings.title,
              class: 'category-icons__icon',
              width: 240
            %}
          {% elsif block.settings.icon_asset != blank %}
            {% render 'theme-asset-image',
              asset: block.settings.icon_asset,
              alt: block.settings.icon_alt,
              class: 'category-icons__icon',
              width: 240
            %}
          {% else %}
            {% render 'placeholder-svg',
              text: block.settings.icon_alt | default: block.settings.title,
              class: 'category-icons__icon category-icons__placeholder',
              width: 68,
              height: 68
            %}
          {% endif %}
          <span class="category-icons__label">{{ block.settings.title }}</span>
        </a>
      </li>
    {% endfor %}
  {% endcapture %}
  {% render 'carousel',
    slides: category_slides,
    class: 'category-icons__carousel',
    gap: '0.5rem',
    track_tag: 'ul',
    show_nav: true
  %}
</section>

{% stylesheet %}
  .category-icons.section-padding {
    padding-block-start: clamp(1.75rem, 6vw, 3rem);
  }

  .category-icons__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }

  .category-icons__titles {
    flex: 1;
    min-width: 0;
  }

  .category-icons__titles .section-heading,
  .category-icons__titles .section-subheading {
    text-align: start;
    margin-inline: 0;
  }

  @media (max-width: 767px) {
    .category-icons.section-padding {
      padding-block-start: clamp(2.25rem, 8vw, 3.25rem);
    }

    .category-icons__header {
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
    }

    .category-icons__titles .section-heading,
    .category-icons__titles .section-subheading {
      text-align: center;
    }

    .category-icons__view-all {
      align-self: center;
    }
  }

  .category-icons__view-all {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .category-icons__view-all:hover {
    color: var(--color-primary-dark);
  }

  .category-icons__view-all span {
    font-size: 1.125rem;
    line-height: 1;
  }

  .category-icons__carousel {
    margin-block-start: 0.75rem;
  }

  @media (min-width: 768px) {
    .category-icons__carousel {
      margin-block-start: 1.5rem;
    }
  }

  .category-icons__item {
    flex: 0 0 calc(46% - 0.25rem);
    width: calc(46% - 0.25rem);
  }

  @media (min-width: 768px) {
    .category-icons__item {
      flex: 0 0 calc(25% - 0.375rem);
      width: calc(25% - 0.375rem);
    }
  }

  @media (max-width: 767px) {
    .category-icons__carousel.carousel--with-nav {
      padding-inline: calc(var(--page-margin) + 1.65rem);
    }

    .category-icons__carousel .carousel__track-wrap {
      margin-inline: 0;
    }

    .category-icons__carousel .carousel__track {
      padding-inline: 0;
      gap: 0.5rem;
      justify-content: flex-start;
      scroll-padding-inline: 0;
    }

    .category-icons__item {
      flex: 0 0 calc((100% - 0.5rem) / 2);
      width: calc((100% - 0.5rem) / 2);
      scroll-snap-align: center;
    }

    .category-icons__carousel .carousel__nav--prev {
      inset-inline-start: 0.1rem;
    }

    .category-icons__carousel .carousel__nav--next {
      inset-inline-end: 0.1rem;
    }

    .category-icons__header {
      margin-block-end: 0;
    }

    .category-icons__card {
      gap: 0.5rem;
      padding: 0.25rem;
    }

    .category-icons__icon {
      width: clamp(4.25rem, 22vw, 5.25rem);
      height: clamp(4.25rem, 22vw, 5.25rem);
      border-width: 2px;
    }

    .category-icons__label {
      font-size: 0.8125rem;
      line-height: 1.35;
    }
  }

  .category-icons__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 0.75rem;
    padding: 0.5rem 0.25rem;
    text-decoration: none;
    color: var(--color-dark);
    transition: transform var(--transition-base), color var(--transition-base);
    touch-action: manipulation;
  }

  .category-icons__card:hover,
  .category-icons__card:focus-visible {
    transform: translateY(-4px);
    color: var(--color-primary);
  }

  .category-icons__icon {
    width: clamp(5rem, 20vw, 7.5rem);
    height: clamp(5rem, 20vw, 7.5rem);
    object-fit: cover;
    border-radius: 50%;
    border: 3px solid color-mix(in srgb, var(--color-gold) 55%, transparent);
    box-shadow: var(--shadow-soft);
    background: var(--color-cream);
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
  }

  .category-icons__card:hover .category-icons__icon,
  .category-icons__card:focus-visible .category-icons__icon {
    border-color: var(--color-primary);
    box-shadow: 0 12px 28px rgba(122, 31, 43, 0.22);
  }

  .category-icons__placeholder {
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .category-icons__label {
    font-weight: 700;
    text-align: center;
    font-size: 0.95rem;
    line-height: 1.4;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.category_icons.name",
  "class": "category-icons-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "العنوان",
      "default": "تسوّقي حسب احتياجج"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "النص الفرعي",
      "default": "دخون، عطور، عناية، أو بوكسات — اختاري فئتج وادخلي مباشرة."
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "عرض رابط «شوفي الكل»",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "فئة",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "الأيقونة" },
        { "type": "text", "id": "icon_asset", "label": "ملف الأيقونة (assets/)", "info": "صورة سياقية — ليست صورة منتج." },
        {
          "type": "text",
          "id": "icon_alt",
          "label": "نص alt للأيقونة (مطلوب)",
          "default": "أيقونة الفئة",
          "info": "مطلوب عند رفع أيقونة. لا تتركي الحقل فارغًا."
        },
        { "type": "text", "id": "title", "label": "العنوان", "default": "فئة" },
        { "type": "url", "id": "link", "label": "الرابط" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.category_icons.name",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "دخون السنع",
            "icon_alt": "أيقونة دخون السنع",
            "link": "/collections/dokhoon-al-san3"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "عطور الكشخة",
            "icon_alt": "أيقونة عطور الكشخة",
            "link": "/collections/perfumes"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "دلع وعناية",
            "icon_alt": "أيقونة دلع وعناية",
            "link": "/collections/care"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "بوكسات الزين",
            "icon_alt": "أيقونة بوكسات الزين",
            "link": "/collections/gift-boxes"
          }
        }
      ]
    }
  ]
}
{% endschema %}
