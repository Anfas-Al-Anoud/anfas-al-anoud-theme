<article class="page-content section-padding">
  <div class="page-content__inner rte">
    {% if section.settings.show_title %}
      <h1 class="page-content__title">{{ page.title }}</h1>
    {% endif %}
    {{ page.content }}
  </div>
</article>

{% stylesheet %}
  .page-content__inner {
    max-width: 48rem;
    margin-inline: auto;
    padding-inline: var(--page-margin);
    line-height: 1.8;
  }
  .page-content__title {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 700;
    margin-block-end: 1.5rem;
    color: var(--color-dark);
  }
  .page-content__inner h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-block: 1.5rem 0.75rem;
    color: var(--color-gold);
  }
  .page-content__inner ul { padding-inline-start: 1.5rem; margin-block-end: 1rem; }
  .page-content__inner li { margin-block-end: 0.5rem; }
{% endstylesheet %}

{% schema %}
{
  "name": "Page",
  "class": "page-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "عرض العنوان",
      "default": true
    }
  ]
}
{% endschema %}
