<section class="trust-features section-padding" data-animate-section>
  <div class="trust-features__grid">
    {% for block in section.blocks %}
      {% liquid
        assign feature_label = block.settings.label
        if feature_label == blank
          assign feature_parts = block.settings.text | split: ':'
          assign feature_label = feature_parts | first | strip
        endif
        if feature_label == blank
          assign feature_label = block.settings.text | truncate: 32
        endif
      %}
      <div class="trust-features__item" {{ block.shopify_attributes }}>
        <div class="trust-features__icon" aria-hidden="true">
          {% case block.settings.icon %}
            {% when 'delivery' %}
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none"><path d="M1 3h15v13H1V3zm16 8h3l3 3v2h-6v-5zm-1 5a2 2 0 100 4 2 2 0 000-4zM5 21a2 2 0 100-4 2 2 0 000 4z" stroke="currentColor" stroke-width="1.5"/></svg>
            {% when 'payment' %}
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none"><rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M2 10h20" stroke="currentColor" stroke-width="1.5"/></svg>
            {% when 'quality' %}
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none"><path d="M12 2l3 7h7l-5.5 4.5L18 21l-6-4-6 4 1.5-7.5L2 9h7l3-7z" stroke="currentColor" stroke-width="1.5"/></svg>
            {% else %}
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none"><path d="M12 2a5 5 0 015 5c0 3.5-5 9-5 9s-5-5.5-5-9a5 5 0 015-5z" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="7" r="2" stroke="currentColor" stroke-width="1.5"/></svg>
          {% endcase %}
        </div>
        <p class="trust-features__label">{{ feature_label }}</p>
        <p class="trust-features__detail">{{ block.settings.text }}</p>
      </div>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .trust-features__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }

  .trust-features__item {
    text-align: center;
    padding: 1.25rem 0.875rem;
    background: var(--color-white);
    border-radius: var(--style-border-radius-cards);
    box-shadow: var(--shadow-soft);
  }

  .trust-features__icon {
    color: var(--color-gold);
    margin-block-end: 0.625rem;
    display: flex;
    justify-content: center;
  }

  .trust-features__icon svg {
    width: 2rem;
    height: 2rem;
  }

  .trust-features__label {
    font-size: 0.875rem;
    font-weight: 700;
    line-height: 1.45;
    color: var(--color-dark);
    margin: 0;
  }

  .trust-features__detail {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-accent);
    margin: 0.375rem 0 0;
  }

  @media (max-width: 767px) {
    .trust-features.section-padding {
      padding-block: 0.875rem;
    }

    .trust-features__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0.375rem;
    }

    .trust-features__item {
      padding: 0.5rem 0.25rem;
      box-shadow: none;
      background: var(--color-white);
      border-radius: calc(var(--style-border-radius-cards) - 4px);
    }

    .trust-features__icon {
      margin-block-end: 0.25rem;
    }

    .trust-features__icon svg {
      width: 1.125rem;
      height: 1.125rem;
    }

    .trust-features__label {
      font-size: 0.625rem;
      line-height: 1.35;
    }

    .trust-features__detail {
      display: none;
    }
  }

  @media (max-width: 380px) {
    .trust-features__label {
      font-size: 0.5625rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.trust_features.name",
  "class": "trust-features-section",
  "blocks": [
    {
      "type": "feature",
      "name": "ميزة",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "الأيقونة",
          "options": [
            { "value": "delivery", "label": "توصيل" },
            { "value": "payment", "label": "دفع" },
            { "value": "quality", "label": "جودة" },
            { "value": "support", "label": "دعم" }
          ],
          "default": "delivery"
        },
        {
          "type": "text",
          "id": "label",
          "label": "عنوان مختصر (للجوال)",
          "info": "يظهر في صف واحد على الجوال. إن تُرك فارغًا يُستخدم الجزء قبل النقطتين من النص."
        },
        { "type": "textarea", "id": "text", "label": "النص الكامل" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.trust_features.name",
      "blocks": [
        { "type": "feature", "settings": { "icon": "delivery", "label": "توصيل سريع", "text": "لحد باب دارج: وين ما كنتي في الإمارات، طلبج يوصل بأسرع وقت." } },
        { "type": "feature", "settings": { "icon": "payment", "label": "دفع آمن", "text": "دفعج بأمان وراحة: طرق دفع متعددة ومضمونة." } },
        { "type": "feature", "settings": { "icon": "quality", "label": "جودة أصلية", "text": "جودة تبيّض الويه: منتجاتي أصلية 100%." } },
        { "type": "feature", "settings": { "icon": "support", "label": "دعم مباشر", "text": "حاضرة للطيبين: دايمًا موجودة عشان أخدمج." } }
      ]
    }
  ]
}
{% endschema %}
