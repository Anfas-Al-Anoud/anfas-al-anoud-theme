{%- comment -%}
  Compact product view rendered on demand via product.url?section_id=quick-view.
  The store-enhancements.js quick-view module injects [data-quickview] into the
  shared modal and binds variant selection + add-to-cart.
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign has_options = true
  if product.has_only_default_variant
    assign has_options = false
  endif
  assign low_threshold = settings.low_stock_threshold | default: 10
-%}

<div class="quickview" data-quickview data-currency="{{ cart.currency.iso_code | default: shop.currency }}" data-currency-label="{{ 'general.currency' | t }}" data-threshold="{{ low_threshold }}" data-low-template="{{ 'products.low_stock' | t: count: '__N__' }}">
  <div class="quickview__media">
    {%- if product.featured_image -%}
      {% render 'image',
        image: product.featured_image,
        fallback_alt: product.title,
        width: 700
      %}
    {%- endif -%}
  </div>

  <div class="quickview__info">
    {% if product.vendor != blank %}
      <p class="quickview__vendor">{{ product.vendor }}</p>
    {% endif %}
    <h2 class="quickview__title">{% render 'tanween', text: product.title %}</h2>

    <div class="quickview__price">
      <s data-qv-compare {% unless current_variant.compare_at_price > current_variant.price %}hidden{% endunless %}>{{ current_variant.compare_at_price | money_without_currency }} {{ 'general.currency' | t }}</s>
      <span class="quickview__current" data-qv-price>{{ current_variant.price | money_without_currency }} {{ 'general.currency' | t }}</span>
    </div>

    <p class="quickview__low-stock" data-qv-low-stock hidden></p>

    <form data-qv-form class="quickview__form">
      {% if has_options %}
        {% for option in product.options_with_values %}
          <div class="quickview__option" data-qv-option-index="{{ forloop.index0 }}">
            <span class="quickview__option-name">{{ option.name }}</span>
            <div class="quickview__swatches">
              {% for value in option.values %}
                <button
                  type="button"
                  class="quickview__swatch {% if option.selected_value == value %}is-active{% endif %}"
                  data-qv-option-value="{{ value | escape }}"
                >{{ value }}</button>
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      {% endif %}

      <input type="hidden" data-qv-variant-id value="{{ current_variant.id }}">

      <div class="quickview__buy">
        <div class="quickview__qty">
          <button type="button" data-qv-qty-step="-1" aria-label="{{ 'general.cart.decrease' | t }}">&minus;</button>
          <input type="number" data-qv-qty value="1" min="1" inputmode="numeric" aria-label="{{ 'general.product.quantity' | t }}">
          <button type="button" data-qv-qty-step="1" aria-label="{{ 'general.cart.increase' | t }}">+</button>
        </div>
        <button
          type="submit"
          class="btn quickview__add"
          data-qv-add
          data-add-text="{{ 'general.product.add_to_cart' | t }}"
          data-soldout-text="{{ 'general.product.sold_out' | t }}"
          data-unavailable-text="{{ 'general.product.unavailable' | t }}"
          {% unless current_variant.available %}disabled{% endunless %}
        >
          <span data-qv-add-label>{% if current_variant.available %}{{ 'general.product.add_to_cart' | t }}{% else %}{{ 'general.product.sold_out' | t }}{% endif %}</span>
        </button>
      </div>
      <p class="quickview__error" data-qv-error hidden role="alert"></p>
    </form>

    <a class="quickview__details" href="{{ product.url }}">{{ 'products.view_details' | t }}</a>
  </div>

  <script type="application/json" data-qv-json>
    [
      {%- for variant in product.variants -%}
        {
          "id": {{ variant.id }},
          "options": {{ variant.options | json }},
          "price": {{ variant.price }},
          "compare_at_price": {{ variant.compare_at_price | default: 0 }},
          "available": {{ variant.available }},
          "inventory_management": {{ variant.inventory_management | json }},
          "inventory_quantity": {{ variant.inventory_quantity | default: 0 }}
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  </script>
</div>

{% stylesheet %}
  .quickview { display: grid; gap: 1.5rem; }
  @media (min-width: 700px) { .quickview { grid-template-columns: 1fr 1fr; } }
  .quickview__media img { width: 100%; border-radius: var(--style-border-radius-cards); aspect-ratio: 1; object-fit: cover; }
  .quickview__vendor { color: var(--color-accent); font-weight: 600; margin-block-end: 0.25rem; }
  .quickview__title { font-size: 1.4rem; margin-block-end: 0.5rem; }
  .quickview__price { display: flex; gap: 0.6rem; align-items: baseline; margin-block-end: 0.5rem; font-size: 1.2rem; }
  .quickview__price s { color: #b0a99f; font-size: 0.9rem; }
  .quickview__current { color: var(--color-primary); font-weight: 700; }
  .quickview__low-stock { color: #c0392b; font-weight: 700; font-size: 0.9rem; margin-block-end: 0.75rem; }
  .quickview__low-stock[hidden] { display: none; }
  .quickview__option { margin-block-end: 1rem; }
  .quickview__option-name { display: block; font-weight: 600; margin-block-end: 0.4rem; }
  .quickview__swatches { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .quickview__swatch { padding: 0.45rem 0.95rem; border: 1.5px solid var(--color-sand); border-radius: 999px; background: var(--color-white); cursor: pointer; font: inherit; transition: all var(--transition-base); }
  .quickview__swatch.is-active { border-color: var(--color-primary); background: var(--color-primary); color: var(--color-primary-foreground); }
  .quickview__buy { display: flex; gap: 0.6rem; margin-block-end: 0.5rem; }
  .quickview__qty { display: inline-flex; align-items: center; border: 1.5px solid var(--color-sand); border-radius: 999px; padding: 0 0.3rem; }
  .quickview__qty button { background: none; border: none; font-size: 1.1rem; width: 2rem; height: 2.5rem; cursor: pointer; color: var(--color-dark); }
  .quickview__qty input { width: 2.5rem; text-align: center; border: none; background: none; font: inherit; -moz-appearance: textfield; }
  .quickview__qty input::-webkit-outer-spin-button,
  .quickview__qty input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  .quickview__add { flex: 1; }
  .quickview__add.is-loading { opacity: 0.7; pointer-events: none; }
  .quickview__error { color: #c0392b; font-size: 0.9rem; }
  .quickview__error[hidden] { display: none; }
  .quickview__details { display: inline-block; margin-block-start: 0.25rem; color: var(--color-primary); font-weight: 600; text-decoration: none; }
{% endstylesheet %}

{% schema %}
{
  "name": "Quick view",
  "settings": []
}
{% endschema %}
