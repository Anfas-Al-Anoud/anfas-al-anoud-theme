<section class="testimonials section-padding" data-animate-section>
  <h2 class="section-heading">{{ section.settings.heading }}</h2>
  <p class="section-subheading">{{ section.settings.subheading }}</p>

  {% capture review_slides %}
    {% assign review_total = section.settings.review_count | default: 181 %}
    {% for i in (1..review_total) %}
      {% liquid
        if i < 10
          assign review_asset = 'reviews/review-0' | append: i | append: '.jpg'
        else
          assign review_asset = 'reviews/review-' | append: i | append: '.jpg'
        endif
      %}
      <figure class="carousel__slide testimonials__slide" data-review-slide>
        <div class="testimonials__phone">
          {% render 'theme-asset-image',
            asset: review_asset,
            alt: section.settings.image_alt,
            class: 'testimonials__shot',
            width: 400,
            loading: 'lazy'
          %}
        </div>
      </figure>
    {% endfor %}
  {% endcapture %}

  {% render 'carousel', slides: review_slides, class: 'testimonials__carousel', gap: '0.5rem' %}
</section>

{% stylesheet %}
  .testimonials__carousel {
    margin-block-start: 0.25rem;
  }

  .testimonials__slide {
    flex: 0 0 calc(72% - 0.25rem);
    width: calc(72% - 0.25rem);
    margin: 0;
  }

  @media (min-width: 768px) {
    .testimonials__slide {
      flex: 0 0 calc(28% - 0.375rem);
      width: calc(28% - 0.375rem);
    }
  }

  .testimonials__phone {
    background: var(--color-white);
    border-radius: 1.25rem;
    padding: 0.5rem;
    box-shadow: 0 10px 28px rgba(61, 43, 31, 0.12);
    border: 1px solid color-mix(in srgb, var(--color-sand) 70%, transparent);
  }

  .testimonials__shot {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0.875rem;
    object-fit: cover;
    aspect-ratio: 9 / 16;
    object-position: top;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.testimonials.name",
  "class": "testimonials-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "العنوان", "default": "شو قالوا عنا الحبايب؟" },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "النص",
      "default": "تصفحي سوالف وتجارب البنات اللي وثقوا فينا."
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "نص alt للقطات",
      "default": "رأي عميلة من متجر أنفاس العنود"
    },
    {
      "type": "range",
      "id": "review_count",
      "label": "عدد لقطات الشاشة",
      "min": 4,
      "max": 181,
      "step": 1,
      "default": 181
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "رأي (نصي — اختياري)",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "النص" },
        { "type": "text", "id": "author", "label": "الاسم" }
      ]
    },
    {
      "type": "review_screenshot",
      "name": "لقطة شاشة",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "الصورة" },
        { "type": "text", "id": "image_asset", "label": "ملف الصورة (assets/)" },
        { "type": "text", "id": "image_alt", "label": "نص alt", "default": "رأي عميلة" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.testimonials.name"
    }
  ]
}
{% endschema %}
