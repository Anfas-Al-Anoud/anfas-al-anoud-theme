{% doc %}
  Renders variant option swatches (color/image) or text pills.

  @param {object} option - Product option with values
  @param {object} product - Product object
  @param {number} option_index - Zero-based option index
  @param {string} [attr_prefix] - Data attribute prefix (e.g. 'qv-')
  @param {string} [swatch_class] - Base CSS class for swatch buttons
{% enddoc %}

{%- liquid
  assign prefix = attr_prefix | default: ''
  assign base_class = swatch_class | default: 'variant-swatch'
  assign option_name_down = option.name | downcase
  assign is_color_option = false
  if option_name_down contains 'color' or option_name_down contains 'colour' or option_name_down contains 'لون'
    assign is_color_option = true
  endif
-%}

<div class="{{ base_class }}s" data-{{ prefix }}option-swatches>
  {%- for value in option.values -%}
    {%- liquid
      assign swatch_image = value.swatch.image
      assign swatch_color = value.swatch.color
      assign variant_image = blank
      unless swatch_image != blank or swatch_color != blank
        for variant in product.variants
          if variant.options[option_index] == value
            if variant.featured_media
              assign variant_image = variant.featured_media.preview_image | default: variant.featured_media
              break
            endif
          endif
        endfor
      endunless
      assign use_image = false
      if swatch_image != blank or variant_image != blank
        assign use_image = true
      endif
      assign use_color = false
      if swatch_color != blank and is_color_option
        assign use_color = true
      endif
    -%}
    <button
      type="button"
      class="{{ base_class }} {% if option.selected_value == value %}is-active{% endif %}{% if use_image %} {{ base_class }}--image{% elsif use_color %} {{ base_class }}--color{% else %} {{ base_class }}--pill{% endif %}"
      data-{{ prefix }}option-value="{{ value | escape }}"
      {% if use_color %}style="--swatch-color: {{ swatch_color }};"{% endif %}
      aria-label="{{ value | escape }}"
      title="{{ value | escape }}"
    >
      {%- if use_image -%}
        {%- if swatch_image != blank -%}
          {{ swatch_image | image_url: width: 80 | image_tag: loading: 'lazy', widths: '40, 80', alt: value }}
        {%- else -%}
          {% render 'image', image: variant_image, alt: value, width: 80 %}
        {%- endif -%}
      {%- elsif use_color -%}
        <span class="{{ base_class }}__color" aria-hidden="true"></span>
      {%- else -%}
        {{ value }}
      {%- endif -%}
    </button>
  {%- endfor -%}
</div>

{% stylesheet %}
  .variant-swatchs,
  .product-page__swatches,
  .quickview__swatches {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .variant-swatch {
    padding: 0;
    border: 2px solid var(--color-sand);
    border-radius: 999px;
    background: var(--color-white);
    cursor: pointer;
    font: inherit;
    transition: border-color var(--transition-base), box-shadow var(--transition-base), background var(--transition-base), color var(--transition-base);
    min-width: 2.5rem;
    min-height: 2.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .variant-swatch--pill {
    padding: 0.55rem 1.1rem;
  }
  .variant-swatch--image {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    overflow: hidden;
    padding: 0;
  }
  .variant-swatch--image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .variant-swatch--color {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    padding: 0.2rem;
  }
  .variant-swatch__color {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: var(--swatch-color, var(--color-sand));
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.08);
  }
  .variant-swatch.is-active {
    border-color: var(--color-gold);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-gold) 35%, transparent);
  }
  .variant-swatch--pill.is-active {
    background: var(--color-gold);
    color: var(--color-white);
    border-color: var(--color-gold);
  }
{% endstylesheet %}
