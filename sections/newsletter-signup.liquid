<section class="newsletter-signup section-padding" data-animate-section>
  <div class="newsletter-signup__inner">
    <div class="newsletter-signup__copy">
      <span class="newsletter-signup__icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
          <path d="M3 6.75A1.75 1.75 0 0 1 4.75 5h14.5A1.75 1.75 0 0 1 21 6.75v10.5A1.75 1.75 0 0 1 19.25 19H4.75A1.75 1.75 0 0 1 3 17.25V6.75Z" stroke="currentColor" stroke-width="1.5"/>
          <path d="m4 7 7.05 5.18a1.6 1.6 0 0 0 1.9 0L20 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </span>
      <div>
        <h2 class="section-heading newsletter-signup__heading">{% render 'tanween', text: section.settings.heading %}</h2>
        {% if section.settings.text != blank %}
          <p class="newsletter-signup__text">{% render 'tanween', text: section.settings.text %}</p>
        {% endif %}
      </div>

      <div class="newsletter-signup__social" aria-label="{{ 'settings.social.name' | t }}">
        {% if settings.social_instagram != blank %}
          <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            {{ 'icon-instagram.svg' | inline_asset_content }}
          </a>
        {% endif %}
        {% if settings.social_tiktok != blank %}
          <a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
            {{ 'icon-tiktok.svg' | inline_asset_content }}
          </a>
        {% endif %}
        {% if settings.social_snapchat != blank %}
          <a href="{{ settings.social_snapchat }}" target="_blank" rel="noopener noreferrer" aria-label="Snapchat">
            {{ 'icon-snapchat.svg' | inline_asset_content }}
          </a>
        {% endif %}
      </div>
    </div>

    {% form 'customer', class: 'newsletter-signup__form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <label class="newsletter-signup__label" for="NewsletterEmail-{{ section.id }}">{{ section.settings.email_label }}</label>
      <div class="newsletter-signup__fields">
        <input
          id="NewsletterEmail-{{ section.id }}"
          type="email"
          name="contact[email]"
          placeholder="{{ section.settings.email_placeholder }}"
          required
          autocomplete="email"
        >
        <button type="submit" class="btn">{{ section.settings.button_label }}</button>
      </div>
      {% if form.posted_successfully? %}
        <p class="newsletter-signup__success" role="status">{{ 'sections.newsletter_signup.success' | t }}</p>
      {% endif %}
      {% if form.errors %}
        <p class="newsletter-signup__error" role="alert">{{ form.errors | default_errors }}</p>
      {% endif %}
    {% endform %}
  </div>
</section>

{% stylesheet %}
  .newsletter-signup__inner {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    max-width: var(--page-width);
    margin-inline: auto;
    display: grid;
    gap: 1.5rem;
    align-items: center;
    color: var(--color-white);
    background:
      radial-gradient(circle at 15% 0%, color-mix(in srgb, var(--color-gold) 22%, transparent), transparent 38%),
      var(--color-primary-dark);
    border: 1px solid color-mix(in srgb, var(--color-gold) 62%, transparent);
    border-radius: var(--style-border-radius-cards);
    padding: clamp(1.5rem, 4vw, 3rem);
    box-shadow: 0 18px 50px color-mix(in srgb, var(--color-dark) 18%, transparent);
  }

  .newsletter-signup__inner::after {
    content: '';
    position: absolute;
    z-index: -1;
    width: 14rem;
    aspect-ratio: 1;
    inset-block-end: -8rem;
    inset-inline-end: -4rem;
    border: 1px solid color-mix(in srgb, var(--color-gold) 28%, transparent);
    border-radius: 50%;
  }

  .newsletter-signup__copy {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.85rem 1rem;
    align-items: start;
  }

  .newsletter-signup__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    color: var(--color-dark);
    background: var(--color-gold);
    box-shadow: 0 8px 24px color-mix(in srgb, var(--color-dark) 20%, transparent);
  }

  .newsletter-signup__heading {
    color: var(--color-white);
    text-align: start;
    margin: 0 0 0.45rem;
  }

  .newsletter-signup__heading::after {
    margin-inline: 0;
    background: var(--color-gold);
  }

  .newsletter-signup__text {
    color: color-mix(in srgb, var(--color-white) 82%, transparent);
    text-align: start;
    margin: 0;
    max-width: 34rem;
    line-height: 1.75;
  }

  .newsletter-signup__social {
    grid-column: 2;
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-block-start: 0.25rem;
  }

  .newsletter-signup__social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid color-mix(in srgb, var(--color-gold) 55%, transparent);
    border-radius: 50%;
    color: var(--color-white);
    transition: color 180ms ease, background 180ms ease, transform 180ms ease;
  }

  .newsletter-signup__social a:hover,
  .newsletter-signup__social a:focus-visible {
    color: var(--color-dark);
    background: var(--color-gold);
    transform: translateY(-2px);
  }

  .newsletter-signup__social svg {
    width: 1.2rem;
    height: 1.2rem;
  }

  @media (min-width: 768px) {
    .newsletter-signup__inner {
      grid-template-columns: minmax(0, 1.1fr) minmax(22rem, 0.9fr);
      gap: clamp(2rem, 5vw, 5rem);
    }
  }

  .newsletter-signup__form {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    min-width: 0;
    padding: 1rem;
    border: 1px solid color-mix(in srgb, var(--color-white) 18%, transparent);
    border-radius: calc(var(--style-border-radius-cards) * 0.75);
    background: color-mix(in srgb, var(--color-white) 9%, transparent);
    backdrop-filter: blur(8px);
  }

  .newsletter-signup__label {
    color: var(--color-white);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .newsletter-signup__fields {
    display: flex;
    gap: 0.6rem;
  }

  .newsletter-signup__form input {
    flex: 1;
    min-width: 0;
    min-height: 3rem;
    padding: 0.75rem 1rem;
    border: 1.5px solid color-mix(in srgb, var(--color-gold) 48%, transparent);
    border-radius: var(--style-border-radius-inputs);
    color: var(--color-dark);
    background: var(--color-white);
    font: inherit;
  }

  .newsletter-signup__form input:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }

  .newsletter-signup__form .btn {
    min-width: 7.5rem;
    min-height: 3rem;
    background: var(--color-gold);
    color: var(--color-dark);
    box-shadow: none;
  }

  .newsletter-signup__success { color: var(--color-white); font-weight: 700; margin: 0; font-size: 0.9rem; }
  .newsletter-signup__error { color: #ffd9d9; margin: 0; font-size: 0.9rem; }

  @media (max-width: 767px) {
    .newsletter-signup__inner {
      margin-inline: var(--page-margin);
    }

    .newsletter-signup__copy {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .newsletter-signup__icon {
      justify-self: center;
    }

    .newsletter-signup__heading,
    .newsletter-signup__text {
      text-align: center;
    }

    .newsletter-signup__heading::after {
      margin-inline: auto;
    }

    .newsletter-signup__social {
      grid-column: 1;
      justify-content: center;
    }

    .newsletter-signup__fields {
      flex-direction: column;
    }

    .newsletter-signup__form .btn {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .newsletter-signup,
    .newsletter-signup__social a {
      animation: none !important;
      transition: none !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.newsletter_signup.name",
  "class": "newsletter-signup-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "خلينا على تواصل"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "t:labels.text",
      "default": "سجّلي إيميلج وكوني أول وحدة تعرفين العروض الحلوة ونصايح العنود للسنع."
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "t:sections.newsletter_signup.email_label",
      "default": "البريد الإلكتروني"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "t:sections.newsletter_signup.email_placeholder",
      "default": "حطي إيميلج هنيه"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:labels.button_label",
      "default": "اشتركي"
    }
  ],
  "presets": [{ "name": "t:sections.newsletter_signup.name" }]
}
{% endschema %}
