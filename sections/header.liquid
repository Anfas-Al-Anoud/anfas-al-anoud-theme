{%- liquid
  assign header_style = settings.header_style | default: 'classic'
-%}
{% capture brand_display %}{% render 'brand-name' %}{% endcapture %}
<header class="site-header full-width site-header--{{ header_style }}" data-header>
  <div class="site-header__inner">
    <button class="site-header__menu-toggle" type="button" aria-label="{{ 'general.accessibility.menu' | t }}" aria-expanded="false" data-menu-toggle>
      <svg class="site-header__burger site-header__burger--3" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
      <svg class="site-header__burger site-header__burger--2" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M5 9h14M5 15h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
    </button>

    <a href="{{ routes.root_url }}" class="site-header__logo">
      {% if settings.logo != blank %}
        {% liquid
          assign logo_render_width = settings.logo_width | times: 2 | at_most: 440
        %}
        {{
          settings.logo
          | image_url: width: logo_render_width
          | image_tag:
            alt: brand_display,
            width: settings.logo_width,
            loading: 'eager'
        }}
      {% else %}
        <img
          src="{{ 'anfas-alanoud-logo.png' | asset_url }}"
          alt="{{ brand_display | escape }}"
          width="{{ settings.logo_width }}"
          height="{{ settings.logo_width }}"
          loading="eager"
        >
      {% endif %}
    </a>

    <nav class="site-header__nav" id="MobileNav" data-mobile-nav aria-label="القائمة الرئيسية">
      {% for link in section.settings.menu.links %}
        {%- if link.links != blank -%}
          <div class="site-header__nav-group">
            <span class="site-header__nav-parent">{% render 'tanween', text: link.title %}</span>
            <div class="site-header__nav-children">
              {%- for child in link.links -%}
                <a href="{{ child.url }}" class="site-header__nav-link site-header__nav-link--child">{% render 'tanween', text: child.title %}</a>
              {%- endfor -%}
            </div>
          </div>
        {%- else -%}
          <a href="{{ link.url }}" class="site-header__nav-link">{% render 'tanween', text: link.title %}</a>
        {%- endif -%}
      {% endfor %}
      {%- if settings.nav_promo_enabled and settings.nav_promo_text != blank -%}
        <a href="{{ settings.nav_promo_link | default: '/collections/offers' }}" class="site-header__promo">
          {% render 'tanween', text: settings.nav_promo_text %}
        </a>
      {%- endif -%}
    </nav>

    <div class="site-header__actions">
      {%- comment -%} Commerce (IMG_7838): language label before search + bag {%- endcomment -%}
      <a href="{{ routes.root_url }}" class="site-header__lang" hreflang="en" lang="en">EN</a>

      <a href="{{ routes.search_url }}" class="site-header__icon site-header__search-trigger" aria-label="{{ 'general.search.title' | t }}">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8"/>
          <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </a>
      <form action="{{ routes.search_url }}" method="get" class="site-header__search" role="search" data-predictive-search>
        <input
          type="search"
          name="q"
          placeholder="{{ 'general.search.placeholder' | t }}"
          aria-label="{{ 'general.search.title' | t }}"
          autocomplete="off"
          data-predictive-input
          aria-expanded="false"
          aria-controls="PredictiveResults"
        >
        <div class="site-header__predictive" id="PredictiveResults" data-predictive-results role="listbox" hidden></div>
      </form>
      {% if shop.customer_accounts_enabled %}
        <a href="{{ routes.account_url }}" class="site-header__icon site-header__account" aria-label="حسابج">
          {{ 'icon-account.svg' | inline_asset_content }}
        </a>
      {% endif %}
      <button type="button" class="site-header__icon site-header__wishlist" data-wishlist-open aria-label="المفضلة">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" stroke="currentColor" stroke-width="1.6"/></svg>
        <span class="site-header__cart-count" data-wishlist-count hidden>0</span>
      </button>
      <button type="button" class="site-header__icon site-header__cart-trigger" data-cart-open aria-label="{{ 'general.cart.title' | t }}">
        <svg class="site-header__bag" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M6 8h12l-1 11H7L6 8Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
          <path d="M9 8V7a3 3 0 0 1 6 0v1" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
          <path class="site-header__bag-heart" d="M12 16.2l-.55-.5C9.4 14.05 8 13 8 11.75 8 10.7 8.85 10 9.85 10c.56 0 1.1.26 1.45.7.35-.44.89-.7 1.45-.7 1 0 1.85.7 1.85 1.75 0 1.25-1.4 2.3-3.45 3.95L12 16.2Z" fill="currentColor"/>
        </svg>
        <span class="site-header__cart-count" data-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
      </button>
    </div>
  </div>
</header>

{% stylesheet %}
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--color-white) 82%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-block-end: 1px solid color-mix(in srgb, var(--color-gold) 30%, transparent);
    box-shadow: var(--shadow-soft);
  }
  .site-header__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    min-height: var(--header-height);
    padding-inline: var(--page-margin);
    max-width: var(--page-width);
    margin-inline: auto;
  }
  .site-header__logo {
    justify-self: start;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    text-decoration: none;
    color: var(--color-dark);
  }
  .site-header__nav {
    display: none;
    flex-direction: column;
    position: fixed;
    inset: 0;
    top: var(--header-height);
    background: var(--color-white);
    padding: 1.5rem;
    gap: 1rem;
    z-index: 99;
  }
  .site-header__nav.is-open { display: flex; }
  .site-header__nav-link {
    text-decoration: none;
    color: var(--color-dark);
    font-weight: 600;
    background: none;
    border: none;
    font: inherit;
    cursor: pointer;
    text-align: start;
    padding: 0.5rem 0;
  }
  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    justify-self: end;
  }
  .site-header__search { display: none; position: relative; }
  .site-header__search input {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-sand);
    border-radius: var(--style-border-radius-inputs);
    min-width: 12rem;
  }
  .site-header__search input:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 1px; }
  .site-header__predictive {
    position: absolute;
    top: calc(100% + 0.5rem);
    inset-inline: 0;
    width: min(24rem, 90vw);
    inset-inline-end: 0;
    background: var(--color-white);
    border: 1px solid var(--color-sand);
    border-radius: var(--style-border-radius-cards);
    box-shadow: 0 16px 40px rgba(61, 43, 31, 0.16);
    max-height: min(70vh, 32rem);
    overflow-y: auto;
    z-index: 120;
  }
  .site-header__predictive[hidden] { display: none; }
  .site-header__icon {
    position: relative;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-dark);
    padding: 0.35rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    min-height: 2.5rem;
    transition: color var(--transition-base);
  }
  .site-header__icon:hover { color: var(--color-primary); }
  .site-header__nav-link:hover { color: var(--color-primary); }
  .site-header__nav-group { display: flex; flex-direction: column; gap: 0.35rem; }
  .site-header__nav-parent {
    font-weight: 700;
    color: var(--color-primary);
    font-size: 0.9rem;
  }
  .site-header__nav-children { display: flex; flex-direction: column; gap: 0.15rem; padding-inline-start: 0.5rem; }
  .site-header__nav-link--child { font-size: 0.92rem; font-weight: 500; }
  .site-header__promo {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.9rem;
    border-radius: 999px;
    background: var(--color-gold);
    color: var(--color-white);
    font-weight: 700;
    font-size: 0.85rem;
    text-decoration: none;
    transition: background var(--transition-base);
  }
  .site-header__promo:hover { background: var(--color-primary); color: var(--color-primary-foreground); }
  .site-header__icon svg { width: 1.35rem; height: 1.35rem; }
  .site-header__bag-heart { color: var(--color-primary); }
  .site-header__cart-count {
    position: absolute;
    top: 2px;
    inset-inline-start: 2px;
    background: var(--color-primary);
    color: var(--color-primary-foreground);
    font-size: 0.65rem;
    font-weight: 700;
    min-width: 1.125rem;
    height: 1.125rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .site-header__search-trigger { display: none; text-decoration: none; color: inherit; }
  .site-header__lang {
    display: none;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
    padding: 0.25rem 0.15rem;
    letter-spacing: 0.02em;
  }
  .site-header__menu-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-dark);
    justify-self: start;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.75rem;
    min-height: 2.75rem;
    padding: 0;
  }
  .site-header__burger--2 { display: none; }

  /* —— Classic mobile: logo only (bottom nav handles the rest) —— */
  @media (max-width: 767px) {
    .header-style--classic .site-header__actions,
    .header-style--classic .site-header__menu-toggle,
    .header-style--classic .site-header__search-trigger,
    .header-style--classic .site-header__lang {
      display: none;
    }
    .header-style--classic .site-header__inner {
      min-height: var(--header-height);
      padding-block: 0.2rem;
    }
    .header-style--classic .site-header__logo {
      justify-self: center;
      grid-column: 1 / -1;
    }
    .header-style--classic .site-header__logo img {
      max-height: clamp(4.25rem, 20vw, 5.5rem);
      width: auto;
    }

    /* —— Commerce (IMG_7838): [menu 2-line] [logo] [EN + search + bag] —— */
    .header-style--commerce .site-header {
      background: #fff;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      border: none;
      border-block-end: 1px solid #e8e8e8;
      box-shadow: none;
    }
    .header-style--commerce .site-header__inner {
      display: grid;
      grid-template-columns: 2.5rem 1fr auto;
      grid-template-areas: "menu logo actions";
      gap: 0.15rem;
      min-height: 3.25rem;
      padding-block: 0.4rem;
      padding-inline: 0.65rem;
      max-width: none;
    }
    .header-style--commerce .site-header__menu-toggle {
      display: inline-flex;
      grid-area: menu;
      justify-self: start;
      color: var(--color-primary);
    }
    .header-style--commerce .site-header__burger--3 { display: none; }
    .header-style--commerce .site-header__burger--2 { display: block; }
    .header-style--commerce .site-header__logo {
      grid-area: logo;
      justify-self: center;
    }
    .header-style--commerce .site-header__logo img {
      max-height: 2.35rem;
      width: auto;
    }
    .header-style--commerce .site-header__nav { display: none !important; }
    .header-style--commerce .site-header__actions {
      display: flex;
      grid-area: actions;
      gap: 0.05rem;
      justify-self: end;
      align-items: center;
      color: var(--color-primary);
    }
    .header-style--commerce .site-header__lang {
      display: inline-flex;
      margin-inline-end: 0.15rem;
      color: var(--color-primary);
      font-size: 0.78rem;
    }
    .header-style--commerce .site-header__search-trigger {
      display: inline-flex;
      color: var(--color-primary);
    }
    .header-style--commerce .site-header__cart-trigger {
      color: var(--color-primary);
    }
    .header-style--commerce .site-header__bag-heart {
      color: var(--color-primary);
    }
    .header-style--commerce .site-header__icon {
      color: var(--color-primary);
    }
    .header-style--commerce .site-header__search,
    .header-style--commerce .site-header__account,
    .header-style--commerce .site-header__wishlist,
    .header-style--commerce .site-header__promo {
      display: none !important;
    }

    /* —— Overlay (IMG_7839): [logo] …… [bag + menu 3-line] —— */
    .header-style--overlay .site-header {
      background: transparent;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      border: none;
      box-shadow: none;
    }
    .header-style--overlay .site-header__inner {
      display: flex;
      align-items: center;
      gap: 0.25rem;
      min-height: 3.35rem;
      padding-block: 0.55rem;
      padding-inline: 1rem;
      max-width: none;
    }
    .header-style--overlay .site-header__logo {
      order: 1;
      margin-inline-end: auto;
      justify-self: start;
    }
    .header-style--overlay .site-header__logo img {
      max-height: 2.35rem;
      width: auto;
    }
    .header-style--overlay .site-header__nav { display: none !important; }
    .header-style--overlay .site-header__actions {
      display: flex;
      order: 2;
      gap: 0.05rem;
      color: var(--color-gold);
    }
    .header-style--overlay .site-header__menu-toggle {
      display: inline-flex;
      order: 3;
      color: var(--color-gold);
      min-width: 2.5rem;
    }
    .header-style--overlay .site-header__burger--2 { display: none; }
    .header-style--overlay .site-header__burger--3 { display: block; }
    .header-style--overlay .site-header__cart-trigger {
      color: var(--color-gold);
    }
    .header-style--overlay .site-header__bag-heart {
      color: var(--color-gold);
    }
    .header-style--overlay .site-header__lang,
    .header-style--overlay .site-header__search,
    .header-style--overlay .site-header__search-trigger,
    .header-style--overlay .site-header__account,
    .header-style--overlay .site-header__wishlist,
    .header-style--overlay .site-header__promo {
      display: none !important;
    }
  }

  @media (min-width: 768px) {
    .site-header__menu-toggle { display: none; }
    .site-header__search-trigger { display: none; }
    .site-header__lang { display: none; }
    .site-header__nav {
      display: flex;
      position: static;
      flex-direction: row;
      flex-wrap: nowrap;
      justify-content: center;
      padding: 0;
      gap: 0.65rem;
      align-items: center;
      min-width: 0;
    }
    .site-header__nav-link,
    .site-header__nav-parent {
      white-space: nowrap;
      flex-shrink: 0;
      padding: 0;
      font-size: 0.84rem;
    }
    .site-header__nav-group {
      position: relative;
      flex-direction: row;
      flex-shrink: 0;
    }
    .site-header__nav-group:hover .site-header__nav-children,
    .site-header__nav-group:focus-within .site-header__nav-children {
      display: flex;
    }
    .site-header__nav-children {
      display: none;
      position: absolute;
      top: 100%;
      inset-inline-start: 0;
      min-width: 11rem;
      padding: 0.65rem;
      background: var(--color-white);
      border: 1px solid var(--color-sand);
      border-radius: var(--style-border-radius-cards);
      box-shadow: var(--shadow-soft);
      z-index: 120;
    }
    .site-header__nav-parent { cursor: default; }
    .site-header__search { display: block; }
    .site-header__search input { min-width: 9.5rem; }
    .site-header__promo {
      flex-shrink: 0;
      white-space: nowrap;
      padding: 0.35rem 0.75rem;
      font-size: 0.78rem;
    }

    .header-style--commerce .site-header {
      background: #fff;
      backdrop-filter: none;
      border: none;
      border-block-end: 1px solid #e8e8e8;
      box-shadow: none;
    }
    .header-style--overlay.template-index .site-header {
      background: transparent;
      backdrop-filter: none;
      border: none;
      box-shadow: none;
    }
  }

  @media (max-width: 767px) {
    .site-header__promo { display: none; }
  }

  /* Overlay: announcement stays in flow; header floats over the hero */
  .header-style--overlay.template-index .site-header-section {
    position: relative;
    z-index: 50;
    height: 0;
    overflow: visible;
  }
  .header-style--overlay.template-index .site-header {
    position: absolute;
    inset-inline: 0;
    top: 0;
    background: transparent;
    border: none;
    box-shadow: none;
  }
  .header-style--overlay:not(.template-index) .site-header {
    background: #fff;
    backdrop-filter: none;
    border-block-end: 1px solid var(--color-sand);
    box-shadow: none;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "class": "site-header-section",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
