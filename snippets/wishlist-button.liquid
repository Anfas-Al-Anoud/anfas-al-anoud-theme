{% doc %}
  Wishlist toggle button for a product.
  @param {object} product - Product object
{% enddoc %}

<button
  type="button"
  class="wishlist-btn"
  data-wishlist-toggle
  data-product-id="{{ product.id }}"
  data-product-title="{{ product.title | escape }}"
  data-product-url="{{ product.url }}"
  data-product-image="{{ product.featured_image | image_url: width: 200 }}"
  data-product-price="{{ product.price | money }}"
  aria-label="أضيفي للمفضلة"
>
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" stroke="currentColor" stroke-width="1.5"/>
  </svg>
</button>

{% stylesheet %}
  .wishlist-btn {
    position: absolute;
    top: 0.75rem;
    inset-inline-end: 0.75rem;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    border: none;
    background: var(--color-white);
    color: var(--color-gold);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-soft);
    z-index: 2;
  }
  .wishlist-btn.is-active { color: #e74c3c; }
  .wishlist-btn.is-active svg path { fill: #e74c3c; }
{% endstylesheet %}
