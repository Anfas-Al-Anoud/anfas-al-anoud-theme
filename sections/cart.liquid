<div class="cart-page section-padding">
  <h1 class="cart-page__title">{{ 'general.cart.title' | t }}</h1>

  {% if cart.item_count == 0 %}
    <div class="cart-page__empty">
      <p>{{ 'general.cart.empty' | t }}</p>
      <a href="{{ routes.all_products_collection_url }}" class="btn">{{ 'general.cart.continue' | t }}</a>
    </div>
  {% else %}
    <form action="{{ routes.cart_url }}" method="post" class="cart-page__form">
      <div class="cart-page__items">
        {% for item in cart.items %}
          <div class="cart-page__item">
            <a href="{{ item.url }}" class="cart-page__item-media">
              {% if item.image %}
                <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.image.alt | default: item.product.title | escape }}" width="100" height="100" loading="lazy">
              {% endif %}
            </a>
            <div class="cart-page__item-info">
              <a href="{{ item.url }}" class="cart-page__item-title">{{ item.product.title }}</a>
              {% unless item.variant.title contains 'Default' %}
                <p class="cart-page__item-variant">{{ item.variant.title }}</p>
              {% endunless %}
              <p class="cart-page__item-price">{{ item.final_price | money_without_currency }} {{ 'general.currency' | t }}</p>
              <a href="{{ item.url_to_remove }}" class="cart-page__remove">{{ 'general.cart.remove' | t }}</a>
            </div>
            <div class="cart-page__item-controls">
              <input
                type="number"
                name="updates[]"
                value="{{ item.quantity }}"
                min="0"
                aria-label="{{ 'general.product.quantity' | t }}"
                class="cart-page__qty"
              >
              <span class="cart-page__line-price">{{ item.final_line_price | money_without_currency }} {{ 'general.currency' | t }}</span>
            </div>
          </div>
        {% endfor %}
      </div>

      <aside class="cart-page__summary">
        <h2>{{ 'general.cart.summary' | t }}</h2>
        {% if settings.enable_cart_note %}
          <label class="cart-page__note-label" for="CartNote">{{ 'general.cart.note_label' | t }}</label>
          <textarea
            id="CartNote"
            class="cart-page__note-input"
            name="note"
            rows="4"
            placeholder="{{ 'general.cart.note_placeholder' | t }}"
          >{{ cart.note }}</textarea>
          {% if settings.enable_gift_message %}
            <p class="cart-page__note-hint">{{ 'general.cart.gift_message_hint' | t }}</p>
          {% endif %}
        {% endif %}
        <div class="cart-page__summary-row">
          <span>{{ 'general.cart.subtotal' | t }}</span>
          <span>{{ cart.total_price | money_without_currency }} {{ 'general.currency' | t }}</span>
        </div>
        <p class="cart-page__note">{{ 'general.cart.tax_note' | t }}</p>
        {% render 'anoud-heart-note', variant: 'compact' %}
        <button type="submit" name="update" class="btn btn--outline cart-page__update">{{ 'general.cart.update' | t }}</button>
        <button type="submit" name="checkout" class="btn cart-page__checkout">{{ 'general.cart.checkout' | t }}</button>
        <a href="{{ routes.all_products_collection_url }}" class="cart-page__continue">{{ 'general.cart.continue' | t }}</a>
      </aside>
    </form>
  {% endif %}
</div>

{% stylesheet %}
  .cart-page { max-width: var(--page-width); margin-inline: auto; padding-inline: var(--page-margin); }
  .cart-page__title { text-align: center; margin-block-end: 2rem; }
  .cart-page__empty { text-align: center; display: flex; flex-direction: column; gap: 1.25rem; align-items: center; padding-block: 3rem; }
  .cart-page__form { display: grid; gap: 2rem; }
  @media (min-width: 900px) { .cart-page__form { grid-template-columns: 1.6fr 1fr; align-items: start; } }
  .cart-page__items { display: flex; flex-direction: column; gap: 1rem; }
  .cart-page__item { display: grid; grid-template-columns: auto 1fr auto; gap: 1rem; padding-block: 1rem; border-block-end: 1px solid var(--color-sand); }
  .cart-page__item-media img { border-radius: var(--style-border-radius-cards); object-fit: cover; width: 100px; height: 100px; }
  .cart-page__item-info { display: flex; flex-direction: column; gap: 0.35rem; }
  .cart-page__item-title { font-weight: 600; color: var(--color-dark); text-decoration: none; }
  .cart-page__item-variant { color: var(--color-accent); font-size: 0.85rem; }
  .cart-page__remove { color: #c0392b; font-size: 0.85rem; text-decoration: none; }
  .cart-page__item-controls { display: flex; flex-direction: column; align-items: end; gap: 0.75rem; }
  .cart-page__qty { width: 4rem; padding: 0.5rem; text-align: center; border: 1.5px solid var(--color-sand); border-radius: var(--style-border-radius-inputs); }
  .cart-page__line-price { font-weight: 700; }
  .cart-page__summary { background: var(--color-cream); border-radius: var(--style-border-radius-cards); padding: 1.5rem; display: flex; flex-direction: column; gap: 0.85rem; position: sticky; top: calc(var(--header-height) + 1rem); }
  .cart-page__note-label { font-weight: 700; font-size: 0.9rem; }
  .cart-page__note-input {
    width: 100%;
    padding: 0.75rem;
    border: 1.5px solid var(--color-sand);
    border-radius: var(--style-border-radius-inputs);
    font: inherit;
    resize: vertical;
  }
  .cart-page__note-hint { font-size: 0.8rem; color: var(--color-accent); margin: 0; }
  .cart-page__summary-row { display: flex; justify-content: space-between; font-weight: 700; font-size: 1.1rem; }
  .cart-page__note { font-size: 0.8rem; color: var(--color-accent); }
  .cart-page__continue { text-align: center; color: var(--color-accent); text-decoration: none; font-weight: 600; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}
