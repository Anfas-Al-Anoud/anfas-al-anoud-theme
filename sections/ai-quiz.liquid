<section class="ai-quiz section-padding" id="ai-quiz" data-animate-section>
  <div class="ai-quiz__inner">
    <div class="ai-quiz__intro">
      {% if section.settings.avatar %}
        {% render 'image', image: section.settings.avatar, alt: section.settings.avatar_alt, fallback_alt: section.settings.heading, class: 'ai-quiz__avatar', width: 120 %}
      {% elsif section.settings.avatar_asset != blank %}
        {% render 'theme-asset-image', asset: section.settings.avatar_asset, alt: section.settings.avatar_alt, class: 'ai-quiz__avatar', width: 120, loading: 'eager' %}
      {% else %}
        {% render 'placeholder-svg',
          text: section.settings.avatar_alt | default: 'العنود',
          class: 'ai-quiz__avatar ai-quiz__avatar--placeholder',
          width: 80,
          height: 80
        %}
      {% endif %}
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
      <p class="section-subheading">{{ section.settings.subheading }}</p>
    </div>

    <div class="ai-quiz__widget" data-ai-quiz>
      <div class="ai-quiz__progress" data-quiz-progress role="list" aria-label="خطوات المساعدة">
        <span class="is-active" role="listitem" aria-current="step"></span>
        <span role="listitem" aria-current="false"></span>
        <span role="listitem" aria-current="false"></span>
      </div>
      <p class="visually-hidden" data-quiz-live aria-live="polite"></p>

      <div class="ai-quiz__step" data-quiz-step="1">
        <p class="ai-quiz__question" id="QuizQ1">شو المناسبة اللي تبين الريحة لها؟</p>
        <div class="ai-quiz__options" role="group" aria-labelledby="QuizQ1">
          <button type="button" class="ai-quiz__option" data-quiz-value="work">دوام وطلعات</button>
          <button type="button" class="ai-quiz__option" data-quiz-value="evening">سهرات وعزايم</button>
          <button type="button" class="ai-quiz__option" data-quiz-value="home">ميلس ومواجيب</button>
          <button type="button" class="ai-quiz__option" data-quiz-value="gift">هدية</button>
        </div>
      </div>

      <div class="ai-quiz__step" data-quiz-step="2" hidden>
        <button type="button" class="ai-quiz__back" data-quiz-back>‹ رجوع</button>
        <p class="ai-quiz__question" id="QuizQ2">شو المزاج اللي تحبينه؟</p>
        <div class="ai-quiz__options" role="group" aria-labelledby="QuizQ2">
          <button type="button" class="ai-quiz__option" data-quiz-value="light">خفيف ومنعش</button>
          <button type="button" class="ai-quiz__option" data-quiz-value="rich">فخم وقوي</button>
          <button type="button" class="ai-quiz__option" data-quiz-value="soft">ناعم ورومانسي</button>
        </div>
      </div>

      <div class="ai-quiz__step" data-quiz-step="3" hidden>
        <button type="button" class="ai-quiz__back" data-quiz-back>‹ رجوع</button>
        <p class="ai-quiz__question" id="QuizQ3">أي نوع منتج تدورين عليه؟</p>
        <div class="ai-quiz__options" role="group" aria-labelledby="QuizQ3">
          <button type="button" class="ai-quiz__option" data-quiz-value="dokhoon">دخون</button>
          <button type="button" class="ai-quiz__option" data-quiz-value="perfume">عطور</button>
          <button type="button" class="ai-quiz__option" data-quiz-value="care">دلع وعناية</button>
          <button type="button" class="ai-quiz__option" data-quiz-value="box">بوكسات</button>
        </div>
      </div>

      <div class="ai-quiz__loading" data-quiz-loading hidden>
        <span class="ai-quiz__dots" aria-hidden="true"><i></i><i></i><i></i></span>
        <p data-quiz-loading-text>لحظة أختار لج الأنسب...</p>
      </div>

      <div class="ai-quiz__results" data-quiz-results hidden>
        <p class="ai-quiz__results-title" data-quiz-results-title>هذي اقتراحاتي لج:</p>
        <div class="ai-quiz__products" data-quiz-products></div>
        <button type="button" class="btn btn--outline" data-quiz-restart>ابدأي من جديد</button>
      </div>
    </div>
  </div>

  <script type="application/json" data-quiz-catalog>
    [
      {%- liquid
        assign quiz_collection = collections[section.settings.collection]
        if quiz_collection == blank
          assign quiz_collection = collections.all
        endif
      -%}
      {%- paginate quiz_collection.products by 100 -%}
        {%- for product in quiz_collection.products -%}
          {%- assign v = product.selected_or_first_available_variant -%}
          {
            "id": {{ product.id | json }},
            "handle": {{ product.handle | json }},
            "title": {{ product.title | json }},
            "url": {{ product.url | json }},
            "type": {{ product.type | json }},
            "tags": {{ product.tags | json }},
            "collections": [
              {%- for c in product.collections -%}
                {{ c.handle | json }}{%- unless forloop.last -%},{%- endunless -%}
              {%- endfor -%}
            ],
            "image": {{ product.featured_image | image_url: width: 200 | json }},
            "price": {{ product.price | money | json }},
            "variant_id": {{ v.id | default: 0 | json }},
            "available": {{ product.available | json }}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      {%- endpaginate -%}
    ]
  </script>
</section>

{% stylesheet %}
  .ai-quiz__inner { max-width: var(--page-width); margin-inline: auto; padding-inline: var(--page-margin); }
  .ai-quiz__intro { text-align: center; margin-block-end: 2rem; }
  .ai-quiz__avatar { width: 5rem; height: 5rem; border-radius: 50%; object-fit: cover; margin-inline: auto; margin-block-end: 1rem; }
  .ai-quiz__avatar--placeholder { overflow: hidden; }
  .ai-quiz__widget {
    background: var(--color-white);
    border-radius: var(--style-border-radius-cards);
    padding: 2rem;
    box-shadow: var(--shadow-soft);
    max-width: 38rem;
    margin-inline: auto;
  }
  .ai-quiz__progress { display: flex; gap: 0.4rem; justify-content: center; margin-block-end: 1.5rem; }
  .ai-quiz__progress span {
    width: 2.5rem;
    height: 0.3rem;
    border-radius: 999px;
    background: var(--color-sand);
    transition: background var(--transition-base);
  }
  .ai-quiz__progress span.is-active { background: var(--color-gold); }
  .ai-quiz__back {
    background: none;
    border: none;
    color: var(--color-accent);
    cursor: pointer;
    font: inherit;
    margin-block-end: 0.75rem;
    min-height: 2.75rem;
    padding-inline: 0.25rem;
  }
  .ai-quiz__back:focus-visible,
  .ai-quiz__option:focus-visible,
  .ai-quiz__product-add:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
  .ai-quiz__question { font-weight: 700; font-size: 1.1rem; margin-block-end: 1.25rem; text-align: center; }
  .ai-quiz__options { display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; }
  .ai-quiz__option {
    padding: 0.7rem 1.35rem;
    border: 1.5px solid var(--color-sand);
    border-radius: 999px;
    background: var(--color-white);
    cursor: pointer;
    font: inherit;
    font-weight: 600;
    min-height: 2.75rem;
    transition: border-color var(--transition-base), background var(--transition-base), color var(--transition-base), transform var(--transition-base);
  }
  .ai-quiz__option:hover { border-color: var(--color-gold); background: var(--color-cream); }
  .ai-quiz__option.is-selected {
    border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 12%, var(--color-white));
    color: var(--color-primary);
  }
  .ai-quiz__loading { text-align: center; padding-block: 1.5rem; color: var(--color-accent); }
  .ai-quiz__dots { display: inline-flex; gap: 0.35rem; margin-block-end: 0.75rem; }
  .ai-quiz__dots i {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background: var(--color-gold);
    animation: quizdot 1s infinite ease-in-out;
  }
  .ai-quiz__dots i:nth-child(2) { animation-delay: 0.15s; }
  .ai-quiz__dots i:nth-child(3) { animation-delay: 0.3s; }
  @keyframes quizdot {
    0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
    40% { opacity: 1; transform: scale(1); }
  }
  .ai-quiz__results-title { font-weight: 700; text-align: center; margin-block-end: 1.25rem; line-height: 1.5; }
  .ai-quiz__products { display: grid; gap: 1rem; margin-block-end: 1.5rem; }
  .ai-quiz__product {
    display: flex;
    gap: 1rem;
    align-items: center;
    padding: 0.75rem;
    border-radius: var(--style-border-radius-cards);
    background: var(--color-cream);
  }
  .ai-quiz__product--top {
    background: color-mix(in srgb, var(--color-gold) 14%, var(--color-cream));
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-gold) 45%, transparent);
  }
  .ai-quiz__product img { width: 4rem; height: 4rem; object-fit: cover; border-radius: 8px; flex-shrink: 0; }
  .ai-quiz__product-body { flex: 1; min-width: 0; }
  .ai-quiz__badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-block-end: 0.2rem;
  }
  .ai-quiz__product-title { color: var(--color-dark); text-decoration: none; font-weight: 600; display: block; }
  .ai-quiz__product-reason {
    margin: 0.2rem 0 0.15rem;
    font-size: 0.82rem;
    color: var(--color-accent);
    line-height: 1.4;
  }
  .ai-quiz__product-price { color: var(--color-accent); font-size: 0.9rem; }
  .ai-quiz__product-add {
    border: none;
    background: var(--color-dark);
    color: var(--color-white);
    border-radius: 999px;
    padding: 0.5rem 1rem;
    cursor: pointer;
    font: inherit;
    font-size: 0.85rem;
    white-space: nowrap;
    min-height: 2.75rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }
  .ai-quiz__product-add:disabled { opacity: 0.5; cursor: default; }
  @media (prefers-reduced-motion: reduce) {
    .ai-quiz__dots i { animation: none; }
    .ai-quiz__option { transition: none; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.ai_quiz.name",
  "class": "ai-quiz-section",
  "settings": [
    { "type": "image_picker", "id": "avatar", "label": "صورة العنود (anoud-avatar.png)" },
    { "type": "text", "id": "avatar_asset", "label": "ملف صورة العنود (assets/)", "default": "anoud-avatar.jpg" },
    {
      "type": "text",
      "id": "avatar_alt",
      "label": "نص alt للصورة (مطلوب)",
      "default": "صورة العنود للمساعدة",
      "info": "مطلوب عند رفع صورة العنود. لا تتركي الحقل فارغًا."
    },
    { "type": "collection", "id": "collection", "label": "المجموعة المصدر للاقتراحات", "info": "اتركيها فارغة لاستخدام كل المنتجات." },
    { "type": "text", "id": "heading", "label": "العنوان", "default": "سولفي وياي" },
    { "type": "textarea", "id": "subheading", "label": "النص", "default": "محتارة شو اللي يلوق على شخصيتج؟ أنا هنيه عشان أساعدج تختارين صح." }
  ],
  "presets": [{ "name": "t:sections.ai_quiz.name" }]
}
{% endschema %}
