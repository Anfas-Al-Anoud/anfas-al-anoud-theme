{% doc %}
  Renders link-hub cards from theme settings (WhatsApp, social) with optional block overrides.
{% enddoc %}

{% liquid
  assign use_auto_links = section.settings.use_auto_links
  assign has_blocks = false
  if section.blocks.size > 0
    assign has_blocks = true
  endif
%}

<section class="link-hub section-padding">
  <h1 class="section-heading">{{ section.settings.heading }}</h1>
  <p class="section-subheading">{{ section.settings.subheading }}</p>

  <div class="link-hub__grid">
    {% if use_auto_links and has_blocks == false %}
      {% if settings.whatsapp_number != blank %}
        <a
          href="https://wa.me/{{ settings.whatsapp_number | remove: '+' | remove: ' ' | remove: '-' }}"
          class="link-hub__card link-hub__card--whatsapp"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="link-hub__icon" aria-hidden="true">{{ 'icon-whatsapp.svg' | inline_asset_content }}</span>
          <span>{{ 'sections.link_hub.whatsapp' | t }}</span>
        </a>
      {% endif %}

      {% if settings.social_instagram != blank %}
        <a href="{{ settings.social_instagram }}" class="link-hub__card" target="_blank" rel="noopener noreferrer">
          <span class="link-hub__icon" aria-hidden="true">{{ 'icon-instagram.svg' | inline_asset_content }}</span>
          <span>{{ 'sections.link_hub.instagram' | t }}</span>
        </a>
      {% endif %}

      {% if settings.social_tiktok != blank %}
        <a href="{{ settings.social_tiktok }}" class="link-hub__card" target="_blank" rel="noopener noreferrer">
          <span class="link-hub__icon" aria-hidden="true">{{ 'icon-tiktok.svg' | inline_asset_content }}</span>
          <span>{{ 'sections.link_hub.tiktok' | t }}</span>
        </a>
      {% endif %}

      {% if settings.social_snapchat != blank %}
        <a href="{{ settings.social_snapchat }}" class="link-hub__card" target="_blank" rel="noopener noreferrer">
          <span class="link-hub__icon" aria-hidden="true">{{ 'icon-snapchat.svg' | inline_asset_content }}</span>
          <span>{{ 'sections.link_hub.snapchat' | t }}</span>
        </a>
      {% endif %}

      {% if settings.social_facebook != blank %}
        <a href="{{ settings.social_facebook }}" class="link-hub__card" target="_blank" rel="noopener noreferrer">
          <span class="link-hub__icon" aria-hidden="true">{{ 'icon-facebook.svg' | inline_asset_content }}</span>
          <span>{{ 'sections.link_hub.facebook' | t }}</span>
        </a>
      {% endif %}

      {% if settings.social_threads != blank %}
        <a href="{{ settings.social_threads }}" class="link-hub__card" target="_blank" rel="noopener noreferrer">
          <span class="link-hub__icon" aria-hidden="true">{{ 'icon-threads.svg' | inline_asset_content }}</span>
          <span>{{ 'sections.link_hub.threads' | t }}</span>
        </a>
      {% endif %}

      {% if section.settings.show_shop_link %}
        <a href="{{ routes.all_products_collection_url }}" class="link-hub__card">
          <span class="link-hub__label">🛍</span>
          <span>{{ 'sections.link_hub.shop' | t }}</span>
        </a>
      {% endif %}
    {% else %}
      {% for block in section.blocks %}
        <a
          href="{{ block.settings.link }}"
          class="link-hub__card"
          {{ block.shopify_attributes }}
          {% if block.settings.external %}target="_blank" rel="noopener noreferrer"{% endif %}
        >
          {% if block.settings.icon %}
            {% render 'image', image: block.settings.icon, alt: block.settings.title, fallback_alt: block.settings.title, width: 80 %}
          {% endif %}
          <span>{{ block.settings.title }}</span>
        </a>
      {% endfor %}
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .link-hub__grid {
    display: grid;
    gap: 1rem;
    max-width: 28rem;
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }
  .link-hub__card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: var(--color-white);
    border-radius: var(--style-border-radius-buttons);
    box-shadow: var(--shadow-soft);
    text-decoration: none;
    color: var(--color-dark);
    font-weight: 700;
    transition: transform var(--transition-base);
  }
  .link-hub__card:hover {
    transform: scale(1.02);
    background: var(--color-gold);
    color: var(--color-white);
  }
  .link-hub__card img { width: 2.5rem; height: 2.5rem; object-fit: contain; }
  .link-hub__icon {
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--color-dark);
  }
  .link-hub__icon svg { width: 1.75rem; height: 1.75rem; display: block; }
  .link-hub__card:hover .link-hub__icon { color: var(--color-white); }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.link_hub.name",
  "class": "link-hub-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "العنوان",
      "default": "لمتنا أحلى وياج"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "النص",
      "default": "تابعينا وتواصلي معنا من هنا — روابطنا الرسمية بمكان واحد"
    },
    {
      "type": "checkbox",
      "id": "use_auto_links",
      "label": "توليد الروابط تلقائيًا من إعدادات السمة",
      "default": true,
      "info": "يستخدم رقم الواتساب وروابط السوشيال من Theme settings. أضيفي blocks يدويًا لتجاوز التوليد التلقائي."
    },
    {
      "type": "checkbox",
      "id": "show_shop_link",
      "label": "إظهار رابط المتجر (اختياري)",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "رابط",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "الأيقونة" },
        { "type": "text", "id": "title", "label": "العنوان", "default": "رابط" },
        { "type": "url", "id": "link", "label": "الرابط" },
        { "type": "checkbox", "id": "external", "label": "رابط خارجي", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.link_hub.name",
      "settings": {
        "use_auto_links": true,
        "show_shop_link": false
      }
    }
  ]
}
{% endschema %}
