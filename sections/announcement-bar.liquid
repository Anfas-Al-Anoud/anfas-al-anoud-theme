{%- unless settings.header_style == 'overlay' -%}
<div class="announcement-bar full-width announcement-bar--{{ settings.header_style | default: 'classic' }}" role="region" aria-label="{{ 'sections.announcement_bar.name' | t }}">
  <div class="announcement-bar__track">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        <p class="announcement-bar__text" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
      {% endfor %}
      {% for block in section.blocks %}
        <p class="announcement-bar__text announcement-bar__text--clone" aria-hidden="true">{{ block.settings.text }}</p>
      {% endfor %}
    {% else %}
      <p class="announcement-bar__text">{{ section.settings.text }}</p>
      <p class="announcement-bar__text announcement-bar__text--clone" aria-hidden="true">{{ section.settings.text }}</p>
    {% endif %}
  </div>
</div>
{%- endunless -%}

{% stylesheet %}
  .announcement-bar {
    background: var(--color-primary);
    color: var(--color-primary-foreground);
    overflow: hidden;
    padding-block: 0.625rem;
  }

  .announcement-bar__track {
    display: flex;
    width: max-content;
    animation: marquee 36s linear infinite;
  }

  .announcement-bar__text {
    white-space: nowrap;
    padding-inline: 3rem;
    font-size: 0.875rem;
    margin: 0;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes marquee-rtl {
    0% { transform: translateX(0); }
    100% { transform: translateX(50%); }
  }

  [dir="rtl"] .announcement-bar__track {
    animation-name: marquee-rtl;
  }

  /* Commerce: slim solid static bar like IMG_7838 */
  .announcement-bar--commerce {
    padding-block: 0.45rem;
  }
  .announcement-bar--commerce .announcement-bar__track {
    width: 100%;
    animation: none;
    justify-content: center;
    overflow: hidden;
  }
  .announcement-bar--commerce .announcement-bar__text {
    padding-inline: 1rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-align: center;
  }
  .announcement-bar--commerce .announcement-bar__text--clone,
  .announcement-bar--commerce .announcement-bar__text:not(:first-of-type) {
    display: none;
  }

  @media (max-width: 767px) {
    .announcement-bar {
      padding-block: 0.35rem;
    }
    .announcement-bar__text {
      font-size: 0.75rem;
      padding-inline: 1.75rem;
    }
    .announcement-bar--commerce {
      padding-block: 0.4rem;
    }
    .announcement-bar--commerce .announcement-bar__text {
      font-size: 0.65rem;
      padding-inline: 0.75rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .announcement-bar__track {
      animation: none;
      width: 100%;
      flex-wrap: wrap;
      justify-content: center;
    }
    .announcement-bar__text--clone {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.announcement_bar.name",
  "class": "announcement-bar-section",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "النص (عند عدم وجود blocks)",
      "default": "استغلي وقتج الذهبي.. توصيل مجاني اليوم لعيونج – عروض عيد الأضحى... ما عيبج المنتج؟ ما تحاتين رديه خلال أسبوع"
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "رسالة",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "النص",
          "default": "🚚 توصيل مجاني داخل الإمارات للطلبات فوق 200 درهم"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.announcement_bar.name",
      "blocks": [
        { "type": "message", "settings": { "text": "🚚 توصيل مجاني داخل الإمارات للطلبات فوق 200 درهم" } }
      ]
    }
  ]
}
{% endschema %}
