<section class="mood-cards section-padding" data-animate-section>
  <div class="mood-cards__header">
    <h2 class="section-heading">{{ section.settings.heading }}</h2>
    {% if section.settings.subheading != blank %}
      <p class="section-subheading">{{ section.settings.subheading }}</p>
    {% endif %}
  </div>
  {% capture mood_slides %}
    {% for block in section.blocks %}
      <article class="carousel__slide mood-cards__card" {{ block.shopify_attributes }}>
        <a href="{{ block.settings.link }}">
          {% if block.settings.image %}
            {% render 'image', image: block.settings.image, alt: block.settings.image_alt, fallback_alt: block.settings.title, class: 'mood-cards__image', width: 600 %}
          {% elsif block.settings.image_asset != blank %}
            {% render 'theme-asset-image', asset: block.settings.image_asset, alt: block.settings.image_alt, class: 'mood-cards__image', width: 600 %}
          {% else %}
            {% render 'placeholder-svg',
              text: block.settings.image_alt | default: block.settings.title,
              class: 'mood-cards__image mood-cards__placeholder',
              width: '100%',
              height: '100%'
            %}
          {% endif %}
          <div class="mood-cards__content">
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        </a>
      </article>
    {% endfor %}
  {% endcapture %}
  {% render 'carousel', slides: mood_slides, class: 'mood-cards__carousel', gap: '1rem', show_nav: true %}
</section>

{% stylesheet %}
  .mood-cards__header {
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }

  .mood-cards__header .section-heading,
  .mood-cards__header .section-subheading {
    text-align: start;
    margin-inline: 0;
  }

  @media (max-width: 767px) {
    .mood-cards__header .section-heading,
    .mood-cards__header .section-subheading {
      text-align: center;
    }
  }

  .mood-cards__carousel {
    margin-block-start: 0.5rem;
  }

  .mood-cards__card {
    flex: 0 0 calc(72% - 0.5rem);
    width: calc(72% - 0.5rem);
    display: flex;
  }

  @media (min-width: 768px) {
    .mood-cards__card {
      flex: 0 0 calc(33.333% - 0.667rem);
      width: calc(33.333% - 0.667rem);
    }
  }

  @media (min-width: 1024px) {
    .mood-cards__card {
      flex: 0 0 calc(25% - 0.75rem);
      width: calc(25% - 0.75rem);
    }
  }

  .mood-cards__card a {
    display: flex;
    flex-direction: column;
    width: 100%;
    text-decoration: none;
    color: inherit;
    border-radius: var(--style-border-radius-cards);
    overflow: hidden;
    background: var(--color-white);
    box-shadow: var(--shadow-soft);
    height: 100%;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .mood-cards__card a:hover,
  .mood-cards__card a:focus-visible {
    transform: translateY(-3px);
    box-shadow: 0 12px 24px rgba(122, 31, 43, 0.14);
  }

  .mood-cards__image {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    flex-shrink: 0;
    transition: transform 0.5s ease;
  }

  .mood-cards__card a:hover .mood-cards__image {
    transform: scale(1.03);
  }

  .mood-cards__content {
    padding: 1rem;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .mood-cards__content h3 {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-dark);
    margin: 0;
    line-height: 1.4;
    text-align: center;
    width: 100%;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: calc(2 * 1.4 * 0.95rem);
    transition: color var(--transition-base);
  }

  .mood-cards__card a:hover .mood-cards__content h3 {
    color: var(--color-primary);
  }

  .mood-cards__content p {
    display: none;
  }

  .mood-cards__placeholder {
    min-height: 0;
    aspect-ratio: 1 / 1;
  }

  @media (max-width: 767px) {
    .mood-cards.section-padding {
      padding-block: 1rem;
    }
  }

  @media (min-width: 768px) {
    .mood-cards.section-padding {
      padding-block: 1.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.mood_cards.name",
  "class": "mood-cards-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "العنوان",
      "default": "اختاري حسب حالتج"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "النص الفرعي",
      "default": "دوام، شاور، ميلس، سهرة، أو زهبة — ادخلي من اللي يناسبج الحين."
    }
  ],
  "blocks": [
    {
      "type": "mood",
      "name": "بطاقة",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "الصورة" },
        { "type": "text", "id": "image_asset", "label": "ملف الصورة (assets/)", "info": "صورة سياقية — ليست صورة منتج." },
        {
          "type": "text",
          "id": "image_alt",
          "label": "نص alt للصورة (مطلوب)",
          "default": "صورة البطاقة",
          "info": "مطلوب عند رفع صورة. لا تتركي الحقل فارغًا."
        },
        { "type": "text", "id": "title", "label": "العنوان", "default": "عنوان" },
        { "type": "textarea", "id": "text", "label": "النص" },
        { "type": "url", "id": "link", "label": "الرابط" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.mood_cards.name",
      "blocks": [
        { "type": "mood", "settings": { "title": "حق الدوام والطلعات", "text": "عطور باردة وهادية تفتح النفس من الصبح وتثبت معاج طول اليوم." } },
        { "type": "mood", "settings": { "title": "الدلع والشاور", "text": "إحساس النظافة اللي يرد الروح! منتجات تدلع بشرتج وشعرج." } },
        { "type": "mood", "settings": { "title": "فخامة الميلس والمواجيب", "text": "بيّضي ويهج جدام خطاريج... دخون ومرشات تخلي ريحة البيت تفوح." } },
        { "type": "mood", "settings": { "title": "للسهرات والعزايم", "text": "تبين تلفتين الانتباه من أول ما تدخلين الصالة؟" } },
        { "type": "mood", "settings": { "title": "زْهبة العروس", "text": "لأن هالليلة ليلتج ومحد بيطوفج.. بوكسات ملكية تخلي ريحتج خيال." } }
      ]
    }
  ]
}
{% endschema %}
