{% doc %}
  Emits BreadcrumbList JSON-LD for product and collection pages.
{% enddoc %}

{% capture brand_display %}{% render 'brand-name' %}{% endcapture %}
{% assign brand_display = brand_display | strip %}

{%- if request.page_type == 'product' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": {{ brand_display | json }},
        "item": "{{ shop.url }}{{ routes.root_url }}"
      }{% if collection %},
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ collection.title | json }},
        "item": "{{ shop.url }}{{ collection.url }}"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": {{ product.title | json }},
        "item": "{{ shop.url }}{{ product.url }}"
      }
      {% else %},
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ product.title | json }},
        "item": "{{ shop.url }}{{ product.url }}"
      }
      {% endif %}
    ]
  }
  </script>
{%- elsif request.page_type == 'collection' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": {{ brand_display | json }},
        "item": "{{ shop.url }}{{ routes.root_url }}"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ collection.title | json }},
        "item": "{{ shop.url }}{{ collection.url }}"
      }
    ]
  }
  </script>
{%- endif -%}
