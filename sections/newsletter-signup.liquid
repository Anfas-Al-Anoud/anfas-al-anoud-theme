<section class="newsletter-signup section-padding" data-animate-section>
  <div class="newsletter-signup__inner">
    <div class="newsletter-signup__copy">
      <h2 class="section-heading newsletter-signup__heading">{% render 'tanween', text: section.settings.heading %}</h2>
      {% if section.settings.text != blank %}
        <p class="section-subheading newsletter-signup__text">{% render 'tanween', text: section.settings.text %}</p>
      {% endif %}
    </div>
    {% form 'customer', class: 'newsletter-signup__form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <label class="visually-hidden" for="NewsletterEmail-{{ section.id }}">{{ section.settings.email_label }}</label>
      <input
        id="NewsletterEmail-{{ section.id }}"
        type="email"
        name="contact[email]"
        placeholder="{{ section.settings.email_placeholder }}"
        required
        autocomplete="email"
      >
      <button type="submit" class="btn">{{ section.settings.button_label }}</button>
      {% if form.posted_successfully? %}
        <p class="newsletter-signup__success" role="status">{{ 'sections.newsletter_signup.success' | t }}</p>
      {% endif %}
      {% if form.errors %}
        <p class="newsletter-signup__error" role="alert">{{ form.errors | default_errors }}</p>
      {% endif %}
    {% endform %}
  </div>
</section>

{% stylesheet %}
  .newsletter-signup__inner {
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
    display: grid;
    gap: 1.25rem;
    align-items: center;
    background: var(--color-cream);
    border: 1px solid color-mix(in srgb, var(--color-gold) 35%, transparent);
    border-radius: var(--style-border-radius-cards);
    padding: 1.75rem;
  }
  @media (min-width: 768px) {
    .newsletter-signup__inner { grid-template-columns: 1fr auto; gap: 2rem; }
  }
  .newsletter-signup__heading,
  .newsletter-signup__text { text-align: start; margin-inline: 0; }
  .newsletter-signup__text { margin-block-end: 0; }
  .newsletter-signup__form {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    min-width: min(100%, 22rem);
  }
  .newsletter-signup__form input {
    padding: 0.75rem 1rem;
    border: 1.5px solid var(--color-sand);
    border-radius: var(--style-border-radius-inputs);
    font: inherit;
  }
  .newsletter-signup__success { color: var(--color-primary); font-weight: 700; margin: 0; font-size: 0.9rem; }
  .newsletter-signup__error { color: #c0392b; margin: 0; font-size: 0.9rem; }
  @media (prefers-reduced-motion: reduce) {
    .newsletter-signup { animation: none !important; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.newsletter_signup.name",
  "class": "newsletter-signup-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "خلينا على تواصل"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "t:labels.text",
      "default": "سجّلي إيميلج وكوني أول وحدة تعرفين العروض الحلوة ونصايح العنود للسنع."
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "t:sections.newsletter_signup.email_label",
      "default": "البريد الإلكتروني"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "t:sections.newsletter_signup.email_placeholder",
      "default": "حطي إيميلج هنيه"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:labels.button_label",
      "default": "اشتركي"
    }
  ],
  "presets": [{ "name": "t:sections.newsletter_signup.name" }]
}
{% endschema %}
