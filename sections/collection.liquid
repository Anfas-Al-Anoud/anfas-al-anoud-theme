<div class="collection-page section-padding">
  <header class="collection-page__header">
    <h1 class="section-heading">
      {%- if collection.handle == 'all' -%}
        {{ 'collections.all_title' | t }}
      {%- else -%}
        {% render 'tanween', text: collection.title %}
      {%- endif -%}
    </h1>
    {% if collection.description != blank %}
      <div class="collection-page__description rte">{{ collection.description }}</div>
    {% endif %}
  </header>

  {% paginate collection.products by section.settings.products_per_page %}
    <div class="collection-page__layout">
      {%- liquid
        assign show_type_filter = false
        if section.settings.show_filters and collection.all_types.size > 0
          assign show_type_filter = true
        endif
        assign has_store_filters = false
        if section.settings.show_filters and collection.filters.size > 0
          for filter in collection.filters
            if filter.type == 'price_range'
              continue
            endif
            assign fl = filter.label | downcase
            if fl == 'product type' or fl == 'type' or filter.label == 'نوع المنتج' or filter.label == 'النوع' or filter.label == 'التصنيف'
              continue
            endif
            assign has_store_filters = true
          endfor
        endif
      -%}
      {% if show_type_filter or has_store_filters %}
        <details class="collection-filters">
          <summary class="collection-filters__toggle">
            {% render 'icon-inline', name: 'filter' %} {{ 'collections.filter' | t }}
          </summary>
          <div class="collection-filters__form">
            {% if show_type_filter %}
              <div class="collection-filters__group">
                <p class="collection-filters__group-title">{{ 'collections.filters.product_type' | t }}</p>
                <ul class="collection-filters__list collection-filters__list--types">
                  <li>
                    <a
                      href="{{ collection.url }}"
                      class="collection-filters__type-link{% if collection.current_type == blank %} is-active{% endif %}"
                    >
                      {{ 'collections.filters.all_types' | t }}
                    </a>
                  </li>
                  {% for product_type in collection.all_types %}
                    {%- if product_type == blank -%}{%- continue -%}{%- endif -%}
                    {%- liquid
                      assign type_key = product_type | downcase | strip
                      assign type_label = product_type
                      case type_key
                        when 'bakhoor'
                          assign type_label = 'collections.filters.types.bakhoor' | t
                        when 'perfume'
                          assign type_label = 'collections.filters.types.perfume' | t
                        when 'spray'
                          assign type_label = 'collections.filters.types.spray' | t
                        when 'body-oil', 'body oil'
                          assign type_label = 'collections.filters.types.body_oil' | t
                        when 'bundle'
                          assign type_label = 'collections.filters.types.bundle' | t
                        when 'care-shampoo'
                          assign type_label = 'collections.filters.types.shampoo' | t
                        when 'care-shower'
                          assign type_label = 'collections.filters.types.shower' | t
                        when 'care-lotion'
                          assign type_label = 'collections.filters.types.lotion' | t
                        when 'care'
                          assign type_label = 'collections.filters.types.care' | t
                      endcase
                    -%}
                    <li>
                      <a
                        href="{{ collection.url }}/{{ product_type | handleize }}"
                        class="collection-filters__type-link{% if collection.current_type == product_type %} is-active{% endif %}"
                      >
                        {{ type_label }}
                      </a>
                    </li>
                  {% endfor %}
                </ul>
              </div>
            {% endif %}

            {% if has_store_filters %}
              <form class="collection-filters__store-form" method="get">
                {% for filter in collection.filters %}
                  {%- if filter.type == 'price_range' -%}{%- continue -%}{%- endif -%}
                  {%- liquid
                    assign filter_label = filter.label
                    assign filter_label_down = filter.label | downcase
                    if filter.label == 'Availability' or filter_label_down == 'availability'
                      assign filter_label = 'collections.filters.availability' | t
                    elsif filter_label_down == 'product type' or filter_label_down == 'type' or filter.label == 'نوع المنتج' or filter.label == 'النوع' or filter.label == 'التصنيف'
                      continue
                    endif
                  -%}
                  <div class="collection-filters__group">
                    <p class="collection-filters__group-title">{{ filter_label }}</p>
                    {% case filter.type %}
                      {% when 'list', 'boolean' %}
                        <ul class="collection-filters__list">
                          {% for value in filter.values %}
                            {%- liquid
                              assign value_label = value.label
                              case value.label
                                when 'In stock'
                                  assign value_label = 'collections.filters.in_stock' | t
                                when 'Out of stock'
                                  assign value_label = 'collections.filters.out_of_stock' | t
                              endcase
                            -%}
                            <li>
                              <label class="collection-filters__option {% if value.count == 0 and value.active == false %}is-disabled{% endif %}">
                                <input
                                  type="checkbox"
                                  name="{{ value.param_name }}"
                                  value="{{ value.value }}"
                                  {% if value.active %}checked{% endif %}
                                >
                                <span>{{ value_label }} ({{ value.count }})</span>
                              </label>
                            </li>
                          {% endfor %}
                        </ul>
                    {% endcase %}
                  </div>
                {% endfor %}
                <div class="collection-filters__actions">
                  <button type="submit" class="btn">{{ 'collections.apply' | t }}</button>
                  <a href="{{ collection.url }}" class="collection-filters__clear">{{ 'collections.clear' | t }}</a>
                </div>
              </form>
            {% elsif show_type_filter and collection.current_type != blank %}
              <div class="collection-filters__actions">
                <a href="{{ collection.url }}" class="collection-filters__clear">{{ 'collections.clear' | t }}</a>
              </div>
            {% endif %}
          </div>
        </details>
      {% endif %}

      <div class="collection-page__main">
        <div class="collection-page__toolbar">
          <span class="collection-page__count">{% render 'arabic-product-count', count: collection.products_count %}</span>
          <label class="collection-page__sort-wrap">
            <span class="visually-hidden">{{ 'collections.sort' | t }}</span>
            <select class="collection-page__sort" onchange="window.location.href=this.value">
              {% for option in collection.sort_options %}
                {%- liquid
                  assign option_label = option.name
                  case option.value
                    when 'manual'
                      assign option_label = 'collections.sort_options.featured' | t
                    when 'best-selling'
                      assign option_label = 'collections.sort_options.best_selling' | t
                    when 'title-ascending'
                      assign option_label = 'collections.sort_options.az' | t
                    when 'title-descending'
                      assign option_label = 'collections.sort_options.za' | t
                    when 'price-ascending'
                      assign option_label = 'collections.sort_options.price_ascending' | t
                    when 'price-descending'
                      assign option_label = 'collections.sort_options.price_descending' | t
                    when 'created-ascending'
                      assign option_label = 'collections.sort_options.date_ascending' | t
                    when 'created-descending'
                      assign option_label = 'collections.sort_options.date_descending' | t
                    when 'relevance', 'most-relevant'
                      assign option_label = 'collections.sort_options.relevance' | t
                  endcase
                -%}
                <option value="{{ collection.url }}?sort_by={{ option.value }}" {% if collection.sort_by == option.value %}selected{% endif %}>
                  {{ option_label }}
                </option>
              {% endfor %}
            </select>
          </label>
        </div>

        <div class="collection-page__grid">
          {% for product in collection.products %}
            {% render 'product-card', product: product %}
          {% else %}
            <p class="collection-page__empty">{{ 'collections.empty' | t }}</p>
          {% endfor %}
        </div>

        {% if paginate.pages > 1 %}
          <nav class="pagination" aria-label="{{ 'general.pagination.label' | t }}">
            {% if paginate.previous %}
              <a href="{{ paginate.previous.url }}" class="pagination__link">{{ 'general.pagination.previous' | t }}</a>
            {% endif %}
            {% for part in paginate.parts %}
              {% if part.is_link %}
                <a href="{{ part.url }}" class="pagination__link">{{ part.title }}</a>
              {% else %}
                <span class="pagination__link {% if part.title == paginate.current_page %}is-current{% endif %}">{{ part.title }}</span>
              {% endif %}
            {% endfor %}
            {% if paginate.next %}
              <a href="{{ paginate.next.url }}" class="pagination__link">{{ 'general.pagination.next' | t }}</a>
            {% endif %}
          </nav>
        {% endif %}
      </div>
    </div>
  {% endpaginate %}
</div>

{% stylesheet %}
  .collection-page { max-width: var(--page-width); margin-inline: auto; padding-inline: var(--page-margin); }
  .collection-page__header { text-align: center; margin-block-end: 2rem; }
  .collection-page__description { max-width: 40rem; margin-inline: auto; line-height: 1.8; color: var(--color-accent); }
  .collection-page__layout { display: block; }
  @media (min-width: 900px) {
    .collection-page__layout { display: grid; grid-template-columns: 16rem 1fr; gap: 2rem; align-items: start; }
  }
  .collection-filters { border: 1px solid var(--color-sand); border-radius: var(--style-border-radius-cards); padding: 1rem 1.25rem; margin-block-end: 1.5rem; }
  @media (min-width: 900px) { .collection-filters { position: sticky; top: calc(var(--header-height) + 1rem); margin-block-end: 0; } }
  .collection-filters__toggle { font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 0.5rem; }
  .collection-filters__toggle svg { width: 1.1rem; height: 1.1rem; }
  .collection-filters__group { margin-block-start: 1rem; }
  .collection-filters__group-title { font-weight: 600; margin-block-end: 0.5rem; }
  .collection-filters__list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.4rem; max-height: 14rem; overflow-y: auto; }
  .collection-filters__list--types { max-height: none; }
  .collection-filters__type-link {
    display: block;
    padding: 0.45rem 0.7rem;
    border-radius: var(--style-border-radius-inputs);
    border: 1px solid var(--color-sand);
    text-decoration: none;
    color: var(--color-dark);
    font-weight: 600;
    font-size: 0.9rem;
    transition: border-color var(--transition-base), background var(--transition-base), color var(--transition-base);
  }
  .collection-filters__type-link:hover {
    border-color: var(--color-gold);
    background: var(--color-cream);
  }
  .collection-filters__type-link.is-active {
    border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 10%, var(--color-white));
    color: var(--color-primary);
  }
  .collection-filters__option { display: flex; align-items: center; gap: 0.5rem; cursor: pointer; }
  .collection-filters__option.is-disabled { opacity: 0.45; }
  .collection-filters__actions { display: flex; align-items: center; gap: 1rem; margin-block-start: 1.25rem; }
  .collection-filters__clear { color: var(--color-accent); text-decoration: none; font-weight: 600; }
  .collection-page__toolbar { display: flex; justify-content: space-between; align-items: center; margin-block-end: 1.5rem; gap: 1rem; }
  .collection-page__sort { padding: 0.5rem 1rem; border-radius: var(--style-border-radius-inputs); border: 1px solid var(--color-sand); }
  .collection-page__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
  @media (min-width: 768px) { .collection-page__grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1200px) { .collection-page__grid { grid-template-columns: repeat(4, 1fr); } }
  .collection-page__empty { grid-column: 1 / -1; text-align: center; padding-block: 2rem; }
  .pagination { display: flex; justify-content: center; flex-wrap: wrap; gap: 0.5rem; margin-block-start: 2.5rem; }
  .pagination__link { min-width: 2.5rem; text-align: center; padding: 0.5rem 0.75rem; border: 1px solid var(--color-sand); border-radius: var(--style-border-radius-inputs); text-decoration: none; color: var(--color-dark); }
  .pagination__link.is-current { background: var(--color-gold); color: var(--color-white); border-color: var(--color-gold); }
  .visually-hidden { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection",
  "class": "collection-section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 16,
      "label": "منتجات لكل صفحة"
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "عرض عوامل التصفية",
      "default": true
    }
  ]
}
{% endschema %}
