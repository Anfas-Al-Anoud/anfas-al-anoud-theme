{% doc %}
  Renders an image from a CDN URL (e.g. product image) when Theme Editor upload is not used.
  @param {string} url - Full image URL
  @param {string} [alt] - Alt text
  @param {string} [class] - CSS class
  @param {number} [width] - Width hint for sizes
  @param {number} [height] - Height hint
  @param {string} [loading] - lazy or eager
{% enddoc %}

{% liquid
  assign alt_text = alt | default: shop.name
  assign img_loading = loading | default: 'lazy'
  assign img_width = width | default: 1200
  assign img_height = height | default: img_width
%}

{% if url != blank %}
  <img
    src="{{ url }}"
    alt="{{ alt_text | escape }}"
    class="{{ class }}"
    loading="{{ img_loading }}"
    width="{{ img_width }}"
    height="{{ img_height }}"
    decoding="async"
  >
{% endif %}
