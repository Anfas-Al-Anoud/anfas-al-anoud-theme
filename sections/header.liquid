<header class="site-header" data-header>
  <div class="site-header__inner">
    <button class="site-header__menu-toggle" type="button" aria-label="{{ 'general.accessibility.menu' | t }}" aria-expanded="false" aria-controls="MobileNav" data-menu-toggle>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>

    <nav class="site-header__nav" id="MobileNav" data-mobile-nav aria-label="القائمة الرئيسية">
      <a href="{{ routes.account_url }}" class="site-header__nav-link">حسابج</a>
      <button type="button" class="site-header__nav-link" data-wishlist-open aria-label="المفضلة">
        مفضلتج
      </button>
      <button type="button" class="site-header__nav-link site-header__cart-trigger" data-cart-open aria-label="{{ 'general.cart.title' | t }}">
        سلتج
        <span class="site-header__cart-count" data-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
      </button>
      <a href="{{ routes.search_url }}" class="site-header__nav-link">{{ 'general.search.title' | t }}</a>
      {% for link in section.settings.menu.links %}
        <a href="{{ link.url }}" class="site-header__nav-link">{{ link.title }}</a>
      {% endfor %}
    </nav>

    <a href="{{ routes.root_url }}" class="site-header__logo">
      {% if settings.logo %}
        {{
          settings.logo
          | image_url: width: settings.logo_width
          | image_tag:
            alt: shop.name,
            width: settings.logo_width,
            loading: 'eager'
        }}
      {% else %}
        <span class="site-header__logo-text" translate="no">{{ shop.name }}</span>
      {% endif %}
      <span class="site-header__logo-subtitle" aria-hidden="true" translate="no">ALANOUD</span>
    </a>

    <div class="site-header__actions">
      <form action="{{ routes.search_url }}" method="get" class="site-header__search" role="search" data-predictive-search>
        <input
          type="search"
          name="q"
          placeholder="{{ 'general.search.placeholder' | t }}"
          aria-label="{{ 'general.search.title' | t }}"
          autocomplete="off"
          data-predictive-input
          aria-expanded="false"
          aria-controls="PredictiveResults"
        >
        <div class="site-header__predictive" id="PredictiveResults" data-predictive-results role="listbox" hidden></div>
      </form>
      {% if shop.customer_accounts_enabled %}
        <a href="{{ routes.account_url }}" class="site-header__icon" aria-label="حسابج">
          {{ 'icon-account.svg' | inline_asset_content }}
        </a>
      {% endif %}
      <button type="button" class="site-header__icon" data-wishlist-open aria-label="المفضلة">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" stroke="currentColor" stroke-width="1.6"/></svg>
        <span class="site-header__cart-count" data-wishlist-count hidden>0</span>
      </button>
      <button type="button" class="site-header__icon site-header__cart-trigger" data-cart-open aria-label="{{ 'general.cart.title' | t }}">
        {{ 'icon-cart.svg' | inline_asset_content }}
        <span class="site-header__cart-count" data-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
      </button>
    </div>
  </div>
</header>

{% stylesheet %}
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--color-white) 82%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-block-end: 1px solid color-mix(in srgb, var(--color-gold) 30%, transparent);
    box-shadow: var(--shadow-soft);
  }
  .site-header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    min-height: var(--header-height);
    padding-inline: var(--page-margin);
    max-width: var(--page-width);
    margin-inline: auto;
  }
  .site-header__logo {
    justify-self: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    text-decoration: none;
    color: var(--color-dark);
  }
  .site-header__logo-text {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-primary);
  }
  .site-header__logo-subtitle {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.35em;
    text-indent: 0.35em;
    color: var(--color-gold);
    text-transform: uppercase;
  }
  .site-header__nav {
    display: none;
    flex-direction: column;
    position: fixed;
    inset: 0;
    top: var(--header-height);
    background: var(--color-white);
    padding: 1.5rem;
    gap: 1rem;
    z-index: 99;
  }
  .site-header__nav.is-open { display: flex; }
  .site-header__nav-link {
    text-decoration: none;
    color: var(--color-dark);
    font-weight: 600;
    background: none;
    border: none;
    font: inherit;
    cursor: pointer;
    text-align: start;
    padding: 0.5rem 0;
  }
  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    justify-self: end;
  }
  .site-header__search { display: none; position: relative; }
  .site-header__search input {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-sand);
    border-radius: var(--style-border-radius-inputs);
    min-width: 12rem;
  }
  .site-header__search input:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 1px; }
  .site-header__predictive {
    position: absolute;
    top: calc(100% + 0.5rem);
    inset-inline: 0;
    width: min(24rem, 90vw);
    inset-inline-end: 0;
    background: var(--color-white);
    border: 1px solid var(--color-sand);
    border-radius: var(--style-border-radius-cards);
    box-shadow: 0 16px 40px rgba(61, 43, 31, 0.16);
    max-height: min(70vh, 32rem);
    overflow-y: auto;
    z-index: 120;
  }
  .site-header__predictive[hidden] { display: none; }
  .site-header__icon {
    position: relative;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-dark);
    padding: 0.25rem;
    transition: color var(--transition-base);
  }
  .site-header__icon:hover { color: var(--color-primary); }
  .site-header__nav-link:hover { color: var(--color-primary); }
  .site-header__icon svg { width: 1.5rem; height: 1.5rem; }
  .site-header__cart-count {
    position: absolute;
    top: -4px;
    inset-inline-start: -4px;
    background: var(--color-primary);
    color: var(--color-primary-foreground);
    font-size: 0.65rem;
    font-weight: 700;
    min-width: 1.125rem;
    height: 1.125rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .site-header__menu-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-dark);
    justify-self: start;
  }
  @media (max-width: 767px) {
    /* App-style top bar: the fixed bottom nav + menu sheet already provide
       menu, search, wishlist, cart and account, so hide the duplicated
       header controls and keep a clean, centered logo. */
    .site-header__actions,
    .site-header__menu-toggle {
      display: none;
    }
    .site-header__logo {
      justify-self: center;
      grid-column: 1 / -1;
    }
  }
  @media (min-width: 768px) {
    .site-header__menu-toggle { display: none; }
    .site-header__nav {
      display: flex;
      position: static;
      flex-direction: row;
      padding: 0;
      gap: 1.25rem;
      align-items: center;
    }
    .site-header__search { display: block; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "class": "site-header-section",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
