{% doc %}
  Product card for collection grids and carousels.
  @param {object} product - Product object
  @param {boolean} [show_wishlist] - Show wishlist button
{% enddoc %}

{%- liquid
  assign second_image = product.media[1].preview_image | default: product.images[1]
  assign on_sale = false
  assign discount_percent = 0
  if product.compare_at_price > product.price
    assign on_sale = true
    assign savings = product.compare_at_price | minus: product.price
    assign discount_percent = savings | times: 100 | divided_by: product.compare_at_price
  endif
  assign rating = product.metafields.reviews.rating.value
  assign promo_label = ''
  assign is_new = false
  assign now_ts = 'now' | date: '%s' | plus: 0
  assign created_ts = product.created_at | date: '%s' | plus: 0
  assign age_days = now_ts | minus: created_ts | divided_by: 86400
  if age_days < 45
    assign is_new = true
  endif
  for tag in product.tags
    assign tag_down = tag | downcase
    if tag contains '1+1'
      assign promo_label = tag
      break
    endif
    if tag contains 'عرض'
      assign promo_label = tag
      break
    endif
    if tag_down contains 'offer'
      assign promo_label = tag
      break
    endif
  endfor
  for tag in product.tags
    assign tag_down = tag | downcase
    if tag contains 'جديد' or tag_down == 'new' or tag_down == 'new in'
      assign is_new = true
      break
    endif
  endfor
-%}

<article class="product-card" data-product-id="{{ product.id }}">
  <div class="product-card__media-wrap">
    <a href="{{ product.url }}" class="product-card__media" aria-label="{{ product.title | escape }}">
      {% if product.featured_image %}
        {% render 'image',
          image: product.featured_image,
          alt: product.featured_image.alt | default: product.title,
          fallback_alt: product.title,
          class: 'product-card__image',
          width: 600
        %}
        {% if second_image %}
          {% render 'image',
            image: second_image,
            alt: product.title,
            class: 'product-card__image product-card__image--hover',
            width: 600
          %}
        {% endif %}
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'product-card__placeholder' }}
      {% endif %}

      <div class="product-card__badges">
        {% if product.available == false %}
          <span class="product-card__badge product-card__badge--sold">{{ 'products.badges.sold_out' | t }}</span>
        {% else %}
          {% if is_new %}
            <span class="product-card__badge product-card__badge--new">{{ 'products.badges.new' | t }}</span>
          {% endif %}
          {% if promo_label != blank %}
            <span class="product-card__badge product-card__badge--promo">{{ promo_label }}</span>
          {% endif %}
          {% if on_sale %}
            {% if discount_percent > 0 %}
              <span class="product-card__badge product-card__badge--percent">
                {{ 'products.badges.percent_off' | t: percent: discount_percent }}
              </span>
            {% else %}
              <span class="product-card__badge product-card__badge--sale">{{ 'products.badges.sale' | t }}</span>
            {% endif %}
          {% endif %}
        {% endif %}
      </div>
    </a>

    {% if show_wishlist != false %}
      {% render 'wishlist-button', product: product %}
    {% endif %}

    <button
      type="button"
      class="product-card__quick-view"
      data-quick-view
      data-url="{{ product.url }}"
      aria-label="{{ 'products.quick_view' | t }}"
    >{% render 'icon-inline', name: 'eye' %}</button>

    {% if product.available %}
      <button
        type="button"
        class="product-card__quick-add"
        data-quick-add
        data-variant-id="{{ product.selected_or_first_available_variant.id }}"
        data-url="{{ product.url }}"
        data-single="{% if product.variants.size == 1 %}true{% else %}false{% endif %}"
        data-open-quick-view="{% if product.variants.size > 1 %}true{% else %}false{% endif %}"
      >{{ 'general.product.add_to_cart' | t }}</button>
    {% endif %}
  </div>

  <div class="product-card__info">
    <a href="{{ product.url }}" class="product-card__title-link">
      <h3 class="product-card__title">{% render 'tanween', text: product.title %}</h3>
    </a>
    <div class="product-card__rating"{% if rating == blank %} data-empty-rating{% endif %}>
      {% if rating != blank %}
        {% render 'rating-stars', rating: rating %}
        {% if product.metafields.reviews.rating_count.value != blank %}
          <span class="product-card__rating-count">({{ product.metafields.reviews.rating_count.value }})</span>
        {% endif %}
      {% else %}
        <a
          href="{{ product.url }}#judgeme_product_reviews"
          class="product-card__rating-cta"
          aria-label="{{ 'products.write_review' | t }}"
        >
          {% render 'rating-stars', rating: 0 %}
          <span class="product-card__write-review">{{ 'products.write_review' | t }}</span>
        </a>
      {% endif %}
    </div>
    <div class="product-card__price">
      {% if on_sale %}
        <s class="product-card__compare">{{ product.compare_at_price | money_without_currency }} {{ 'general.currency' | t }}</s>
      {% endif %}
      <span class="product-card__current">{{ product.price | money_without_currency }} {{ 'general.currency' | t }}</span>
    </div>
  </div>
</article>

{% stylesheet %}
  .product-card { position: relative; display: flex; flex-direction: column; height: 100%; border-radius: var(--style-border-radius-cards); overflow: hidden; background: var(--color-white); box-shadow: var(--shadow-soft); transition: transform var(--transition-base), box-shadow var(--transition-base); }
  .product-card:hover { transform: translateY(-4px); box-shadow: 0 12px 28px rgba(61,43,31,0.12); }
  .product-card__media-wrap { position: relative; }
  .product-card__media { position: relative; display: block; aspect-ratio: 1; overflow: hidden; background: var(--color-sand); }
  .product-card__image { width: 100%; height: 100%; object-fit: cover; transition: opacity var(--transition-base), transform 0.6s ease; }
  .product-card__image--hover { position: absolute; inset: 0; opacity: 0; }
  .product-card__media-wrap:hover .product-card__image--hover { opacity: 1; }
  .product-card__media-wrap:hover .product-card__image:not(.product-card__image--hover) { transform: scale(1.03); }
  .product-card__badges { position: absolute; top: 0.75rem; inset-inline-start: 0.75rem; display: flex; flex-direction: column; gap: 0.35rem; }
  .product-card__badge { padding: 0.2rem 0.7rem; border-radius: 999px; font-size: 0.72rem; font-weight: 700; color: var(--color-white); }
  .product-card__badge--new {
    background: var(--color-white);
    color: var(--color-primary);
    border: 1px solid var(--color-primary);
  }
  .product-card__badge--sale { background: var(--color-gold); }
  .product-card__badge--percent { background: var(--color-primary); }
  .product-card__badge--promo { background: var(--color-primary-dark); }
  .product-card__badge--sold { background: #6b635c; }
  .product-card__quick-add {
    position: absolute;
    inset-inline: 0.75rem;
    bottom: 0.75rem;
    padding: 0.6rem;
    border: none;
    border-radius: 999px;
    background: var(--color-primary);
    color: var(--color-primary-foreground);
    font: inherit;
    font-weight: 700;
    cursor: pointer;
    opacity: 0;
    transform: translateY(0.5rem);
    box-shadow: 0 6px 18px rgba(122, 31, 43, 0.3);
    transition: opacity var(--transition-base), transform var(--transition-base), background var(--transition-base);
  }
  .product-card__quick-add:hover { background: var(--color-primary-dark); }
  .product-card__media-wrap:hover .product-card__quick-add,
  .product-card__quick-add:focus-visible { opacity: 1; transform: translateY(0); }
  @media (hover: none) {
    .product-card__quick-add {
      opacity: 1;
      transform: none;
      font-size: 0.8125rem;
      padding: 0.5rem 0.75rem;
    }
  }
  .product-card__quick-view {
    position: absolute;
    top: 3.25rem;
    inset-inline-end: 0.75rem;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    border: none;
    background: var(--color-white);
    color: var(--color-primary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-soft);
    z-index: 2;
    opacity: 0;
    transform: translateY(-0.35rem);
    transition: opacity var(--transition-base), transform var(--transition-base), color var(--transition-base);
  }
  .product-card__quick-view svg { width: 1.15rem; height: 1.15rem; }
  .product-card__quick-view:hover { color: var(--color-primary-dark); }
  .product-card__media-wrap:hover .product-card__quick-view,
  .product-card__quick-view:focus-visible { opacity: 1; transform: translateY(0); }
  @media (hover: none) { .product-card__quick-view { opacity: 1; transform: none; } }
  .product-card__info { padding: 1rem; display: flex; flex-direction: column; flex: 1; }
  .product-card__title-link { text-decoration: none; color: inherit; }
  .product-card__title {
    font-size: 0.95rem;
    font-weight: 600;
    margin-block-end: 0.5rem;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: calc(2 * 1.4 * 0.95rem);
  }
  .product-card__rating { display: flex; align-items: center; gap: 0.35rem; margin-block-end: 0.4rem; color: var(--color-gold); min-height: 1.15rem; }
  .product-card__rating-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    text-decoration: none;
    color: inherit;
  }
  .product-card__rating-cta .rating-stars { color: color-mix(in srgb, var(--color-gold) 55%, #cfc8be); }
  .product-card__write-review {
    color: var(--color-accent);
    font-size: 0.75rem;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 0.12em;
  }
  .product-card__rating-count { color: #999; font-size: 0.8rem; }
  .product-card__price { display: flex; gap: 0.5rem; align-items: center; margin-block-start: auto; }
  .product-card__compare { color: #6b635c; font-size: 0.85rem; text-decoration-thickness: 1px; }
  .product-card__current { color: var(--color-primary-dark); font-weight: 700; font-size: 1rem; }
{% endstylesheet %}
