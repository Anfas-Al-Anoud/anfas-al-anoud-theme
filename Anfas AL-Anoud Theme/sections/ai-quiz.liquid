<section class="ai-quiz section-padding" id="ai-quiz" data-animate-section>
  <div class="ai-quiz__inner">
    <div class="ai-quiz__intro">
      {% if section.settings.avatar %}
        {% render 'image', image: section.settings.avatar, alt: 'صورة العنود للمساعدة', class: 'ai-quiz__avatar', width: 120 %}
      {% endif %}
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
      <p class="section-subheading">{{ section.settings.subheading }}</p>
    </div>

    <div class="ai-quiz__widget" data-ai-quiz>
      <div class="ai-quiz__step" data-quiz-step="1">
        <p class="ai-quiz__question">شو المناسبة اللي تبين الريحة لها؟</p>
        <div class="ai-quiz__options">
          <button type="button" class="btn btn--outline" data-quiz-value="work">دوام وطلعات</button>
          <button type="button" class="btn btn--outline" data-quiz-value="evening">سهرات وعزايم</button>
          <button type="button" class="btn btn--outline" data-quiz-value="home">ميلس ومواجيب</button>
          <button type="button" class="btn btn--outline" data-quiz-value="gift">هدية</button>
        </div>
      </div>

      <div class="ai-quiz__step" data-quiz-step="2" hidden>
        <p class="ai-quiz__question">ايش نوع المنتج اللي تدورين عليه؟</p>
        <div class="ai-quiz__options">
          <button type="button" class="btn btn--outline" data-quiz-value="dokhoon">دخون</button>
          <button type="button" class="btn btn--outline" data-quiz-value="perfume">عطور</button>
          <button type="button" class="btn btn--outline" data-quiz-value="care">دلع وعناية</button>
          <button type="button" class="btn btn--outline" data-quiz-value="box">بوكسات</button>
        </div>
      </div>

      <div class="ai-quiz__step" data-quiz-step="3" hidden>
        <p class="ai-quiz__question">شو المزاج اللي تحبينه؟</p>
        <div class="ai-quiz__options">
          <button type="button" class="btn btn--outline" data-quiz-value="light">خفيف ومنعش</button>
          <button type="button" class="btn btn--outline" data-quiz-value="rich">فخم وقوي</button>
          <button type="button" class="btn btn--outline" data-quiz-value="soft">ناعم ورومانسي</button>
        </div>
      </div>

      <div class="ai-quiz__results" data-quiz-results hidden>
        <p class="ai-quiz__results-title">هذي اقتراحاتي لج:</p>
        <div class="ai-quiz__products" data-quiz-products></div>
        <button type="button" class="btn btn--outline" data-quiz-restart>ابدأي من جديد</button>
      </div>
    </div>
  </div>

  <script type="application/json" data-quiz-catalog>
    [
      {% assign first = true %}
      {% for product in collections.all.products limit: 50 %}
        {% unless first %},{% endunless %}
        {
          "id": {{ product.id }},
          "title": {{ product.title | json }},
          "url": {{ product.url | json }},
          "type": {{ product.type | json }},
          "tags": {{ product.tags | json }},
          "image": {{ product.featured_image | image_url: width: 300 | json }},
          "price": {{ product.price | money | json }}
        }
        {% assign first = false %}
      {% endfor %}
    ]
  </script>
</section>

<button type="button" class="ai-quiz__float" data-quiz-open aria-label="سولفي وياي">
  💬
</button>

{% stylesheet %}
  .ai-quiz__inner {
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }
  .ai-quiz__intro { text-align: center; margin-block-end: 2rem; }
  .ai-quiz__avatar {
    width: 5rem;
    height: 5rem;
    border-radius: 50%;
    object-fit: cover;
    margin-inline: auto;
    margin-block-end: 1rem;
  }
  .ai-quiz__widget {
    background: var(--color-white);
    border-radius: var(--style-border-radius-cards);
    padding: 2rem;
    box-shadow: var(--shadow-soft);
    max-width: 36rem;
    margin-inline: auto;
  }
  .ai-quiz__question {
    font-weight: 700;
    font-size: 1.1rem;
    margin-block-end: 1.25rem;
    text-align: center;
  }
  .ai-quiz__options {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
  .ai-quiz__products {
    display: grid;
    gap: 1rem;
    margin-block: 1.5rem;
  }
  .ai-quiz__product-link {
    display: flex;
    gap: 1rem;
    align-items: center;
    text-decoration: none;
    color: var(--color-dark);
    padding: 0.75rem;
    border-radius: var(--style-border-radius-cards);
    background: var(--color-cream);
  }
  .ai-quiz__product-link img { width: 4rem; height: 4rem; object-fit: cover; border-radius: 8px; }
  .ai-quiz__float {
    position: fixed;
    bottom: 5rem;
    inset-inline-start: 1.25rem;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    background: var(--color-gold);
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    box-shadow: var(--shadow-soft);
    z-index: 90;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.ai_quiz.name",
  "class": "ai-quiz-section",
  "settings": [
    { "type": "image_picker", "id": "avatar", "label": "صورة العنود (anoud-avatar.png)" },
    { "type": "text", "id": "heading", "label": "العنوان", "default": "سولفي وياي" },
    { "type": "textarea", "id": "subheading", "label": "النص", "default": "محتارة شو اللي يلوق على شخصيتج؟ أنا هنيه عشان أساعدج تختارين صح." }
  ],
  "presets": [{ "name": "t:sections.ai_quiz.name" }]
}
{% endschema %}
