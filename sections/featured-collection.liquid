{% liquid
  assign featured_products = section.settings.collection.products
  if featured_products == blank or featured_products.size == 0
    assign featured_products = collections.all.products
  endif
%}
<section class="featured-collection section-padding" data-animate-section>
  <h2 class="section-heading">{{ section.settings.heading }}</h2>
  {% if section.settings.subheading != blank %}
    <p class="section-subheading">{{ section.settings.subheading }}</p>
  {% endif %}

  {% if featured_products.size > 0 %}
    <div class="featured-collection__carousel" data-carousel>
      <button type="button" class="featured-collection__nav featured-collection__nav--prev" data-carousel-prev aria-label="السابق">&lsaquo;</button>
      <div class="featured-collection__track-wrap">
        <div class="featured-collection__track" data-carousel-track>
          {% for product in featured_products limit: section.settings.products_to_show %}
            <div class="featured-collection__slide">
              {% render 'product-card', product: product %}
            </div>
          {% endfor %}
        </div>
      </div>
      <button type="button" class="featured-collection__nav featured-collection__nav--next" data-carousel-next aria-label="التالي">&rsaquo;</button>
    </div>
  {% endif %}
</section>

{% stylesheet %}
  .featured-collection__carousel {
    position: relative;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }
  .featured-collection__track-wrap {
    overflow: hidden;
  }
  .featured-collection__track {
    display: flex;
    gap: 1.25rem;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-block: 0.5rem;
    padding-inline: 0.25rem;
  }
  .featured-collection__track::-webkit-scrollbar { display: none; }
  .featured-collection__slide {
    flex: 0 0 calc(78% - 0.625rem);
    scroll-snap-align: start;
    min-width: 0;
  }
  @media (min-width: 768px) {
    .featured-collection__carousel {
      padding-inline: calc(var(--page-margin) + 2rem);
    }
    .featured-collection__slide { flex: 0 0 calc(33.333% - 0.833rem); }
  }
  @media (min-width: 1024px) {
    .featured-collection__slide { flex: 0 0 calc(25% - 0.9375rem); }
  }
  .featured-collection__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    border: none;
    background: var(--color-primary);
    color: var(--color-primary-foreground);
    font-size: 1.5rem;
    cursor: pointer;
    z-index: 2;
    display: none;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 18px rgba(122, 31, 43, 0.28);
    transition: background var(--transition-base), transform var(--transition-base);
  }
  .featured-collection__nav:hover { background: var(--color-primary-dark); }
  @media (min-width: 768px) {
    .featured-collection__nav { display: flex; }
  }
  .featured-collection__nav--prev { inset-inline-start: 0; }
  .featured-collection__nav--next { inset-inline-end: 0; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.featured_collection.name",
  "class": "featured-collection-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "العنوان",
      "default": "الأكثر مبيعًا"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "النص الفرعي",
      "default": "هذي أكثر المنتجات اللي حبوها البنات ورجعوا طلبوها مرة ثانية.. جربيها وما بتندمين."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "المجموعة"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 20,
      "step": 1,
      "default": 8,
      "label": "عدد المنتجات"
    }
  ],
  "presets": [{ "name": "t:sections.featured_collection.name" }]
}
{% endschema %}
