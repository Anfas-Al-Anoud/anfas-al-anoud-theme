<section class="quality-banner section-padding full-width" data-animate-section>
  <div class="quality-banner__inner">
    <div class="quality-banner__media" aria-hidden="true">
      {% if section.settings.image %}
        {% render 'image', image: section.settings.image, alt: section.settings.image_alt, fallback_alt: section.settings.heading, class: 'quality-banner__image', width: 1200 %}
      {% elsif section.settings.image_asset != blank %}
        {% render 'theme-asset-image', asset: section.settings.image_asset, alt: section.settings.image_alt, class: 'quality-banner__image', width: 1200 %}
      {% endif %}
    </div>
    <div class="quality-banner__overlay">
      <h2 class="quality-banner__heading">{{ section.settings.heading }}</h2>
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="btn">{{ section.settings.button_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .quality-banner__inner {
    position: relative;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
    border-radius: var(--style-border-radius-cards);
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .quality-banner__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .quality-banner__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .quality-banner__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: clamp(1.25rem, 4vw, 3rem);
    background: linear-gradient(
      to top,
      rgba(61, 43, 31, 0.94) 0%,
      rgba(61, 43, 31, 0.78) 40%,
      rgba(61, 43, 31, 0.52) 100%
    );
  }

  .quality-banner__heading {
    color: var(--color-white);
    font-size: clamp(1.25rem, 3vw, 2rem);
    font-weight: 700;
    margin-block-end: 1.5rem;
    max-width: 40rem;
    line-height: 1.5;
    text-wrap: balance;
  }

  @media (max-width: 767px) {
    .quality-banner.section-padding {
      padding-block: clamp(0.75rem, 2.5vw, 1.25rem);
    }

    .quality-banner__inner {
      aspect-ratio: 5 / 3;
      max-width: none;
      margin-inline: 0;
      padding-inline: 0;
      border-radius: 0;
    }

    .quality-banner__overlay {
      padding: clamp(0.875rem, 3vw, 1.25rem);
    }

    .quality-banner__heading {
      font-size: clamp(0.875rem, 3.6vw, 1rem);
      margin-block-end: 0.75rem;
      line-height: 1.45;
    }

    .quality-banner__overlay .btn {
      padding: 0.5rem 1rem;
      font-size: 0.8125rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.quality_banner.name",
  "class": "quality-banner-section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "الصورة (ingredients-banner.jpg)" },
    { "type": "text", "id": "image_asset", "label": "ملف الصورة (assets/)", "default": "quality-banner-ingredients.jpg" },
    {
      "type": "text",
      "id": "image_alt",
      "label": "نص alt (مطلوب)",
      "default": "صورة تعبر عن جودة المكونات - أنفاس العنود",
      "info": "مطلوب لإمكانية الوصول ومحركات البحث. لا تتركي الحقل فارغًا."
    },
    { "type": "text", "id": "heading", "label": "العنوان", "default": "سر الزين في تفاصيلنا.. أنا دايمًا أختار لج أصفى المكونات عشان تميزج في كل خطوة." },
    { "type": "text", "id": "button_label", "label": "نص الزر", "default": "اكتشفي أسرار منتجاتي" },
    { "type": "url", "id": "button_link", "label": "الرابط" }
  ],
  "presets": [{ "name": "t:sections.quality_banner.name" }]
}
{% endschema %}
