<section class="testimonials section-padding" data-animate-section>
  <h2 class="section-heading">{{ section.settings.heading }}</h2>
  <p class="section-subheading">{{ section.settings.subheading }}</p>

  {%- liquid
    assign review_pool = section.settings.review_pool | default: 181
    assign visible_count = section.settings.visible_count | default: 10
  -%}

  <div
    class="testimonials__carousel carousel"
    data-testimonials
    data-reviews-pool="{{ review_pool }}"
    data-reviews-show="{{ visible_count }}"
    data-review-sample="{{ 'review-01.jpg' | asset_url | escape }}"
    data-review-alt="{{ section.settings.image_alt | escape }}"
    style="--carousel-gap: 0.5rem;"
  >
    <div class="carousel__track-wrap">
      <div class="carousel__track" data-carousel-track></div>
    </div>
    <div class="carousel__dots" data-carousel-dots role="tablist" aria-label="{{ section.settings.heading | escape }}"></div>
  </div>
</section>

{% stylesheet %}
  .testimonials__carousel {
    margin-block-start: 0.75rem;
  }

  .testimonials__slide {
    flex: 0 0 calc(66% - 0.25rem);
    width: calc(66% - 0.25rem);
    margin: 0;
    scroll-snap-align: center;
  }

  @media (min-width: 768px) {
    .testimonials__slide {
      flex: 0 0 calc(24% - 0.4rem);
      width: calc(24% - 0.4rem);
    }
  }

  .testimonials__phone {
    position: relative;
    background: var(--color-white);
    border-radius: 1.5rem;
    padding: 0.5rem;
    box-shadow: 0 14px 34px rgba(61, 43, 31, 0.14);
    border: 1px solid color-mix(in srgb, var(--color-sand) 70%, transparent);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .testimonials__phone::after {
    content: '';
    position: absolute;
    inset-block-start: 0.9rem;
    inset-inline-start: 50%;
    transform: translateX(-50%);
    width: 34%;
    height: 0.28rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-sand) 85%, transparent);
    z-index: 2;
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .testimonials__slide:hover .testimonials__phone {
      transform: translateY(-4px);
      box-shadow: 0 20px 44px rgba(61, 43, 31, 0.2);
    }
  }

  .testimonials__shot {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 1.05rem;
    object-fit: cover;
    aspect-ratio: 9 / 16;
    object-position: top;
    background: color-mix(in srgb, var(--color-sand) 30%, var(--color-white));
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    function shuffle(arr) {
      for (let i = arr.length - 1; i > 0; i -= 1) {
        const j = Math.floor(Math.random() * (i + 1));
        [arr[i], arr[j]] = [arr[j], arr[i]];
      }
      return arr;
    }

    function reviewFileName(n) {
      return n < 10 ? `review-0${n}.jpg` : `review-${n}.jpg`;
    }

    function reviewUrlFromSample(sampleUrl, n) {
      return sampleUrl.replace(/review-\d+\.jpg/, reviewFileName(n));
    }

    function tryInit(section) {
      if (window.initCarousels) {
        window.initCarousels(section.parentNode || document);
      } else {
        setTimeout(function () { tryInit(section); }, 120);
      }
    }

    function buildReviews(root) {
      root.querySelectorAll('[data-testimonials]:not([data-testimonials-ready])').forEach((section) => {
        const track = section.querySelector('[data-carousel-track]');
        const sample = section.getAttribute('data-review-sample');
        if (!track || !sample) return;

        section.setAttribute('data-testimonials-ready', '');

        const pool = parseInt(section.getAttribute('data-reviews-pool'), 10) || 181;
        const show = parseInt(section.getAttribute('data-reviews-show'), 10) || 10;
        const alt = section.getAttribute('data-review-alt') || '';
        const keep = Math.min(show, pool);

        const indices = Array.from({ length: pool }, (_, i) => i + 1);
        shuffle(indices);

        indices.slice(0, keep).forEach((n) => {
          const figure = document.createElement('figure');
          figure.className = 'carousel__slide testimonials__slide';
          figure.setAttribute('data-review-slide', '');

          const phone = document.createElement('div');
          phone.className = 'testimonials__phone';

          const img = document.createElement('img');
          img.src = reviewUrlFromSample(sample, n);
          img.alt = alt;
          img.className = 'testimonials__shot';
          img.loading = 'lazy';
          img.decoding = 'async';
          img.width = 400;
          img.height = 711;

          phone.appendChild(img);
          figure.appendChild(phone);
          track.appendChild(figure);
        });

        section.setAttribute('data-carousel', '');
        tryInit(section);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => buildReviews(document));
    } else {
      buildReviews(document);
    }

    document.addEventListener('shopify:section:load', (event) => {
      buildReviews(event.target || document);
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.testimonials.name",
  "class": "testimonials-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "العنوان", "default": "شو قالوا عنا الحبايب؟" },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "النص",
      "default": "تصفحي سوالف وتجارب البنات اللي وثقوا فينا."
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "نص alt للقطات",
      "default": "رأي عميلة من متجر أنفاس العنود"
    },
    {
      "type": "range",
      "id": "review_pool",
      "label": "إجمالي لقطات الشاشة المتوفرة (assets/review-XX.jpg)",
      "min": 4,
      "max": 181,
      "step": 1,
      "default": 181
    },
    {
      "type": "range",
      "id": "visible_count",
      "label": "عدد اللقطات المعروضة عشوائيًا في كل مرة",
      "min": 4,
      "max": 40,
      "step": 1,
      "default": 10
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "رأي",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "النص" },
        { "type": "text", "id": "author", "label": "الاسم" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.testimonials.name"
    }
  ]
}
{% endschema %}
