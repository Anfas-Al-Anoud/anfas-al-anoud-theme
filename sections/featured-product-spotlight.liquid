{% liquid
  assign product = section.settings.product
  assign on_sale = false
  assign discount_percent = 0
  if product != blank
    if product.compare_at_price > product.price
      assign on_sale = true
      assign savings = product.compare_at_price | minus: product.price
      assign discount_percent = savings | times: 100 | divided_by: product.compare_at_price
    endif
  endif
%}

{% if product != blank %}
  <section class="product-spotlight section-padding" data-animate-section>
    <div class="product-spotlight__shell">
      <article class="product-spotlight__inner">
        <a href="{{ product.url }}" class="product-spotlight__media" aria-label="{{ product.title | escape }}">
          {% if product.featured_image %}
            {% render 'image',
              image: product.featured_image,
              alt: product.featured_image.alt | default: product.title,
              fallback_alt: product.title,
              class: 'product-spotlight__image',
              width: 1200
            %}
          {% else %}
            {{ 'product-1' | placeholder_svg_tag: 'product-spotlight__image product-spotlight__placeholder' }}
          {% endif %}
        </a>

        <div class="product-spotlight__panel">
          {% if section.settings.badge != blank %}
            <p class="product-spotlight__badge">{{ section.settings.badge }}</p>
          {% elsif on_sale %}
            {% if discount_percent > 0 %}
              <p class="product-spotlight__badge">{{ 'products.badges.percent_off' | t: percent: discount_percent }}</p>
            {% else %}
              <p class="product-spotlight__badge">{{ 'products.badges.sale' | t }}</p>
            {% endif %}
          {% endif %}

          {% if section.settings.heading != blank %}
            <h2 class="product-spotlight__heading">{{ section.settings.heading }}</h2>
          {% else %}
            <h2 class="product-spotlight__heading">{% render 'tanween', text: product.title %}</h2>
          {% endif %}

          {% if section.settings.subheading != blank %}
            <p class="product-spotlight__subheading">{{ section.settings.subheading }}</p>
          {% endif %}

          <div class="product-spotlight__price">
            {% if on_sale %}
              <s class="product-spotlight__compare">{{ product.compare_at_price | money_with_currency }}</s>
            {% endif %}
            <span class="product-spotlight__current">{{ product.price | money_with_currency }}</span>
          </div>

          {% if product.available %}
            {% if product.variants.size == 1 %}
              <button
                type="button"
                class="btn product-spotlight__btn"
                data-quick-add
                data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                data-url="{{ product.url }}"
                data-single="true"
              >
                {{ 'general.product.add_to_cart' | t }}
              </button>
            {% else %}
              <a href="{{ product.url }}" class="btn product-spotlight__btn">
                {{ 'products.view_details' | t }}
              </a>
            {% endif %}
          {% else %}
            <span class="product-spotlight__sold">{{ 'products.badges.sold_out' | t }}</span>
          {% endif %}
        </div>
      </article>
    </div>
  </section>
{% endif %}

{% stylesheet %}
  .product-spotlight__shell {
    width: 100%;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }

  .product-spotlight__inner {
    display: grid;
    gap: 0;
    overflow: hidden;
    border-radius: var(--style-border-radius-cards);
    background: var(--color-dark);
    box-shadow: var(--shadow-soft);
  }

  .product-spotlight__media {
    display: block;
    position: relative;
    overflow: hidden;
    min-height: 12rem;
  }

  .product-spotlight__image {
    width: 100%;
    height: 100%;
    min-height: 12rem;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .product-spotlight__placeholder {
    width: 100%;
    min-height: 12rem;
    background: var(--color-sand);
  }

  .product-spotlight__panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: clamp(1.15rem, 3.2vw, 1.75rem);
    background: rgba(61, 43, 31, 0.94);
    color: var(--color-white);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-gold) 35%, transparent);
  }

  .product-spotlight__badge {
    display: inline-block;
    margin: 0 0 0.75rem;
    padding: 0.3rem 0.85rem;
    border-radius: 999px;
    background: var(--color-gold);
    color: var(--color-dark);
    font-size: 0.75rem;
    font-weight: 700;
  }

  .product-spotlight__heading {
    margin: 0 0 0.55rem;
    font-size: clamp(1.2rem, 2.6vw, 1.75rem);
    font-weight: 700;
    line-height: 1.35;
    text-wrap: balance;
    color: var(--color-white);
  }

  .product-spotlight__subheading {
    margin: 0 0 1rem;
    max-width: 22rem;
    font-size: 0.9rem;
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-white) 88%, transparent);
  }

  .product-spotlight__price {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: center;
    gap: 0.5rem 0.75rem;
    margin-block-end: 1.15rem;
  }

  .product-spotlight__compare {
    color: color-mix(in srgb, var(--color-white) 65%, transparent);
    font-size: 0.9375rem;
  }

  .product-spotlight__current {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--color-gold);
  }

  .product-spotlight__btn {
    display: block;
    width: min(100%, 16rem);
    margin-inline: auto;
  }

  .product-spotlight__sold {
    display: inline-block;
    font-weight: 700;
    color: color-mix(in srgb, var(--color-white) 75%, transparent);
  }

  @media (min-width: 768px) {
    .product-spotlight.section-padding {
      padding-block: clamp(1.5rem, 3vw, 2.5rem);
    }

    .product-spotlight__inner {
      grid-template-columns: 1.25fr 0.75fr;
      min-height: 20rem;
    }

    .product-spotlight__media {
      min-height: 20rem;
    }

    .product-spotlight__image {
      min-height: 20rem;
    }

    .product-spotlight__panel {
      padding: clamp(1.75rem, 3.5vw, 2.75rem) clamp(1.5rem, 3vw, 2.25rem);
      gap: 0.15rem;
    }

    .product-spotlight__heading {
      font-size: clamp(1.45rem, 2.2vw, 1.9rem);
    }

    .product-spotlight__subheading {
      font-size: 0.95rem;
      margin-block-end: 1.15rem;
    }

    .product-spotlight__price {
      margin-block-end: 1.35rem;
    }
  }

  @media (max-width: 767px) {
    .product-spotlight.section-padding {
      padding-block: 0.875rem;
    }

    .product-spotlight__shell {
      padding-inline: var(--page-margin);
    }

    .product-spotlight__media {
      aspect-ratio: 1.35 / 1;
      min-height: 0;
    }

    .product-spotlight__image {
      min-height: 0;
      height: 100%;
    }

    .product-spotlight__panel {
      align-items: center;
      text-align: center;
    }

    .product-spotlight__btn {
      width: min(100%, 16rem);
      margin-inline: auto;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.featured_product_spotlight.name",
  "class": "product-spotlight-section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "المنتج"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "عنوان مخصص (اختياري)"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "نص فرعي (اختياري)"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "شارة العرض",
      "default": "عرض محدود"
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured_product_spotlight.name"
    }
  ]
}
{% endschema %}
