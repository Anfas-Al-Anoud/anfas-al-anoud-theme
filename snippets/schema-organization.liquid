{%- liquid
  assign socials = ''
  if settings.social_instagram != blank
    assign socials = socials | append: settings.social_instagram | append: '||'
  endif
  if settings.social_tiktok != blank
    assign socials = socials | append: settings.social_tiktok | append: '||'
  endif
  if settings.social_snapchat != blank
    assign socials = socials | append: settings.social_snapchat | append: '||'
  endif
  if settings.social_facebook != blank
    assign socials = socials | append: settings.social_facebook | append: '||'
  endif
  if settings.social_threads != blank
    assign socials = socials | append: settings.social_threads | append: '||'
  endif
  assign social_list = socials | split: '||'

  assign phone = settings.whatsapp_number | remove: '+' | remove: ' '
-%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": {{ 'general.brand_name' | t | json }},
  "url": {{ shop.url | json }},
  {% if settings.logo %}"logo": "https:{{ settings.logo | image_url: width: 500 }}",{% endif %}
  "description": "متجر أنفاس العنود - دخون منزلي (كرات معمول) وعطور ومنتجات عناية فاخرة للسوق الإماراتي",
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "AE"
  }{% if phone != blank %},
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+{{ phone }}",
    "contactType": "customer service",
    "areaServed": "AE",
    "availableLanguage": ["ar", "en"]
  }{% endif %}{% if social_list.size > 0 %},
  "sameAs": [{% for s in social_list %}{{ s | json }}{% unless forloop.last %},{% endunless %}{% endfor %}]{% endif %}
}
</script>

{% if request.page_type == 'index' %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": {{ 'general.brand_name' | t | json }},
    "url": {{ shop.url | json }},
    "inLanguage": "ar-AE",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "{{ shop.url }}{{ routes.search_url }}?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>
{% endif %}
