<section class="product-reviews section-padding" {{ section.shopify_attributes }}>
  <div class="product-reviews__inner">
    <h2 class="section-heading">{{ section.settings.heading }}</h2>
    {% if section.settings.subheading != blank %}
      <p class="section-subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    {% render 'judge-me-review-widget' %}

    {% content_for 'blocks' %}

    {% if section.blocks.size == 0 and request.design_mode %}
      <div class="product-reviews__install-hint">
        <p>{{ section.settings.install_hint }}</p>
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .product-reviews__inner {
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }

  .product-reviews__install-hint {
    margin-block-start: 1rem;
    padding: 1rem 1.25rem;
    border-radius: var(--style-border-radius-cards);
    background: color-mix(in srgb, var(--color-sand) 55%, var(--color-white));
    color: var(--color-accent);
    line-height: 1.7;
    text-align: center;
  }

  .product-reviews__install-hint p {
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "تقييمات المنتج",
  "class": "product-reviews-section",
  "blocks": [{ "type": "@app" }],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "العنوان",
      "default": "تقييمات البنات"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "وصف مختصر",
      "default": "شاركي تجربتج وساعدي بنات ثانيين يختارون بثقة."
    },
    {
      "type": "textarea",
      "id": "install_hint",
      "label": "تلميح قبل تثبيت التطبيق",
      "default": "ثبّتي تطبيق Judge.me من متجر تطبيقات Shopify وأكملي خطوة التثبيت. ويدجت التقييمات مضاف في الثيم تلقائيًا."
    }
  ],
  "presets": [{ "name": "تقييمات المنتج" }]
}
{% endschema %}
