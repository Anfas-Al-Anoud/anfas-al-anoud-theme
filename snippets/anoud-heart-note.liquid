{% doc %}
  Heart closing note from Al-Anoud — used on about page and near checkout.

  @param {string} [heading] - Optional heading override
  @param {string} [body] - Optional body override
  @param {string} [signature] - Optional signature override
  @param {string} [variant] - Visual variant: default | compact
{% enddoc %}

{%- liquid
  assign note_heading = heading | default: 'رسالة من قلبي لقلبج..'
  assign note_body = body | default: 'شكرًا إنج وثقني بج، وخلّيتي أنفاس العنود جزء من يومج. الله يخلّيج لأهلك وتبقين دائمًا على أحلى روائحج.'
  assign note_signature = signature | default: 'العنود'
  assign note_variant = variant | default: 'default'
-%}

<aside class="anoud-heart-note anoud-heart-note--{{ note_variant }}">
  <div class="anoud-heart-note__icon" aria-hidden="true">
    {{ 'icon-policy-heart.svg' | inline_asset_content }}
  </div>
  <div class="anoud-heart-note__content">
    <p class="anoud-heart-note__heading">{{ note_heading }}</p>
    <p class="anoud-heart-note__body">{{ note_body }}</p>
    <p class="anoud-heart-note__signature">{{ note_signature }}</p>
  </div>
</aside>

{% stylesheet %}
  .anoud-heart-note {
    display: flex;
    gap: 0.85rem;
    align-items: flex-start;
    padding: 1rem 1.1rem;
    border-radius: var(--style-border-radius-cards);
    background: color-mix(in srgb, var(--color-cream) 88%, var(--color-gold));
    border: 1px solid color-mix(in srgb, var(--color-gold) 35%, transparent);
  }

  .anoud-heart-note__icon {
    width: 2.25rem;
    height: 2.25rem;
    flex-shrink: 0;
    color: var(--color-primary);
  }

  .anoud-heart-note__icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .anoud-heart-note__heading {
    margin: 0 0 0.35rem;
    font-weight: 700;
    color: var(--color-dark);
  }

  .anoud-heart-note__body {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--color-accent);
  }

  .anoud-heart-note__signature {
    margin: 0.55rem 0 0;
    font-weight: 700;
    color: var(--color-primary);
  }

  .anoud-heart-note--compact {
    padding: 0.85rem 0.95rem;
    margin-block: 0.35rem 0.75rem;
  }

  .anoud-heart-note--compact .anoud-heart-note__body {
    font-size: 0.84rem;
    line-height: 1.6;
  }
{% endstylesheet %}
