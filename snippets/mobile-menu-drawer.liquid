{% doc %}
  App-style mobile menu bottom sheet (mobile only). Opened by the header
  hamburger ([data-menu-toggle]) and the bottom-nav menu button
  ([data-mobile-menu-open]); open/close/scroll-lock are wired in theme.js.

  @example
  {% render 'mobile-menu-drawer' %}
{% enddoc %}

<button
  type="button"
  class="mobile-menu-backdrop"
  data-mobile-menu-backdrop
  aria-label="{{ 'general.accessibility.close' | t }}"
  hidden
></button>

<div class="mobile-menu" data-mobile-menu role="dialog" aria-modal="true" aria-labelledby="MobileMenuTitle" hidden>
  <div class="mobile-menu__handle" aria-hidden="true"></div>
  <div class="mobile-menu__head">
    <h2 class="mobile-menu__title" id="MobileMenuTitle">{{ 'general.nav.menu' | t }}</h2>
    <button type="button" class="mobile-menu__close" data-mobile-menu-close aria-label="{{ 'general.accessibility.close' | t }}">
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>
  </div>

  <nav class="mobile-menu__body" aria-label="{{ 'general.accessibility.menu' | t }}">
    <ul class="mobile-menu__links">
      {%- if linklists.main-menu.links.size > 0 -%}
        {%- for link in linklists.main-menu.links -%}
          <li>
            <a href="{{ link.url }}" class="mobile-menu__link">{% render 'tanween', text: link.title %}</a>
            {%- if link.links != blank -%}
              <ul class="mobile-menu__sublinks">
                {%- for child in link.links -%}
                  <li><a href="{{ child.url }}" class="mobile-menu__sublink">{% render 'tanween', text: child.title %}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </li>
        {%- endfor -%}
      {%- else -%}
        <li><a href="{{ routes.root_url }}" class="mobile-menu__link">{{ 'general.nav.home' | t }}</a></li>
        <li><a href="{{ routes.all_products_collection_url }}" class="mobile-menu__link">{{ 'collections.title' | t }}</a></li>
      {%- endif -%}
      {%- if shop.customer_accounts_enabled -%}
        <li><a href="{{ routes.account_url }}" class="mobile-menu__link">حسابج</a></li>
      {%- endif -%}
    </ul>

    {%- if settings.nav_promo_enabled and settings.nav_promo_text != blank -%}
      <a href="{{ settings.nav_promo_link | default: '/collections/offers' }}" class="mobile-menu__promo">
        <span class="mobile-menu__promo-badge">{{ 'general.nav.promo' | t }}</span>
        <span>{% render 'tanween', text: settings.nav_promo_text %}</span>
      </a>
    {%- endif -%}

    {%- if settings.whatsapp_number != blank -%}
      <a
        href="https://wa.me/{{ settings.whatsapp_number | remove: '+' | remove: ' ' }}"
        class="mobile-menu__whatsapp"
        target="_blank"
        rel="noopener noreferrer"
      >
        {{ 'icon-whatsapp.svg' | inline_asset_content }}
        <span>رمسيني على واتساب</span>
      </a>
    {%- endif -%}
  </nav>
</div>

{% stylesheet %}
  .mobile-menu-backdrop {
    position: fixed;
    inset: 0;
    z-index: 110;
    border: none;
    padding: 0;
    background: rgba(31, 18, 12, 0.5);
    opacity: 0;
    transition: opacity var(--transition-base);
  }
  .mobile-menu-backdrop.is-open { opacity: 1; }
  .mobile-menu-backdrop[hidden] { display: none; }
  .mobile-menu {
    position: fixed;
    inset-inline: 0;
    bottom: 0;
    z-index: 111;
    background: var(--color-white);
    border-start-start-radius: 1.5rem;
    border-start-end-radius: 1.5rem;
    padding: 0.75rem 1.25rem calc(1.25rem + env(safe-area-inset-bottom));
    box-shadow: 0 -12px 40px rgba(61, 43, 31, 0.2);
    transform: translateY(100%);
    transition: transform 0.32s cubic-bezier(0.22, 1, 0.36, 1);
    max-height: 80vh;
    overflow-y: auto;
  }
  .mobile-menu.is-open { transform: translateY(0); }
  .mobile-menu[hidden] { display: none; }
  .mobile-menu__handle {
    width: 2.75rem;
    height: 0.3rem;
    border-radius: 999px;
    background: var(--color-sand);
    margin: 0 auto 0.75rem;
  }
  .mobile-menu__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-block-end: 0.5rem;
  }
  .mobile-menu__title { font-size: 1.15rem; color: var(--color-primary); margin: 0; }
  .mobile-menu__close {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-dark);
    padding: 0.25rem;
  }
  .mobile-menu__close svg { width: 1.5rem; height: 1.5rem; }
  .mobile-menu__links { list-style: none; margin: 0; padding: 0; }
  .mobile-menu__link {
    display: block;
    padding: 0.9rem 0.25rem;
    text-decoration: none;
    color: var(--color-dark);
    font-weight: 600;
    font-size: 1.05rem;
    border-block-end: 1px solid color-mix(in srgb, var(--color-sand) 60%, transparent);
  }
  .mobile-menu__link:hover { color: var(--color-primary); }
  .mobile-menu__sublinks { list-style: none; margin: 0; padding: 0 0 0.35rem 1rem; }
  .mobile-menu__sublink {
    display: block;
    padding: 0.45rem 0.25rem;
    text-decoration: none;
    color: var(--color-accent);
    font-size: 0.95rem;
  }
  .mobile-menu__promo {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-block: 1rem 0.25rem;
    padding: 0.9rem 1rem;
    border-radius: var(--style-border-radius-cards);
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    color: var(--color-primary-foreground);
    text-decoration: none;
    font-weight: 700;
  }
  .mobile-menu__promo-badge {
    font-size: 0.72rem;
    opacity: 0.9;
    letter-spacing: 0.04em;
  }
  .mobile-menu__whatsapp {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    margin-block-start: 1.25rem;
    padding: 0.85rem 1rem;
    border-radius: 999px;
    background: #25D366;
    color: #fff;
    font-weight: 700;
    text-decoration: none;
  }
  .mobile-menu__whatsapp svg { width: 1.35rem; height: 1.35rem; }
  @media (min-width: 768px) {
    .mobile-menu,
    .mobile-menu-backdrop { display: none !important; }
  }
{% endstylesheet %}
