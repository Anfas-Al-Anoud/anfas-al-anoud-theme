{%- liquid
  assign header_style = settings.header_style | default: 'classic'
-%}
<div
  class="announcement-bar full-width announcement-bar--{{ header_style }}"
  role="region"
  aria-label="{{ 'sections.announcement_bar.name' | t }}"
>
  {%- if header_style == 'overlay' -%}
    <span class="announcement-bar__dots" aria-hidden="true"></span>
  {%- endif -%}

  <div class="announcement-bar__track">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        <p class="announcement-bar__text" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
      {% endfor %}
      {% for block in section.blocks %}
        <p class="announcement-bar__text announcement-bar__text--clone" aria-hidden="true">{{ block.settings.text }}</p>
      {% endfor %}
    {% else %}
      <p class="announcement-bar__text">{{ section.settings.text }}</p>
      <p class="announcement-bar__text announcement-bar__text--clone" aria-hidden="true">{{ section.settings.text }}</p>
    {% endif %}
  </div>

  {%- if header_style == 'overlay' -%}
    <span class="announcement-bar__chevron" aria-hidden="true">‹</span>
  {%- endif -%}
</div>

{% stylesheet %}
  .announcement-bar {
    background: var(--color-primary);
    color: var(--color-primary-foreground);
    overflow: hidden;
    padding-block: 0.625rem;
  }

  .announcement-bar__track {
    display: flex;
    width: max-content;
    animation: marquee 36s linear infinite;
  }

  .announcement-bar__text {
    white-space: nowrap;
    padding-inline: 3rem;
    font-size: 0.875rem;
    margin: 0;
  }

  .announcement-bar__dots,
  .announcement-bar__chevron {
    display: none;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes marquee-rtl {
    0% { transform: translateX(0); }
    100% { transform: translateX(50%); }
  }

  [dir="rtl"] .announcement-bar__track {
    animation-name: marquee-rtl;
  }

  /* Commerce: slightly tighter bar */
  .announcement-bar--commerce {
    padding-block: 0.48rem;
  }
  .announcement-bar--commerce .announcement-bar__track {
    width: 100%;
    animation: none;
    justify-content: center;
    overflow: hidden;
  }
  .announcement-bar--commerce .announcement-bar__text {
    padding-inline: 1rem;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-align: center;
    line-height: 1.35;
  }
  .announcement-bar--commerce .announcement-bar__text--clone,
  .announcement-bar--commerce .announcement-bar__text:not(:first-of-type) {
    display: none;
  }

  /* Overlay (IMG_7839): black bar + dots + chevron */
  .announcement-bar--overlay {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.35rem;
    background: #0a0a0a;
    color: #fff;
    padding-block: 0.55rem;
    padding-inline: 0.75rem;
  }
  .announcement-bar--overlay .announcement-bar__dots {
    display: block;
    width: 0.28rem;
    height: 0.28rem;
    border-radius: 50%;
    background: #fff;
    margin-inline-end: 0.85rem;
    box-shadow:
      0.42rem 0 0 rgba(255, 255, 255, 0.55),
      0.84rem 0 0 rgba(255, 255, 255, 0.35);
  }
  .announcement-bar--overlay .announcement-bar__track {
    width: 100%;
    max-width: 100%;
    animation: none;
    justify-content: center;
    overflow: hidden;
  }
  .announcement-bar--overlay .announcement-bar__text {
    padding-inline: 0.5rem;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-align: center;
  }
  .announcement-bar--overlay .announcement-bar__text--clone,
  .announcement-bar--overlay .announcement-bar__text:not(:first-of-type) {
    display: none;
  }
  .announcement-bar--overlay .announcement-bar__chevron {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    line-height: 1;
    opacity: 0.9;
    padding-inline: 0.15rem;
  }

  @media (max-width: 767px) {
    .announcement-bar {
      padding-block: 0.35rem;
    }
    .announcement-bar__text {
      font-size: 0.75rem;
      padding-inline: 1.75rem;
    }
    .announcement-bar--commerce {
      padding-block: 0.4rem;
    }
    .announcement-bar--commerce .announcement-bar__text {
      font-size: 0.6rem;
      padding-inline: 0.65rem;
    }
    .announcement-bar--overlay {
      padding-block: 0.5rem;
    }
    .announcement-bar--overlay .announcement-bar__text {
      font-size: 0.62rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .announcement-bar__track {
      animation: none;
      width: 100%;
      flex-wrap: wrap;
      justify-content: center;
    }
    .announcement-bar__text--clone {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.announcement_bar.name",
  "class": "announcement-bar-section",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "text",
