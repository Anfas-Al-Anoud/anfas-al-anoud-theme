<section
  class="product-recommendations section-padding"
  data-recommendations
  data-url="{{ routes.product_recommendations_url }}?product_id={{ product.id }}&limit={{ section.settings.limit | default: 4 }}&section_id={{ section.id }}"
  {% if recommendations.performed and recommendations.products_count == 0 %}hidden{% endif %}
>
  <h2 class="section-heading">{{ section.settings.heading }}</h2>
  <div data-recommendations-grid>
    {% if recommendations.performed and recommendations.products_count > 0 %}
      {% capture rec_slides %}
        {% for rec_product in recommendations.products %}
          <div class="carousel__slide product-recommendations__slide">
            {% render 'product-card', product: rec_product %}
          </div>
        {% endfor %}
      {% endcapture %}
      {% render 'carousel',
        slides: rec_slides,
        class: 'product-recommendations__carousel',
        gap: '1rem',
        show_nav: true,
        show_dots: true
      %}
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .product-recommendations__slide {
    flex: 0 0 calc(72% - 0.5rem);
    width: calc(72% - 0.5rem);
  }

  @media (min-width: 768px) {
    .product-recommendations__slide {
      flex: 0 0 calc(33.333% - 0.667rem);
      width: calc(33.333% - 0.667rem);
    }
  }

  @media (min-width: 1024px) {
    .product-recommendations__slide {
      flex: 0 0 calc(25% - 0.75rem);
      width: calc(25% - 0.75rem);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product recommendations",
  "class": "product-recommendations-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "العنوان",
      "default": "قد يعجبج أيضًا"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4,
      "label": "عدد المنتجات"
    }
  ]
}
{% endschema %}
