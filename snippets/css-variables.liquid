{% liquid
  case settings.arabic_font_family
    when 'ibm_plex'
      assign font_primary = "'IBM Plex Sans Arabic', 'Noto Sans Arabic', sans-serif"
    when 'cairo'
      assign font_primary = "'Cairo', 'Noto Sans Arabic', sans-serif"
    else
      assign font_primary = "'Noto Sans Arabic', 'IBM Plex Sans Arabic', sans-serif"
  endcase
%}

{% style %}
  :root {
    --font-primary--family: {{ font_primary }};
    --font-primary--style: normal;
    --font-primary--weight: 400;
    --page-width: {{ settings.max_page_width }};
    --page-margin: {{ settings.min_page_margin }}px;
    --color-background: {{ settings.background_color }};
    --color-foreground: {{ settings.foreground_color }};
    --color-gold: {{ settings.colors.gold }};
    --color-sand: {{ settings.colors.sand }};
    --color-cream: {{ settings.colors.cream }};
    --color-dark: {{ settings.colors.dark }};
    --color-accent: {{ settings.colors.accent }};
    --color-white: {{ settings.colors.white }};
    --style-border-radius-inputs: {{ settings.input_corner_radius }}px;
    --style-border-radius-buttons: {{ settings.input_corner_radius }}px;
    --style-border-radius-cards: 12px;
    --transition-base: 0.25s ease;
    --shadow-soft: 0 4px 24px rgba(61, 43, 31, 0.08);
    --header-height: 4.5rem;
  }
{% endstyle %}
